@@ -0,0 +1,29 @@
+package com.eu.habbo.plugin.events.users;
+
+import com.eu.habbo.habbohotel.users.Habbo;
+
+/**
+ * Fired when a Habbo saves (or updates) a macro from the MacrosWindow.
+ * The {@code habbo} field is the owner; the requested binding's command
+ * + keybind + category travel as fields on this event so the plugin can
+ * persist them and broadcast a fresh MacrosListComposer back.
+ *
+ * {@code macroId} is 0 for new bindings; a non-zero id is currently
+ * unused (the plugin upserts on (habbo_id, keybind)) but is kept on the
+ * wire for future "edit-in-place" flows.
+ */
+public class UserMacroSaveRequestedEvent extends UserEvent {
+    public final int macroId;
+    public final String keybind;
+    public final String command;
+    public final String category;
+
+    public UserMacroSaveRequestedEvent(Habbo requester, int macroId, String keybind,
+                                       String command, String category) {
+        super(requester);
+        this.macroId = macroId;
+        this.keybind = keybind;
+        this.command = command;
+        this.category = category;
+    }
+}
