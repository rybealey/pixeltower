@@ -0,0 +1,29 @@
+package com.eu.habbo.messages.incoming.users;
+
+import com.eu.habbo.Emulator;
+import com.eu.habbo.messages.incoming.MessageHandler;
+import com.eu.habbo.plugin.events.users.UserMacroSaveRequestedEvent;
+
+/**
+ * Pixeltower-custom incoming packet (header 6555). Emitted by the
+ * MacrosWindow's "Add Macro" button. Wire format:
+ *   int macroId   (0 for a new macro; non-zero updates an existing row)
+ *   string keybind
+ *   string command
+ *   string category
+ * Length validation lives in the plugin's MacrosManager.save(); this
+ * handler is a thin bridge that just decodes and fires the event.
+ */
+public class PixeltowerSaveMacroEvent extends MessageHandler {
+    @Override
+    public void handle() throws Exception {
+        if (this.client == null || this.client.getHabbo() == null) return;
+        int macroId = this.packet.readInt();
+        String keybind = this.packet.readString();
+        String command = this.packet.readString();
+        String category = this.packet.readString();
+        Emulator.getPluginManager().fireEvent(
+                new UserMacroSaveRequestedEvent(
+                        this.client.getHabbo(), macroId, keybind, command, category));
+    }
+}
