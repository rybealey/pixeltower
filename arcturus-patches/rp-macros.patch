+import com.eu.habbo.habbohotel.users.Habbo;
+
+/**
+ * Fired when a Habbo deletes a macro from the MacrosWindow. Ownership
+ * is re-checked inside MacrosManager.delete() — passing this event does
+ * not authorize anything by itself.
+ */
+public class UserMacroDeleteRequestedEvent extends UserEvent {
+    public final int macroId;
+
+    public UserMacroDeleteRequestedEvent(Habbo requester, int macroId) {
+        super(requester);
+        this.macroId = macroId;
+    }
+}
