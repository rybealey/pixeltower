+package com.eu.habbo.messages.incoming.users;
+
+import com.eu.habbo.Emulator;
+import com.eu.habbo.messages.incoming.MessageHandler;
+import com.eu.habbo.plugin.events.users.UserMacroDeleteRequestedEvent;
+
+/**
+ * Pixeltower-custom incoming packet (header 6556). Emitted by the trash
+ * icon on each row of the MacrosWindow. Wire format: int macroId.
+ * Ownership is verified inside MacrosManager.delete().
+ */
+public class PixeltowerDeleteMacroEvent extends MessageHandler {
+    @Override
+    public void handle() throws Exception {
+        if (this.client == null || this.client.getHabbo() == null) return;
+        int macroId = this.packet.readInt();
+        Emulator.getPluginManager().fireEvent(
+                new UserMacroDeleteRequestedEvent(this.client.getHabbo(), macroId));
+    }
+}
