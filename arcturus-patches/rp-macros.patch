+package com.eu.habbo.messages.incoming.users;
+
+import com.eu.habbo.Emulator;
+import com.eu.habbo.messages.incoming.MessageHandler;
+import com.eu.habbo.plugin.events.users.UserMacrosRequestedEvent;
+
+/**
+ * Pixeltower-custom incoming packet (header 6554). Emitted by the patched
+ * Nitro MacrosWindow on open and by MacrosKeybindListener on mount. Body
+ * is empty. The handler is a thin bridge — it just fires
+ * {@link UserMacrosRequestedEvent} for the PixeltowerRP plugin to pick
+ * up and respond with a MacrosListComposer snapshot.
+ */
+public class PixeltowerRequestMacrosEvent extends MessageHandler {
+    @Override
+    public void handle() throws Exception {
+        if (this.client == null || this.client.getHabbo() == null) return;
+        Emulator.getPluginManager().fireEvent(
+                new UserMacrosRequestedEvent(this.client.getHabbo()));
+    }
+}
