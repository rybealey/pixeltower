+package com.eu.habbo.plugin.events.users;
+
+import com.eu.habbo.habbohotel.users.Habbo;
+
+/**
+ * Fired when a Habbo selects another user as their current Pixeltower target
+ * — emitted by the {@code PixeltowerSetTargetEvent} incoming handler which
+ * the patched Nitro InfoStand widget triggers on every avatar-sprite click.
+ * The {@code habbo} field on the super-class is the viewer; {@code targetHabboId}
+ * is the target's Habbo id (may reference an offline user).
+ */
+public class UserTargetSelectedEvent extends UserEvent {
+
+    public final int targetHabboId;
+
+    public UserTargetSelectedEvent(Habbo viewer, int targetHabboId) {
+        super(viewer);
+        this.targetHabboId = targetHabboId;
+    }
+}
