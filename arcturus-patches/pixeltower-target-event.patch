+package com.eu.habbo.messages.incoming.users;
+
+import com.eu.habbo.Emulator;
+import com.eu.habbo.messages.incoming.MessageHandler;
+import com.eu.habbo.plugin.events.users.UserTargetSelectedEvent;
+
+/**
+ * Pixeltower-custom incoming packet (header 6550). The patched Nitro
+ * InfoStand widget emits this whenever the local player clicks another
+ * user's avatar sprite. The handler is a thin bridge — it just fires
+ * {@link UserTargetSelectedEvent} for the PixeltowerRP plugin to pick up
+ * and run the set-target / push-stats logic, keeping Arcturus core free
+ * of pixeltower game rules.
+ */
+public class PixeltowerSetTargetEvent extends MessageHandler {
+    @Override
+    public void handle() throws Exception {
+        if (this.client == null || this.client.getHabbo() == null) return;
+        int targetHabboId = this.packet.readInt();
+        Emulator.getPluginManager().fireEvent(
+                new UserTargetSelectedEvent(this.client.getHabbo(), targetHabboId));
+    }
+}
