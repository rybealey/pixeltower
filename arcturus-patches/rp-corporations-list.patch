+package com.eu.habbo.plugin.events.users;
+
+import com.eu.habbo.habbohotel.users.Habbo;
+
+/**
+ * Fired when a Habbo opens the Pixeltower CorporationsWindow — emitted
+ * by the {@code PixeltowerRequestCorporationsEvent} incoming handler. The
+ * {@code habbo} field on the super-class is the requester, who should
+ * receive the resulting CorporationsListComposer.
+ */
+public class UserCorporationsRequestedEvent extends UserEvent {
+    public UserCorporationsRequestedEvent(Habbo requester) {
+        super(requester);
+    }
+}
