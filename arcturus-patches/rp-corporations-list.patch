+package com.eu.habbo.messages.incoming.users;
+
+import com.eu.habbo.Emulator;
+import com.eu.habbo.messages.incoming.MessageHandler;
+import com.eu.habbo.plugin.events.users.UserCorporationsRequestedEvent;
+
+/**
+ * Pixeltower-custom incoming packet (header 6552). The patched Nitro
+ * CorporationsWindow emits this whenever it opens. Body is empty.
+ * The handler is a thin bridge — it just fires
+ * {@link UserCorporationsRequestedEvent} for the PixeltowerRP plugin to
+ * pick up and respond with a CorporationsListComposer snapshot.
+ */
+public class PixeltowerRequestCorporationsEvent extends MessageHandler {
+    @Override
+    public void handle() throws Exception {
+        if (this.client == null || this.client.getHabbo() == null) return;
+        Emulator.getPluginManager().fireEvent(
+                new UserCorporationsRequestedEvent(this.client.getHabbo()));
+    }
+}
