+package com.eu.habbo.plugin.events.users;
+
+import com.eu.habbo.habbohotel.users.Habbo;
+
+/**
+ * Fired when a Habbo accepts or rejects a roleplay service offer popup
+ * (heal, repair, …) — emitted by the {@code RoleplayOfferResponseEvent}
+ * incoming handler which the patched Nitro OfferHUD triggers on click.
+ * The {@code habbo} field on the super-class is the responder (target);
+ * {@code offerId} is the server-issued correlation id; {@code accepted}
+ * is true on Accept, false on Reject.
+ */
+public class UserOfferResponseEvent extends UserEvent {
+
+    public final int offerId;
+    public final boolean accepted;
+
+    public UserOfferResponseEvent(Habbo responder, int offerId, boolean accepted) {
+        super(responder);
+        this.offerId = offerId;
+        this.accepted = accepted;
+    }
+}
