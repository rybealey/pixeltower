+package com.eu.habbo.messages.incoming.users;
+
+import com.eu.habbo.Emulator;
+import com.eu.habbo.messages.incoming.MessageHandler;
+import com.eu.habbo.plugin.events.users.UserOfferResponseEvent;
+
+/**
+ * Pixeltower-custom incoming packet (header 6506). The patched Nitro
+ * OfferHUD popup emits this when the recipient of a roleplay service
+ * offer (heal, repair, …) clicks Accept or Reject. The handler is a
+ * thin bridge — it just fires {@link UserOfferResponseEvent} for the
+ * PixeltowerRP plugin to pick up and route to its OfferManager,
+ * keeping Arcturus core free of pixeltower game rules.
+ *
+ * Wire format: int offerId, boolean accepted.
+ */
+public class RoleplayOfferResponseEvent extends MessageHandler {
+    @Override
+    public void handle() throws Exception {
+        if (this.client == null || this.client.getHabbo() == null) return;
+        int offerId = this.packet.readInt();
+        boolean accepted = this.packet.readBoolean();
+        Emulator.getPluginManager().fireEvent(
+                new UserOfferResponseEvent(
+                        this.client.getHabbo(),
+                        offerId,
+                        accepted));
+    }
+}
