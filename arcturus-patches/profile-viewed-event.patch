+package com.eu.habbo.plugin.events.users;
+
+import com.eu.habbo.habbohotel.users.Habbo;
+
+/**
+ * Fired when a Habbo opens another Habbo's profile card (by clicking their
+ * avatar in a room, by finding them via search, etc.). The {@code habbo}
+ * field on the super-class is the viewer; {@code target} is the profile
+ * subject. Both are non-null — the handler's offline branch does not fire
+ * this event.
+ */
+public class UserProfileCardViewedEvent extends UserEvent {
+
+    public final Habbo target;
+
+    public UserProfileCardViewedEvent(Habbo viewer, Habbo target) {
+        super(viewer);
+        this.target = target;
+    }
+}
