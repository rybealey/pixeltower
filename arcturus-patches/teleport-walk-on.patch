+    @Override
+    public void onWalkOn(RoomUnit roomUnit, Room room, Object[] objects) throws Exception {
+        // pixeltower: trigger the paired teleport as soon as a user steps on
+        // the tile, not only on click. Unpaired teleports stay inert on walk
+        // so admins still get the standard click → pair-dialog flow.
+        if (this.getTargetId() <= 0) return;
+        Habbo habbo = room.getHabbo(roomUnit);
+        if (habbo == null) return;
+        this.roomUnitID = roomUnit.getId();
+        this.startTeleport(room, habbo);
+        walkable = true;
+        try {
+            super.onClick(habbo.getClient(), room, new Object[]{"TOGGLE_OVERRIDE"});
+        } catch (Exception ignored) {
+        }
+    }
