+// ──────────── UpdateCorpBadges (header 6504) ────────────
+//
+// Per-room map of habboId → corp hotel-badge code, used to override the
+// "favorite Habbo Group" badge slot in the user infostand for any
+// employee of a corp that has badge_code set in rp_corporations. The
+// override is purely visual; the user's actual favorite group on the
+// server is unchanged.
+
+export class UpdateCorpBadgesParser implements IMessageParser
+{
+    private _badges: Map<number, string>;
+
+    public flush(): boolean
+    {
+        this._badges = new Map<number, string>();
+        return true;
+    }
+
+    public parse(wrapper: IMessageDataWrapper): boolean
+    {
+        if(!wrapper) return false;
+        this._badges = new Map<number, string>();
+        const count = wrapper.readInt();
+        for(let i = 0; i < count; i++)
+        {
+            const habboId = wrapper.readInt();
+            const badgeCode = wrapper.readString();
+            this._badges.set(habboId, badgeCode);
+        }
+        return true;
+    }
+
+    public get badges(): Map<number, string>
+    {
+        return this._badges;
+    }
+}
+
+export class UpdateCorpBadgesEvent extends MessageEvent implements IMessageEvent
+{
+    constructor(callBack: Function)
+    {
+        super(callBack, UpdateCorpBadgesParser);
+    }
+
+    public getParser(): UpdateCorpBadgesParser
+    {
+        return this.parser as UpdateCorpBadgesParser;
+    }
+}
