@@ -0,0 +1,16 @@
+import { FC } from 'react';
+import { useCorpBadges } from '../../hooks/pixeltower';
+
+/**
+ * Headless component that mounts {@link useCorpBadges} for its side effect:
+ * keeping the shared corp-badge map fresh while the user is in a room. The
+ * InfoStand consumes the same map via {@code useBetween} but only renders
+ * on demand — without an always-mounted listener, the room-entry packet
+ * (sent before any infostand opens) would be lost. Returns null because
+ * it has no UI of its own.
+ */
+export const CorpBadgesListener: FC<{}> = () =>
+{
+    useCorpBadges();
+    return null;
+}
