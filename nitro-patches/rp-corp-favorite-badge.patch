+import { useState } from 'react';
+import { useBetween } from 'use-between';
+import { UpdateCorpBadgesEvent } from '../../api/pixeltower/PixeltowerSoundMessages';
+import { useMessageEvent } from '../events';
+
+/**
+ * Per-room {habboId -> corp hotel-badge code} map sent by the server on
+ * room entry and after any hire/fire/quit affecting the room. Drives the
+ * favorite-Habbo-Group badge override in the InfoStand. The listener has
+ * to be mounted at all times while in a room (the room-entry packet
+ * arrives before any infostand opens), so {@link CorpBadgesListener}
+ * mounts this hook from MainView and the InfoStand reads from it via
+ * {@code useBetween}-shared state.
+ */
+const useCorpBadgesState = () =>
+{
+    const [ badges, setBadges ] = useState<Map<number, string>>(new Map());
+
+    useMessageEvent<UpdateCorpBadgesEvent>(UpdateCorpBadgesEvent, event =>
+    {
+        const parser = event.getParser();
+        setBadges(new Map(parser.badges));
+    });
+
+    return { badges };
+}
+
+export const useCorpBadges = () => useBetween(useCorpBadgesState);
