diff --git a/src/hooks/pixeltower/useCorporations.ts b/src/hooks/pixeltower/useCorporations.ts
new file mode 100644
--- /dev/null
+++ b/src/hooks/pixeltower/useCorporations.ts
@@ -0,0 +1,28 @@
+import { useState } from 'react';
+import { useBetween } from 'use-between';
+import { CorporationsListCorp, CorporationsListEvent } from '../../api/pixeltower/PixeltowerSoundMessages';
+import { useMessageEvent } from '../events';
+
+export type Corporation = CorporationsListCorp;
+
+/**
+ * Public roster of every corp + every employee, replaced wholesale on each
+ * server snapshot (CorporationsListEvent / header 6505). The snapshot is
+ * requested by {@code CorporationsWindow} on open via
+ * {@code RequestCorporationsComposer}; useBetween keeps the result shared
+ * across components so future corp-related views (commands list, infostand
+ * extension, etc.) can read without a re-request.
+ */
+const useCorporationsState = () =>
+{
+    const [ corporations, setCorporations ] = useState<Corporation[]>([]);
+
+    useMessageEvent<CorporationsListEvent>(CorporationsListEvent, event =>
+    {
+        setCorporations(event.getParser().corporations);
+    });
+
+    return { corporations };
+}
+
+export const useCorporations = () => useBetween(useCorporationsState);
diff --git a/src/components/pixeltower/CorporationsWindow.tsx b/src/components/pixeltower/CorporationsWindow.tsx
new file mode 100644
--- /dev/null
+++ b/src/components/pixeltower/CorporationsWindow.tsx
@@ -0,0 +1,189 @@
+import { ILinkEventTracker } from '@nitrots/nitro-renderer';
+import { FC, useEffect, useMemo, useState } from 'react';
+import { LuPackage, LuUsers } from 'react-icons/lu';
+import { AddEventLinkTracker, RemoveLinkEventTracker, SendMessageComposer } from '../../api';
+import { RequestCorporationsComposer } from '../../api/pixeltower/PixeltowerSoundMessages';
+import { LayoutAvatarImageView, LayoutBadgeImageView, NitroCardContentView, NitroCardHeaderView, NitroCardView } from '../../common';
+import { Corporation, useCorporations } from '../../hooks/pixeltower';
+
+// Corporations Window — matches .designs/client_ui.pen frame qwlWN.
+// Triggered from the Drawer HUD "Corps" button via
+// CreateLinkEvent('corporations-window/show|hide|toggle'). Uses the
+// native Nitro card chrome (draggable header, red X close button) for
+// parity with every other in-game dialog. The roster snapshot is fetched
+// via RequestCorporationsComposer (header 6552) on each open and replied
+// to with a CorporationsListEvent (header 6505), shared across the app
+// via the useCorporations hook.
+
+const formatNumber = (value: number): string =>
+    value.toLocaleString('en-US');
+
+interface RankBucket
+{
+    rankNum: number;
+    title: string;
+    salary: number;
+    members: Corporation['members'];
+}
+
+// Drop a trailing roman numeral tier (e.g. "Paramedic V" → "Paramedic").
+// Five tiers of the same role collapse into one displayed rank — the
+// underlying rank_num ladder is preserved server-side for promotion logic.
+const stripTier = (title: string): string =>
+    title.replace(/\s+[IVX]+$/i, '').trim();
+
+const bucketMembersByRank = (corp: Corporation): RankBucket[] =>
+{
+    const ranksByNum = new Map<number, { title: string; salary: number; members: Corporation['members'] }>();
+    corp.ranks.forEach(r => ranksByNum.set(r.rankNum, { title: r.title, salary: r.salary, members: [] }));
+    corp.members.forEach(m =>
+    {
+        const bucket = ranksByNum.get(m.rankNum);
+        if(bucket) bucket.members.push(m);
+    });
+
+    // Iterate senior→junior so the first encounter of each base title sets
+    // the group's wage + sort key (highest tier wins). Subsequent tiers
+    // contribute their members to the same bucket.
+    const groups = new Map<string, RankBucket>();
+    Array.from(ranksByNum.entries())
+        .sort((a, b) => b[0] - a[0])
+        .forEach(([ rankNum, v ]) =>
+        {
+            const stripped = stripTier(v.title);
+            if(!groups.has(stripped))
+            {
+                groups.set(stripped, { rankNum, title: stripped, salary: v.salary, members: [] });
+            }
+            groups.get(stripped).members.push(...v.members);
+        });
+    return Array.from(groups.values());
+}
+
+export const CorporationsWindow: FC<{}> = () =>
+{
+    const [ isVisible, setIsVisible ] = useState(false);
+    const [ selectedCorpId, setSelectedCorpId ] = useState<number | null>(null);
+    const { corporations } = useCorporations();
+
+    useEffect(() =>
+    {
+        const linkTracker: ILinkEventTracker = {
+            linkReceived: (url: string) =>
+            {
+                const parts = url.split('/');
+                if(parts.length < 2) return;
+                switch(parts[1])
+                {
+                    case 'show':   setIsVisible(true); return;
+                    case 'hide':   setIsVisible(false); return;
+                    case 'toggle': setIsVisible(v => !v); return;
+                }
+            },
+            eventUrlPrefix: 'corporations-window/'
+        };
+        AddEventLinkTracker(linkTracker);
+        return () => RemoveLinkEventTracker(linkTracker);
+    }, []);
+
+    useEffect(() =>
+    {
+        if(!isVisible) return;
+        SendMessageComposer(new RequestCorporationsComposer());
+    }, [ isVisible ]);
+
+    useEffect(() =>
+    {
+        if(selectedCorpId !== null) return;
+        if(!corporations.length) return;
+        setSelectedCorpId(corporations[0].corpId);
+    }, [ corporations, selectedCorpId ]);
+
+    const selectedCorp = useMemo(
+        () => corporations.find(c => c.corpId === selectedCorpId) ?? null,
+        [ corporations, selectedCorpId ]);
+
+    const rankBuckets = useMemo(
+        () => selectedCorp ? bucketMembersByRank(selectedCorp) : [],
+        [ selectedCorp ]);
+
+    if(!isVisible) return null;
+
+    const close = () => setIsVisible(false);
+
+    return (
+        <NitroCardView uniqueKey="pixeltower-corporations" theme="primary" classNames={ [ 'pixeltower-corporations-window' ] }>
+            <NitroCardHeaderView headerText="Corporations" onCloseClick={ close } />
+            <NitroCardContentView classNames={ [ 'pixeltower-corporations-window__content' ] } overflow="hidden">
+                <div className="pixeltower-corporations-window__body">
+                    <div className="pixeltower-corporations-window__rail">
+                        { corporations.map(corp => (
+                            <button
+                                key={ corp.corpId }
+                                type="button"
+                                className={ 'pixeltower-corporations-window__badge' + (corp.corpId === selectedCorpId ? ' pixeltower-corporations-window__badge--active' : '') }
+                                title={ corp.corpName }
+                                onClick={ () => setSelectedCorpId(corp.corpId) }>
+                                { corp.badgeCode
+                                    ? <LayoutBadgeImageView badgeCode={ corp.badgeCode } isGroup={ false } />
+                                    : <span className="pixeltower-corporations-window__badge-fallback">{ corp.corpName.charAt(0) }</span>
+                                }
+                            </button>
+                        )) }
+                    </div>
+                    <div className="pixeltower-corporations-window__main">
+                        { !selectedCorp && (
+                            <div className="pixeltower-corporations-window__loading">Loading…</div>
+                        ) }
+                        { selectedCorp && (
+                            <>
+                                <div className="pixeltower-corporations-window__corp-header">
+                                    <div className="pixeltower-corporations-window__corp-name">{ selectedCorp.corpName }</div>
+                                    <div className="pixeltower-corporations-window__stats">
+                                        <div className="pixeltower-corporations-window__pill">
+                                            <LuUsers />
+                                            <span>{ formatNumber(selectedCorp.members.length) } { selectedCorp.members.length === 1 ? 'employee' : 'employees' }</span>
+                                        </div>
+                                        <div className="pixeltower-corporations-window__pill">
+                                            <LuPackage />
+                                            <span>{ formatNumber(selectedCorp.stockCapacity) } stock</span>
+                                        </div>
+                                    </div>
+                                </div>
+                                { rankBuckets.map(bucket => (
+                                    <div key={ bucket.rankNum } className="pixeltower-corporations-window__rank">
+                                        <div className="pixeltower-corporations-window__rank-header">
+                                            <span className="pixeltower-corporations-window__rank-title">{ bucket.title }</span>
+                                            <span className="pixeltower-corporations-window__wage">${ formatNumber(bucket.salary) }</span>
+                                        </div>
+                                        { bucket.members.length > 0 && (
+                                            <div className="pixeltower-corporations-window__rank-grid">
+                                                { bucket.members.map(member => (
+                                                    <div key={ member.habboId } className="pixeltower-corporations-window__employee">
+                                                        <div className="pixeltower-corporations-window__avatar">
+                                                            { member.figure
+                                                                ? <LayoutAvatarImageView figure={ member.figure } direction={ 2 } />
+                                                                : null
+                                                            }
+                                                        </div>
+                                                        <div className="pixeltower-corporations-window__employee-text">
+                                                            <span className="pixeltower-corporations-window__employee-name">{ member.username }</span>
+                                                            <span className="pixeltower-corporations-window__employee-rank">{ bucket.title }</span>
+                                                        </div>
+                                                    </div>
+                                                )) }
+                                                { bucket.members.length % 2 === 1 && (
+                                                    <div className="pixeltower-corporations-window__employee pixeltower-corporations-window__employee--filler" />
+                                                ) }
+                                            </div>
+                                        ) }
+                                    </div>
+                                )) }
+                            </>
+                        ) }
+                    </div>
+                </div>
+            </NitroCardContentView>
+        </NitroCardView>
+    );
+}
