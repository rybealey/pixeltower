--- /dev/null
+++ b/src/components/pixeltower/CorporationsWindow.scss
@@ -0,0 +1,245 @@
+@use './tokens' as *;
+
+// Corporations Window — matches .designs/client_ui.pen frame qwlWN.
+// Outer chrome is NitroCardView (theme="primary") so it inherits the same
+// slate-blue draggable header + red X close button every other Pixeltower
+// dialog uses (Diamonds, Commands List). Body sits on the default $light
+// (#DFDFDF) .content-area background.
+
+$pt-corp-panel-bg:       #FFFFFF;
+$pt-corp-panel-border:   #A0A8B5;
+$pt-corp-text-strong:    #1F2C40;
+$pt-corp-text-muted:     #6B7280;
+$pt-corp-card-bg:        #FAFAFA;
+$pt-corp-pill-bg:        #EAEAEA;
+$pt-corp-wage-bg:        #E8F5EE;
+$pt-corp-wage-border:    #48C66B;
+$pt-corp-wage-text:      #1F6B36;
+$pt-corp-active-glow:    #FFD028;
+$pt-corp-active-stroke:  #1F2C40;
+
+.pixeltower-corporations-window {
+    width: 660px;
+    max-width: calc(100vw - 24px);
+    color: $pt-corp-text-strong;
+    font-family: $pt-font-family;
+
+    // Fixed height so the window doesn't shrink for sparsely-populated
+    // corps (e.g. The Armory with 0 employees). The right pane scrolls
+    // when employees exceed the available space. Capped on short viewports
+    // so it never escapes the visible area.
+    height: 420px;
+    max-height: calc(100vh - 80px);
+
+    &__content {
+        display: flex;
+        flex-direction: column;
+        min-height: 0;
+    }
+
+    &__body {
+        display: flex;
+        gap: 12px;
+        padding: 12px;
+        flex: 1;
+        min-height: 0;
+    }
+
+    &__rail {
+        display: flex;
+        flex-direction: column;
+        gap: 6px;
+        padding: 6px;
+        width: 60px;
+        background: $pt-corp-panel-bg;
+        border: 1px solid $pt-corp-panel-border;
+        border-radius: 3px;
+        flex-shrink: 0;
+        align-self: flex-start;
+    }
+
+    &__badge {
+        width: 48px;
+        height: 48px;
+        background: #E5E5E5;
+        border: 1px solid $pt-corp-panel-border;
+        border-radius: 3px;
+        cursor: pointer;
+        display: flex;
+        align-items: center;
+        justify-content: center;
+        padding: 0;
+
+        &:hover { filter: brightness(1.04); }
+
+        &--active {
+            border: 2px solid $pt-corp-active-stroke;
+            box-shadow: 0 0 0 2px $pt-corp-active-glow, 0 0 8px $pt-corp-active-glow;
+        }
+
+        .badge-image { transform: scale(1); }
+    }
+
+    &__badge-fallback {
+        font-family: $pt-font-family;
+        font-size: 20px;
+        font-weight: 900;
+        color: $pt-corp-text-muted;
+        text-transform: uppercase;
+    }
+
+    &__main {
+        display: flex;
+        flex-direction: column;
+        gap: 12px;
+        flex: 1;
+        min-width: 0;
+        min-height: 0;
+        overflow-y: auto;
+        padding-right: 4px;
+    }
+
+    &__loading,
+    &__empty {
+        background: $pt-corp-panel-bg;
+        border: 1px solid $pt-corp-panel-border;
+        border-radius: 3px;
+        padding: 16px;
+        text-align: center;
+        color: $pt-corp-text-muted;
+        font-size: 13px;
+    }
+
+    &__corp-header {
+        display: flex;
+        align-items: center;
+        justify-content: space-between;
+        gap: 12px;
+        background: $pt-corp-panel-bg;
+        border: 1px solid $pt-corp-panel-border;
+        border-radius: 3px;
+        padding: 10px 12px;
+    }
+
+    &__corp-name {
+        font-size: 18px;
+        font-weight: 900;
+        color: $pt-corp-text-strong;
+    }
+
+    &__stats {
+        display: flex;
+        gap: 6px;
+        flex-shrink: 0;
+    }
+
+    &__pill {
+        display: flex;
+        align-items: center;
+        gap: 6px;
+        padding: 4px 8px;
+        background: $pt-corp-pill-bg;
+        border: 1px solid $pt-corp-panel-border;
+        border-radius: 3px;
+        font-size: 12px;
+        font-weight: 700;
+        color: $pt-corp-text-strong;
+
+        svg { width: 12px; height: 12px; color: $pt-corp-text-muted; }
+    }
+
+    &__rank {
+        background: $pt-corp-panel-bg;
+        border: 1px solid $pt-corp-panel-border;
+        border-radius: 3px;
+        display: flex;
+        flex-direction: column;
+    }
+
+    &__rank-header {
+        display: flex;
