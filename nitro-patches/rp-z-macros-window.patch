diff --git a/src/hooks/pixeltower/useKeybindCapture.ts b/src/hooks/pixeltower/useKeybindCapture.ts
new file mode 100644
index 0000000..8047d53
--- /dev/null
+++ b/src/hooks/pixeltower/useKeybindCapture.ts
@@ -0,0 +1,79 @@
+import { useCallback, useEffect, useState } from 'react';
+import { encodeKeyEvent, encodeMouseEvent } from '../../api/pixeltower/MacroBindingFormat';
+
+/**
+ * Capture-mode hook used by the Add Macro modal's Keybinding field.
+ *
+ * Caller flow:
+ *   1. User clicks the field → component calls startCapture().
+ *   2. While capturing, the next keydown or mousedown anywhere in the
+ *      document is translated to the canonical binding string and stored
+ *      in `captured`. Capture mode auto-exits.
+ *   3. Component reads `captured` for save, or calls reset() to clear it.
+ *
+ * Bare modifier presses (Shift on its own etc.) and unmapped mouse buttons
+ * are ignored — the user has to follow up with a real key/button.
+ */
+export interface KeybindCaptureApi
+{
+    isCapturing: boolean;
+    captured: string;
+    startCapture: () => void;
+    cancelCapture: () => void;
+    reset: () => void;
+}
+
+export const useKeybindCapture = (initial: string = ''): KeybindCaptureApi =>
+{
+    const [ isCapturing, setIsCapturing ] = useState(false);
+    const [ captured, setCaptured ] = useState(initial);
+
+    const startCapture = useCallback(() => setIsCapturing(true), []);
+    const cancelCapture = useCallback(() => setIsCapturing(false), []);
+    const reset = useCallback(() => { setCaptured(''); setIsCapturing(false); }, []);
+
+    useEffect(() =>
+    {
+        if(!isCapturing) return;
+
+        const onKey = (event: KeyboardEvent) =>
+        {
+            // Escape always cancels without recording.
+            if(event.code === 'Escape')
+            {
+                event.preventDefault();
+                event.stopPropagation();
+                setIsCapturing(false);
+                return;
+            }
+            const encoded = encodeKeyEvent(event);
+            if(!encoded) return;
+            event.preventDefault();
+            event.stopPropagation();
+            setCaptured(encoded);
+            setIsCapturing(false);
+        };
+
+        const onMouse = (event: MouseEvent) =>
+        {
+            const encoded = encodeMouseEvent(event);
+            if(!encoded) return;
+            event.preventDefault();
+            event.stopPropagation();
+            setCaptured(encoded);
+            setIsCapturing(false);
+        };
+
+        // capture-phase listeners so we get the press before any
+        // input/textarea swallows it.
+        document.addEventListener('keydown', onKey, true);
+        document.addEventListener('mousedown', onMouse, true);
+        return () =>
+        {
+            document.removeEventListener('keydown', onKey, true);
+            document.removeEventListener('mousedown', onMouse, true);
+        };
+    }, [ isCapturing ]);
+
+    return { isCapturing, captured, startCapture, cancelCapture, reset };
+}
diff --git a/src/hooks/pixeltower/useMacros.ts b/src/hooks/pixeltower/useMacros.ts
new file mode 100644
index 0000000..b0fb94c
--- /dev/null
+++ b/src/hooks/pixeltower/useMacros.ts
@@ -0,0 +1,37 @@
+import { useState } from 'react';
+import { useBetween } from 'use-between';
+import { MacroCategoryItem, MacrosListEvent, MacrosListItem } from '../../api/pixeltower/PixeltowerSoundMessages';
+import { useMessageEvent } from '../events';
+
+export type Macro = MacrosListItem;
+export type MacroCategory = MacroCategoryItem;
+
+/**
+ * Local player's saved macros + categories, replaced wholesale on every
+ * MacrosListEvent (header 6553). Requested via {@code RequestMacrosComposer}
+ * from the MacrosWindow on open and on initial mount of MacrosKeybindListener.
+ *
+ * Shared via useBetween so the window UI and the global keybind dispatcher
+ * read from the same source of truth — saving / reordering / switching
+ * categories updates both.
+ *
+ * setMacros is exposed for optimistic updates (e.g. drag-to-reorder) — the
+ * window applies the new order immediately, then sends a ReorderMacros
+ * composer; the server's reply replaces the snapshot.
+ */
+const useMacrosState = () =>
+{
+    const [ macros, setMacros ] = useState<Macro[]>([]);
+    const [ categories, setCategories ] = useState<MacroCategory[]>([]);
+
+    useMessageEvent<MacrosListEvent>(MacrosListEvent, event =>
+    {
+        const parser = event.getParser();
+        setMacros(parser.macros);
+        setCategories(parser.categories);
+    });
+
+    return { macros, setMacros, categories };
+}
+
+export const useMacros = () => useBetween(useMacrosState);
