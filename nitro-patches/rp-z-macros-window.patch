diff --git a/src/components/pixeltower/MacrosWindow.tsx b/src/components/pixeltower/MacrosWindow.tsx
new file mode 100644
index 0000000..4f50fdb
--- /dev/null
+++ b/src/components/pixeltower/MacrosWindow.tsx
@@ -0,0 +1,324 @@
+import { ILinkEventTracker } from '@nitrots/nitro-renderer';
+import { DragEvent as ReactDragEvent, FC, useEffect, useMemo, useRef, useState } from 'react';
+import { LuChevronDown, LuGripVertical, LuPlus, LuTrash2 } from 'react-icons/lu';
+import { AddEventLinkTracker, RemoveLinkEventTracker, SendMessageComposer } from '../../api';
+import { formatBindingForDisplay } from '../../api/pixeltower/MacroBindingFormat';
+import { DeleteMacroCategoryComposer, DeleteMacroComposer, ReorderMacrosComposer, RequestMacrosComposer, SaveMacroComposer, SetActiveMacroCategoryComposer } from '../../api/pixeltower/PixeltowerSoundMessages';
+import { NitroCardContentView, NitroCardHeaderView, NitroCardView } from '../../common';
+import { useMacros } from '../../hooks/pixeltower';
+import { AddMacroCategoryDialog } from './AddMacroCategoryDialog';
+import { AddMacroDialog } from './AddMacroDialog';
+
+// Macros Window — .designs/client_ui.pen frame 59QGF.
+// Triggered from the Drawer HUD "Macros" button via
+// CreateLinkEvent('macros-window/show|hide|toggle'). Uses native Nitro card
+// chrome (draggable header, red X close button) for parity with every other
+// in-game dialog. Two action chips (amber "+ New Category", green "+ New
+// Macro") sit in a body action row, with a full-width category dropdown
+// below acting as the active filter for the table.
+//
+// The roster is fetched via RequestMacrosComposer (header 6554) on each
+// open and replied to with a MacrosListEvent (header 6553), shared across
+// the app via the useMacros hook. The MacrosKeybindListener consumes the
+// same hook to dispatch saved bindings against the global key/mouse stream.
+//
+// Active category is server-side state — switching dispatches
+// SetActiveMacroCategoryComposer (header 6558); the resulting MacrosListEvent
+// echo flips is_active on the matching row.
+
+const DEFAULT_CATEGORY = 'Default';
+
+export const MacrosWindow: FC<{}> = () =>
+{
+    const [ isVisible, setIsVisible ] = useState(false);
+    const [ addOpen, setAddOpen ] = useState(false);
+    const [ addCatOpen, setAddCatOpen ] = useState(false);
+    const [ ddOpen, setDdOpen ] = useState(false);
+    const [ editing, setEditing ] = useState<{ macroId: number; draft: string } | null>(null);
+    const [ dragIndex, setDragIndex ] = useState<number | null>(null);
+    const [ dropIndex, setDropIndex ] = useState<number | null>(null);
+    const ddRef = useRef<HTMLDivElement>(null);
+    const editInputRef = useRef<HTMLInputElement>(null);
+
+    const { macros, setMacros, categories } = useMacros();
+
+    const activeCategory = useMemo(
+        () => categories.find(c => c.isActive) ?? categories[0] ?? null,
+        [ categories ]);
+
+    const visibleMacros = useMemo(
+        () => activeCategory ? macros.filter(m => m.category === activeCategory.name) : [],
+        [ macros, activeCategory ]);
+
+    useEffect(() =>
+    {
+        const linkTracker: ILinkEventTracker = {
+            linkReceived: (url: string) =>
+            {
+                const parts = url.split('/');
+                if(parts.length < 2) return;
+                switch(parts[1])
+                {
+                    case 'show':   setIsVisible(true); return;
+                    case 'hide':   setIsVisible(false); return;
+                    case 'toggle': setIsVisible(v => !v); return;
+                }
+            },
+            eventUrlPrefix: 'macros-window/'
+        };
+        AddEventLinkTracker(linkTracker);
+        return () => RemoveLinkEventTracker(linkTracker);
+    }, []);
+
+    useEffect(() =>
+    {
+        if(!isVisible) return;
+        SendMessageComposer(new RequestMacrosComposer());
+    }, [ isVisible ]);
+
+    useEffect(() =>
+    {
+        if(!ddOpen) return;
+        const onDocClick = (event: MouseEvent) =>
+        {
+            if(!ddRef.current) return;
+            if(!ddRef.current.contains(event.target as Node)) setDdOpen(false);
+        };
+        document.addEventListener('mousedown', onDocClick);
+        return () => document.removeEventListener('mousedown', onDocClick);
+    }, [ ddOpen ]);
+
+    // Active category just changed (or the user moved the macro between
+    // categories) — drop any in-flight edit so we don't accidentally save
+    // into the wrong row.
+    useEffect(() => { setEditing(null); }, [ activeCategory?.id ]);
+
+    if(!isVisible) return null;
+
+    const close = () =>
+    {
+        setAddOpen(false);
+        setAddCatOpen(false);
+        setDdOpen(false);
+        setEditing(null);
+        setIsVisible(false);
+    };
+
+    const handleSave = (keybind: string, command: string, category: string) =>
+    {
+        SendMessageComposer(new SaveMacroComposer(0, keybind, command, category));
+        setAddOpen(false);
+    };
+
+    const handleDelete = (macroId: number) =>
+    {
+        SendMessageComposer(new DeleteMacroComposer(macroId));
+    };
+
+    const handlePickCategory = (categoryId: number) =>
+    {
+        setDdOpen(false);
+        if(activeCategory && categoryId === activeCategory.id) return;
+        SendMessageComposer(new SetActiveMacroCategoryComposer(categoryId));
+    };
+
+    const handleDeleteCategory = (categoryId: number) =>
+    {
+        SendMessageComposer(new DeleteMacroCategoryComposer(categoryId));
+    };
+
+    const beginEdit = (macroId: number, current: string) =>
+    {
+        setEditing({ macroId, draft: current });
+        // Focus + select on next tick so the rendered input exists.
+        setTimeout(() => editInputRef.current?.select(), 0);
+    };
+
+    const commitEdit = () =>
+    {
+        if(!editing) return;
+        const target = macros.find(m => m.macroId === editing.macroId);
+        const draft = editing.draft.trim();
+        setEditing(null);
+        if(!target || !draft || draft === target.command) return;
+        SendMessageComposer(new SaveMacroComposer(target.macroId, target.keybind, draft, target.category));
+    };
+
+    const cancelEdit = () => setEditing(null);
+
+    const handleDragStart = (index: number) => (event: ReactDragEvent<HTMLDivElement>) =>
+    {
+        // Don't start a drag from inside the inline edit input.
+        if(editing) { event.preventDefault(); return; }
+        setDragIndex(index);
+        event.dataTransfer.effectAllowed = 'move';
+        event.dataTransfer.setData('text/plain', String(index));
+    };
+
+    const handleDragOver = (index: number) => (event: ReactDragEvent<HTMLDivElement>) =>
+    {
+        if(dragIndex === null) return;
+        event.preventDefault();
+        event.dataTransfer.dropEffect = 'move';
+        if(index !== dropIndex) setDropIndex(index);
+    };
+
+    const handleDragEnd = () =>
+    {
+        setDragIndex(null);
+        setDropIndex(null);
+    };
+
+    const handleDrop = (index: number) => (event: ReactDragEvent<HTMLDivElement>) =>
+    {
+        event.preventDefault();
+        const from = dragIndex;
+        handleDragEnd();
+        if(from === null || from === index || !activeCategory) return;
+
+        // Reorder the visible (filtered) slice; keep other categories' rows
+        // in place. The composer sends the new ordering for just the
+        // visible category, so server-side sort_order updates only those.
+        const visible = visibleMacros.slice();
+        const [ moved ] = visible.splice(from, 1);
+        visible.splice(index, 0, moved);
+
+        const others = macros.filter(m => m.category !== activeCategory.name);
+        setMacros(others.concat(visible));
+        SendMessageComposer(new ReorderMacrosComposer(visible.map(m => m.macroId)));
+    };
+
+    return (
+        <>
+            <NitroCardView uniqueKey="pixeltower-macros" theme="primary" classNames={ [ 'pixeltower-macros-window' ] }>
+                <NitroCardHeaderView headerText="Macros" onCloseClick={ close } />
+                <NitroCardContentView classNames={ [ 'pixeltower-macros-window__content' ] } overflow="hidden">
+                    <div className="pixeltower-macros-window__action-row">
+                        <button
+                            type="button"
+                            className="pixeltower-macros-window__new-cat-btn"
+                            title="New category"
+                            onClick={ () => setAddCatOpen(true) }>
+                            <LuPlus />
+                            <span>New Category</span>
+                        </button>
+                        <button
+                            type="button"
+                            className="pixeltower-macros-window__new-btn"
+                            title="New macro"
+                            onClick={ () => setAddOpen(true) }>
+                            <LuPlus />
+                            <span>New Macro</span>
+                        </button>
+                    </div>
+                    <div ref={ ddRef } className={ 'pixeltower-macros-window__cat-dd-wrap' + (ddOpen ? ' pixeltower-macros-window__cat-dd-wrap--open' : '') }>
+                        <button
+                            type="button"
+                            className="pixeltower-macros-window__cat-dd"
+                            onClick={ () => setDdOpen(o => !o) }>
+                            <span className="pixeltower-macros-window__cat-dd-label">{ activeCategory?.name ?? DEFAULT_CATEGORY }</span>
+                            <LuChevronDown className="pixeltower-macros-window__cat-dd-chev" />
+                        </button>
+                        { ddOpen && (
+                            <div className="pixeltower-macros-window__cat-menu" role="listbox">
+                                { categories.map(cat => (
+                                    <div
+                                        key={ cat.id }
+                                        className={ 'pixeltower-macros-window__cat-item' + (cat.isActive ? ' pixeltower-macros-window__cat-item--active' : '') }
+                                        role="option"
+                                        aria-selected={ cat.isActive }
+                                        onClick={ () => handlePickCategory(cat.id) }>
+                                        <span className="pixeltower-macros-window__cat-item-name">{ cat.name }</span>
+                                        { cat.name !== DEFAULT_CATEGORY && (
+                                            <button
+                                                type="button"
+                                                className="pixeltower-macros-window__cat-item-del"
+                                                title={ `Delete "${ cat.name }" and all its macros` }
+                                                onClick={ e => { e.stopPropagation(); handleDeleteCategory(cat.id); } }>
+                                                <LuTrash2 />
+                                            </button>
+                                        ) }
+                                    </div>
+                                )) }
+                            </div>
+                        ) }
+                    </div>
+                    <div className="pixeltower-macros-window__table">
+                        <div className="pixeltower-macros-window__row pixeltower-macros-window__row--header">
+                            <div className="pixeltower-macros-window__col pixeltower-macros-window__col--grip" />
+                            <div className="pixeltower-macros-window__col pixeltower-macros-window__col--key">Keybinding</div>
+                            <div className="pixeltower-macros-window__col pixeltower-macros-window__col--cmd">Command</div>
+                            <div className="pixeltower-macros-window__col pixeltower-macros-window__col--action">Action</div>
+                        </div>
+                        { visibleMacros.length === 0 && (
+                            <div className="pixeltower-macros-window__empty">
+                                No macros in <strong>{ activeCategory?.name ?? DEFAULT_CATEGORY }</strong> yet — click <strong>+ New Macro</strong> to bind a key.
+                            </div>
+                        ) }
+                        { visibleMacros.map((macro, index) => (
+                            <div
+                                key={ macro.macroId }
+                                className={ 'pixeltower-macros-window__row'
+                                    + (dragIndex === index ? ' pixeltower-macros-window__row--dragging' : '')
+                                    + (dropIndex === index && dragIndex !== index ? ' pixeltower-macros-window__row--drop-target' : '') }
+                                draggable={ editing?.macroId !== macro.macroId }
+                                onDragStart={ handleDragStart(index) }
+                                onDragOver={ handleDragOver(index) }
+                                onDrop={ handleDrop(index) }
+                                onDragEnd={ handleDragEnd }>
+                                <div className="pixeltower-macros-window__col pixeltower-macros-window__col--grip" title="Drag to reorder">
+                                    <LuGripVertical />
+                                </div>
+                                <div className="pixeltower-macros-window__col pixeltower-macros-window__col--key">
+                                    { formatBindingForDisplay(macro.keybind) }
+                                </div>
+                                <div className="pixeltower-macros-window__col pixeltower-macros-window__col--cmd">
+                                    { editing?.macroId === macro.macroId
+                                        ? <input
+                                            ref={ editInputRef }
+                                            type="text"
+                                            className="pixeltower-macros-window__cmd-input"
+                                            value={ editing.draft }
+                                            maxLength={ 128 }
+                                            onChange={ e => setEditing({ macroId: macro.macroId, draft: e.target.value }) }
+                                            onBlur={ commitEdit }
+                                            onKeyDown={ e =>
+                                            {
+                                                if(e.key === 'Enter') { e.preventDefault(); commitEdit(); }
+                                                else if(e.key === 'Escape') { e.preventDefault(); cancelEdit(); }
+                                            } } />
+                                        : <button
+                                            type="button"
+                                            className="pixeltower-macros-window__cmd-chip"
+                                            title="Click to edit"
+                                            onClick={ () => beginEdit(macro.macroId, macro.command) }>
+                                            <span className="pixeltower-macros-window__cmd-text">{ macro.command }</span>
+                                        </button>
+                                    }
+                                </div>
+                                <div className="pixeltower-macros-window__col pixeltower-macros-window__col--action">
+                                    <button
+                                        type="button"
+                                        className="pixeltower-macros-window__delete"
+                                        title="Delete macro"
+                                        onClick={ () => handleDelete(macro.macroId) }>
+                                        <LuTrash2 />
+                                    </button>
+                                </div>
+                            </div>
+                        )) }
+                    </div>
+                </NitroCardContentView>
+            </NitroCardView>
+            { addOpen && (
+                <AddMacroDialog
+                    onClose={ () => setAddOpen(false) }
+                    onSave={ handleSave } />
+            ) }
+            { addCatOpen && (
+                <AddMacroCategoryDialog
+                    onClose={ () => setAddCatOpen(false) } />
+            ) }
+        </>
+    );
+}
