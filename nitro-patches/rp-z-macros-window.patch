@@ -0,0 +1,147 @@
+@use './tokens' as *;
+
+// Add New Macro dialog — .designs/client_ui.pen frame X8ukF.
+// Outer chrome is NitroCardView (theme="primary"); body styling matches
+// the inputs/buttons designed in the .pen.
+
+$pt-add-macro-input-bg:    #FFFFFF;
+$pt-add-macro-input-stroke: #A0A8B5;
+$pt-add-macro-text-strong: #1F2C40;
+$pt-add-macro-text-muted:  #6B7280;
+$pt-add-macro-focus-stroke: #2B3A54;
+
+$pt-add-macro-red-top:      #E04848;
+$pt-add-macro-red-bottom:   #7A1818;
+$pt-add-macro-red-glow:     #FF9090;
+
+$pt-add-macro-green-top:    #48C66B;
+$pt-add-macro-green-bottom: #1F6B36;
+$pt-add-macro-green-glow:   #9AE3B0;
+
+.pixeltower-add-macro {
+    width: 380px;
+    max-width: calc(100vw - 24px);
+    color: $pt-add-macro-text-strong;
+    font-family: $pt-font-family;
+
+    &__content {
+        display: flex;
+        flex-direction: column;
+        gap: 12px;
+        padding: 14px;
+    }
+
+    &__field {
+        display: flex;
+        flex-direction: column;
+        gap: 5px;
+    }
+
+    &__label {
+        font-size: 12px;
+        font-weight: 700;
+        letter-spacing: 0.4px;
+        color: $pt-add-macro-text-strong;
+    }
+
+    &__input {
+        display: flex;
+        align-items: center;
+        height: 34px;
+        padding: 0 10px;
+        background: $pt-add-macro-input-bg;
+        border: 1px solid $pt-add-macro-input-stroke;
+        border-radius: 2px;
+        font-family: inherit;
+        font-size: 13px;
+        color: $pt-add-macro-text-strong;
+        outline: none;
+        width: 100%;
+        box-sizing: border-box;
+
+        &--key {
+            justify-content: flex-start;
+            cursor: pointer;
+            text-align: left;
+        }
+
+        &--capturing {
+            border-color: $pt-add-macro-focus-stroke;
+            box-shadow: 0 0 0 2px rgba(94, 127, 163, 0.30);
+        }
+
+        &--select {
+            justify-content: space-between;
+            font-weight: 700;
+        }
+
+        &--readonly {
+            cursor: default;
+        }
+
+        &--text {
+            font-family: 'Ubuntu Mono', Ubuntu, monospace;
+        }
+
+        &::placeholder { color: $pt-add-macro-text-muted; }
+    }
+
+    &__placeholder {
+        color: $pt-add-macro-text-muted;
+        font-size: 12px;
+        letter-spacing: 0.3px;
+    }
+
+    &__value {
+        color: $pt-add-macro-text-strong;
+        font-weight: 700;
+    }
+
+    &__chevron {
+        width: 14px;
+        height: 14px;
+        color: $pt-add-macro-text-strong;
+    }
+
+    &__buttons {
+        display: flex;
+        justify-content: flex-end;
+        gap: 8px;
+        margin-top: 4px;
+    }
+
+    &__btn {
+        display: inline-flex;
+        align-items: center;
+        gap: 6px;
+        height: 32px;
+        padding: 0 14px;
+        border: 2px solid $pt-panel-stroke;
+        border-radius: 3px;
+        color: #FFFFFF;
+        font-family: inherit;
+        font-weight: 700;
+        font-size: 13px;
+        letter-spacing: 0.5px;
+        cursor: pointer;
+        text-shadow: 0 1px 0 rgba(10, 20, 36, 0.50);
+
+        svg { width: 13px; height: 13px; }
+        &:hover { filter: brightness(1.08); }
+        &:disabled { filter: grayscale(0.6) brightness(0.85); cursor: not-allowed; }
+
+        &--reset {
+            background: linear-gradient(180deg,
+                $pt-add-macro-red-top 0%, $pt-add-macro-red-top 50%,
+                $pt-add-macro-red-bottom 50%, $pt-add-macro-red-bottom 100%);
+            box-shadow: 0 1px 0 $pt-add-macro-red-glow;
+        }
+
+        &--add {
+            background: linear-gradient(180deg,
+                $pt-add-macro-green-top 0%, $pt-add-macro-green-top 50%,
+                $pt-add-macro-green-bottom 50%, $pt-add-macro-green-bottom 100%);
+            box-shadow: 0 1px 0 $pt-add-macro-green-glow;
+        }
+    }
+}
