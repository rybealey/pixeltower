+@use './tokens' as *;
+
+// Macros Window — .designs/client_ui.pen frame 59QGF.
+// Outer chrome is NitroCardView (theme="primary"), so the title bar +
+// red X close button match every other Pixeltower dialog. Both action
+// chips (amber "+ New Category", green "+ New Macro") sit in a body
+// action row above the full-width category dropdown.
+
+$pt-macros-text-strong: #1F2C40;
+$pt-macros-text-muted:  #6B7280;
+
+$pt-macros-red-top:     #E04848;
+$pt-macros-red-bottom:  #7A1818;
+$pt-macros-red-glow:    #FF9090;
+
+$pt-macros-green-top:    #48C66B;
+$pt-macros-green-bottom: #1F6B36;
+$pt-macros-green-glow:   #9AE3B0;
+
+$pt-macros-amber-top:    #C8941A;
+$pt-macros-amber-bottom: #5C3D00;
+$pt-macros-amber-glow:   #E8B83A;
+
+$pt-macros-input-bg:     #FFFFFF;
+$pt-macros-input-stroke: #A0A8B5;
+
+$pt-macros-table-bg:     #FFFFFF;
+$pt-macros-table-stroke: #A0A8B5;
+$pt-macros-header-bg:    #EAEAEA;
+$pt-macros-row-divider:  #D0D0D0;
+
+$pt-macros-cmd-chip-bg:     #F4F5F7;
+$pt-macros-cmd-chip-stroke: #C5CCD6;
+$pt-macros-cmd-chip-text:   #2B3A54;
+$pt-macros-cmd-chip-edit:   #9AA3B2;
+
+.pixeltower-macros-window {
+    width: 520px;
+    max-width: calc(100vw - 24px);
+    color: $pt-macros-text-strong;
+    font-family: $pt-font-family;
+
+    &__content {
+        display: flex;
+        flex-direction: column;
+        gap: 12px;
+        padding: 12px 16px 16px 16px;
+        min-height: 0;
+    }
+
+    &__action-row {
+        display: flex;
+        align-items: center;
+        justify-content: flex-end;
+        gap: 8px;
+    }
+
+    %pt-macros-action-chip {
+        display: inline-flex;
+        align-items: center;
+        gap: 6px;
+        height: 30px;
+        padding: 0 12px;
+        border: 2px solid $pt-panel-stroke;
+        border-radius: 3px;
+        color: #FFFFFF;
+        font-family: inherit;
+        font-weight: 700;
+        font-size: 13px;
+        letter-spacing: 0.4px;
+        text-shadow: 0 1px 0 rgba(10, 20, 36, 0.50);
+        cursor: pointer;
+        flex-shrink: 0;
+
+        svg { width: 13px; height: 13px; }
+        &:hover { filter: brightness(1.08); }
+        &:disabled {
+            opacity: 0.65;
+            cursor: not-allowed;
+            &:hover { filter: none; }
+        }
+    }
+
+    &__new-cat-btn {
+        @extend %pt-macros-action-chip;
+        background: linear-gradient(180deg,
+            $pt-macros-amber-top 0%, $pt-macros-amber-top 50%,
+            $pt-macros-amber-bottom 50%, $pt-macros-amber-bottom 100%);
+        box-shadow: 0 1px 0 $pt-macros-amber-glow;
+    }
+
+    &__new-btn {
+        @extend %pt-macros-action-chip;
+        background: linear-gradient(180deg,
+            $pt-macros-green-top 0%, $pt-macros-green-top 50%,
+            $pt-macros-green-bottom 50%, $pt-macros-green-bottom 100%);
+        box-shadow: 0 1px 0 $pt-macros-green-glow;
+    }
+
+    &__cat-dd-wrap {
+        position: relative;
+
+        &--open .pixeltower-macros-window__cat-dd-chev {
+            transform: rotate(180deg);
+        }
+    }
+
+    &__cat-dd {
+        display: flex;
+        align-items: center;
+        justify-content: space-between;
+        width: 100%;
+        height: 32px;
+        padding: 0 10px;
+        background: $pt-macros-input-bg;
+        border: 1px solid $pt-macros-input-stroke;
+        border-radius: 2px;
+        cursor: pointer;
+        font-family: inherit;
+        text-align: left;
+
+        &:hover { filter: brightness(0.98); }
+    }
+
+    &__cat-dd-label {
+        font-size: 13px;
+        font-weight: 700;
+        letter-spacing: 0.4px;
+        color: $pt-macros-text-strong;
+    }
+
+    &__cat-dd-chev {
+        width: 14px;
+        height: 14px;
+        color: $pt-macros-text-strong;
+        transition: transform 120ms ease;
+    }
+
+    &__cat-menu {
+        position: absolute;
+        top: calc(100% + 2px);
+        left: 0;
+        right: 0;
+        z-index: 5;
+        background: $pt-macros-input-bg;
+        border: 1px solid $pt-macros-input-stroke;
+        border-radius: 2px;
+        box-shadow: 0 4px 8px rgba(10, 20, 36, 0.25);
+        max-height: 240px;
+        overflow-y: auto;
+    }
+
+    &__cat-item {
+        display: flex;
+        align-items: center;
+        justify-content: space-between;
+        gap: 8px;
+        height: 30px;
+        padding: 0 10px;
+        cursor: pointer;
+        font-size: 13px;
+        font-weight: 700;
+        color: $pt-macros-text-strong;
+
+        &:hover { background: rgba(94, 127, 163, 0.12); }
+
+        &--active {
+            background: rgba(94, 127, 163, 0.18);
+        }
+    }
+
+    &__cat-item-name {
+        flex: 1 1 auto;
+        min-width: 0;
+        text-overflow: ellipsis;
+        white-space: nowrap;
+        overflow: hidden;
+    }
+
+    &__cat-item-del {
+        display: inline-flex;
+        align-items: center;
+        justify-content: center;
+        width: 22px;
+        height: 22px;
+        padding: 0;
+        border: 1px solid $pt-panel-stroke;
+        border-radius: 3px;
+        background: linear-gradient(180deg,
+            $pt-macros-red-top 0%, $pt-macros-red-top 50%,
+            $pt-macros-red-bottom 50%, $pt-macros-red-bottom 100%);
+        color: #FFFFFF;
+        cursor: pointer;
+        opacity: 0.85;
+
+        svg { width: 11px; height: 11px; }
+        &:hover { opacity: 1; filter: brightness(1.05); }
+    }
+
+    &__table {
+        background: $pt-macros-table-bg;
+        border: 1px solid $pt-macros-table-stroke;
+        border-radius: 3px;
+        overflow: hidden;
+        display: flex;
+        flex-direction: column;
+    }
+
+    &__row {
+        display: flex;
+        align-items: center;
+        gap: 12px;
+        padding: 8px 12px;
+        border-bottom: 1px solid $pt-macros-row-divider;
+        transition: background 120ms ease, opacity 120ms ease;
+
+        &:last-child { border-bottom: 0; }
+
+        &--header {
+            background: $pt-macros-header-bg;
+            color: $pt-macros-text-muted;
+            font-size: 12px;
+            font-weight: 700;
+            letter-spacing: 1px;
+            text-transform: uppercase;
+        }
+
+        &--dragging {
+            opacity: 0.5;
+        }
+
+        &--drop-target {
+            background: rgba(94, 127, 163, 0.12);
+            box-shadow: inset 0 2px 0 $pt-panel-stroke;
+        }
+    }
+
+    &__col {
+        display: flex;
+        align-items: center;
+        font-size: 14px;
+        font-weight: 700;
+        color: $pt-macros-text-strong;
+
+        &--grip {
+            width: 16px;
+            flex-shrink: 0;
+            justify-content: center;
+            color: $pt-macros-cmd-chip-edit;
+            cursor: grab;
+
+            svg { width: 16px; height: 16px; }
+        }
+
+        &--key {
+            width: 140px;
+            flex-shrink: 0;
+        }
+
+        &--cmd {
+            flex: 1 1 auto;
+            min-width: 0;
+        }
+
+        &--action {
+            flex-shrink: 0;
+            width: 56px;
+            justify-content: flex-end;
+        }
+    }
+
+    &__row--header &__col--key,
+    &__row--header &__col--cmd,
+    &__row--header &__col--action {
+        font-weight: 700;
+        color: $pt-macros-text-muted;
+    }
+
+    // Drag handle column header is empty (grip is row-only) — keep the
+    // 16px slot reserved so columns line up between header + body.
+    &__row--header &__col--grip { cursor: default; }
+
+    &__cmd-chip {
