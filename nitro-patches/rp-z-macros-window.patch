diff --git a/src/components/pixeltower/AddMacroDialog.tsx b/src/components/pixeltower/AddMacroDialog.tsx
new file mode 100644
index 0000000..8ce79f8
--- /dev/null
+++ b/src/components/pixeltower/AddMacroDialog.tsx
@@ -0,0 +1,110 @@
+import { FC, useEffect, useMemo, useState } from 'react';
+import { LuCheck, LuChevronDown, LuRotateCcw } from 'react-icons/lu';
+import { formatBindingForDisplay } from '../../api/pixeltower/MacroBindingFormat';
+import { NitroCardContentView, NitroCardHeaderView, NitroCardView } from '../../common';
+import { useKeybindCapture, useMacros } from '../../hooks/pixeltower';
+
+// .designs/client_ui.pen frame X8ukF — modal triggered by the
+// "+ New Macro" button on the Macros window's top action row. Owns local
+// form state; on Add Macro, hands the captured binding + command back via
+// onSave and the parent dispatches the SaveMacroComposer. Native Nitro
+// card chrome for parity with every other in-game dialog.
+//
+// Category select pulls from the same useMacros snapshot that drives the
+// list; default selection is whichever category is currently active.
+
+interface AddMacroDialogProps
+{
+    onClose: () => void;
+    onSave: (keybind: string, command: string, category: string) => void;
+}
+
+export const AddMacroDialog: FC<AddMacroDialogProps> = ({ onClose, onSave }) =>
+{
+    const { isCapturing, captured, startCapture, reset } = useKeybindCapture();
+    const [ command, setCommand ] = useState('');
+    const [ wasCapturing, setWasCapturing ] = useState(false);
+    const { categories } = useMacros();
+    const initialCategory = useMemo(
+        () => (categories.find(c => c.isActive) ?? categories[0])?.name ?? 'Default',
+        // Run once on mount; category selection is local-only after that.
+        // eslint-disable-next-line react-hooks/exhaustive-deps
+        []);
+    const [ category, setCategory ] = useState<string>(initialCategory);
+
+    // Track once we've left capture mode so the placeholder swap doesn't flash
+    // back to "Press a key…" between presses.
+    useEffect(() => { if(isCapturing) setWasCapturing(true); }, [ isCapturing ]);
+
+    const canSave = captured.length > 0 && command.trim().length > 0;
+
+    const handleSave = () =>
+    {
+        if(!canSave) return;
+        onSave(captured, command.trim(), category);
+    };
+
+    const placeholder = isCapturing ? 'Press a key or mouse button…' : 'Click to record a keybinding';
+    const display = formatBindingForDisplay(captured);
+
+    return (
+        <NitroCardView uniqueKey="pixeltower-add-macro" theme="primary" classNames={ [ 'pixeltower-add-macro' ] }>
+            <NitroCardHeaderView headerText="Add New Macro" onCloseClick={ onClose } />
+            <NitroCardContentView classNames={ [ 'pixeltower-add-macro__content' ] }>
+                <div className="pixeltower-add-macro__field">
+                    <label className="pixeltower-add-macro__label">Keybinding</label>
+                    <button
+                        type="button"
+                        className={ 'pixeltower-add-macro__input pixeltower-add-macro__input--key' + (isCapturing ? ' pixeltower-add-macro__input--capturing' : '') }
+                        onClick={ startCapture }>
+                        { display
+                            ? <span className="pixeltower-add-macro__value">{ display }</span>
+                            : <span className="pixeltower-add-macro__placeholder">{ wasCapturing ? placeholder : placeholder }</span>
+                        }
+                    </button>
+                </div>
+                <div className="pixeltower-add-macro__field">
+                    <label className="pixeltower-add-macro__label">Category</label>
+                    <div className="pixeltower-add-macro__input pixeltower-add-macro__input--select">
+                        <select
+                            className="pixeltower-add-macro__select"
+                            value={ category }
+                            onChange={ e => setCategory(e.target.value) }>
+                            { categories.map(c => (
+                                <option key={ c.id } value={ c.name }>{ c.name }</option>
+                            )) }
+                        </select>
+                        <LuChevronDown className="pixeltower-add-macro__chevron" />
+                    </div>
+                </div>
+                <div className="pixeltower-add-macro__field">
+                    <label className="pixeltower-add-macro__label">Command</label>
+                    <input
+                        type="text"
+                        className="pixeltower-add-macro__input pixeltower-add-macro__input--text"
+                        placeholder="Enter macro command"
+                        value={ command }
+                        onChange={ e => setCommand(e.target.value) }
+                        maxLength={ 128 } />
+                </div>
+                <div className="pixeltower-add-macro__buttons">
+                    <button
+                        type="button"
+                        className="pixeltower-add-macro__btn pixeltower-add-macro__btn--reset"
+                        onClick={ reset }>
+                        <LuRotateCcw />
+                        <span>Reset Keys</span>
+                    </button>
+                    <button
+                        type="button"
+                        className="pixeltower-add-macro__btn pixeltower-add-macro__btn--add"
+                        disabled={ !canSave }
+                        onClick={ handleSave }>
+                        <LuCheck />
+                        <span>Add Macro</span>
+                    </button>
+                </div>
+            </NitroCardContentView>
+        </NitroCardView>
+    );
+}
