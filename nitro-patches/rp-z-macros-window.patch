diff --git a/src/components/pixeltower/MacrosKeybindListener.tsx b/src/components/pixeltower/MacrosKeybindListener.tsx
new file mode 100644
index 0000000..b1ed484
--- /dev/null
+++ b/src/components/pixeltower/MacrosKeybindListener.tsx
@@ -0,0 +1,90 @@
+import { FC, useEffect } from 'react';
+import { ChatMessageTypeEnum, SendMessageComposer } from '../../api';
+import { encodeKeyEvent, encodeMouseEvent } from '../../api/pixeltower/MacroBindingFormat';
+import { RequestMacrosComposer } from '../../api/pixeltower/PixeltowerSoundMessages';
+import { useRoom } from '../../hooks';
+import { useMacros } from '../../hooks/pixeltower';
+import { useChatInputWidget } from '../../hooks/rooms/widgets/useChatInputWidget';
+
+// Headless component — mounted once in MainView. Owns the global keydown +
+// mousedown listeners that fire saved macros from anywhere in the client.
+//
+// Why a separate component: the MacrosWindow is unmounted while closed, but
+// the dispatcher needs to run continuously. useMacros is shared across both
+// components via useBetween, so the listener stays in sync with whatever
+// the player has saved.
+//
+// Why useChatInputWidget here: it exposes sendChat(), which already has all
+// the :command shortcuts wired up (:ps x → currently selected target, :hit,
+// :commands open, etc.). Reusing it means a macro for ":ps x" behaves
+// identically to typing ":ps x" into the chat box. The hook isn't memoized
+// across instances so its internal state is parallel to the chat widget's,
+// but only sendChat is read here, and sendChat reads roomSession from the
+// shared useRoom() context.
+
+export const MacrosKeybindListener: FC<{}> = () =>
+{
+    const { macros } = useMacros();
+    const { sendChat } = useChatInputWidget();
+    const { roomSession } = useRoom();
+
+    // Pull a fresh list once on mount. The window also requests on every
+    // open, but mounting before the window is ever opened means saved macros
+    // start firing from the first key press of the session.
+    useEffect(() =>
+    {
+        SendMessageComposer(new RequestMacrosComposer());
+    }, []);
+
+    useEffect(() =>
+    {
+        if(!sendChat || !roomSession || macros.length === 0) return;
+
+        const map = new Map<string, string>();
+        macros.forEach(m => map.set(m.keybind, m.command));
+
+        const isInputActive = () =>
+        {
+            const el = document.activeElement as HTMLElement | null;
+            if(!el) return false;
+            const tag = el.tagName;
+            if(tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT') return true;
+            if(el.isContentEditable) return true;
+            return false;
+        };
+
+        const fire = (binding: string): boolean =>
+        {
+            const command = map.get(binding);
+            if(!command) return false;
+            sendChat(command, ChatMessageTypeEnum.CHAT_DEFAULT);
+            return true;
+        };
+
+        const onKey = (event: KeyboardEvent) =>
+        {
+            if(isInputActive()) return;
+            const binding = encodeKeyEvent(event);
+            if(!binding) return;
+            if(fire(binding)) event.preventDefault();
+        };
+
+        const onMouse = (event: MouseEvent) =>
+        {
+            if(isInputActive()) return;
+            const binding = encodeMouseEvent(event);
+            if(!binding) return;
+            if(fire(binding)) event.preventDefault();
+        };
+
+        document.addEventListener('keydown', onKey);
+        document.addEventListener('mousedown', onMouse);
+        return () =>
+        {
+            document.removeEventListener('keydown', onKey);
+            document.removeEventListener('mousedown', onMouse);
+        };
+    }, [ macros, sendChat, roomSession ]);
+
+    return null;
+}
