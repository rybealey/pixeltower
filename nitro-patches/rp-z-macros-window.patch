@@ -0,0 +1,68 @@
+import { FC, useState } from 'react';
+import { LuCheck } from 'react-icons/lu';
+import { SendMessageComposer } from '../../api';
+import { CreateMacroCategoryComposer } from '../../api/pixeltower/PixeltowerSoundMessages';
+import { NitroCardContentView, NitroCardHeaderView, NitroCardView } from '../../common';
+
+// .designs/client_ui.pen frame mY6Az — modal triggered by the amber
+// "+ New Category" button on the Macros window's action row. Single
+// Category Name input + Cancel / Add Category buttons. Server-side
+// MacrosManager.createCategory trims, length-checks, and dedups; on
+// any rejection the snapshot echo lets the modal close cleanly.
+
+interface AddMacroCategoryDialogProps
+{
+    onClose: () => void;
+}
+
+const MAX_NAME_LEN = 32;
+
+export const AddMacroCategoryDialog: FC<AddMacroCategoryDialogProps> = ({ onClose }) =>
+{
+    const [ name, setName ] = useState('');
+    const trimmed = name.trim();
+    const canSubmit = trimmed.length > 0 && trimmed.length <= MAX_NAME_LEN;
+
+    const handleSubmit = () =>
+    {
+        if(!canSubmit) return;
+        SendMessageComposer(new CreateMacroCategoryComposer(trimmed));
+        onClose();
+    };
+
+    return (
+        <NitroCardView uniqueKey="pixeltower-add-macro-category" theme="primary" classNames={ [ 'pixeltower-add-macro-cat' ] }>
+            <NitroCardHeaderView headerText="Add New Macro Category" onCloseClick={ onClose } />
+            <NitroCardContentView classNames={ [ 'pixeltower-add-macro-cat__content' ] }>
+                <div className="pixeltower-add-macro-cat__field">
+                    <label className="pixeltower-add-macro-cat__label">Category Name</label>
+                    <input
+                        type="text"
+                        className="pixeltower-add-macro-cat__input"
+                        placeholder="Enter category name"
+                        value={ name }
+                        autoFocus
+                        onChange={ e => setName(e.target.value) }
+                        onKeyDown={ e => { if(e.key === 'Enter') handleSubmit(); else if(e.key === 'Escape') onClose(); } }
+                        maxLength={ MAX_NAME_LEN } />
+                </div>
+                <div className="pixeltower-add-macro-cat__buttons">
+                    <button
+                        type="button"
+                        className="pixeltower-add-macro-cat__btn pixeltower-add-macro-cat__btn--cancel"
+                        onClick={ onClose }>
+                        <span>Cancel</span>
+                    </button>
+                    <button
+                        type="button"
+                        className="pixeltower-add-macro-cat__btn pixeltower-add-macro-cat__btn--add"
+                        disabled={ !canSubmit }
+                        onClick={ handleSubmit }>
+                        <LuCheck />
+                        <span>Add Category</span>
+                    </button>
+                </div>
+            </NitroCardContentView>
+        </NitroCardView>
+    );
+}
