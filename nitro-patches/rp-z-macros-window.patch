+// ──────────── MacrosList (header 6553) ────────────
+//
+// Snapshot of every macro the local player has saved. Sent in response to
+// RequestMacrosComposer; the MacrosWindow + MacrosKeybindListener replace
+// their state wholesale on each receipt. The `keybind` field uses the
+// MacroBindingFormat encoding (see api/pixeltower/MacroBindingFormat.ts).
+
+export interface MacrosListItem
+{
+    macroId: number;
+    keybind: string;
+    command: string;
+    category: string;
+}
+
+export interface MacroCategoryItem
+{
+    id: number;
+    name: string;
+    sortOrder: number;
+    isActive: boolean;
+}
+
+export class MacrosListParser implements IMessageParser
+{
+    private _macros: MacrosListItem[];
+    private _categories: MacroCategoryItem[];
+
+    public flush(): boolean
+    {
+        this._macros = [];
+        this._categories = [];
+        return true;
+    }
+
+    public parse(wrapper: IMessageDataWrapper): boolean
+    {
+        if(!wrapper) return false;
+        this._macros = [];
+        this._categories = [];
+        const count = wrapper.readInt();
+        for(let i = 0; i < count; i++)
+        {
+            this._macros.push({
+                macroId: wrapper.readInt(),
+                keybind: wrapper.readString(),
+                command: wrapper.readString(),
+                category: wrapper.readString()
+            });
+        }
+        const catCount = wrapper.readInt();
+        for(let i = 0; i < catCount; i++)
+        {
+            this._categories.push({
+                id: wrapper.readInt(),
+                name: wrapper.readString(),
+                sortOrder: wrapper.readInt(),
+                isActive: wrapper.readBoolean()
+            });
+        }
+        return true;
+    }
+
+    public get macros(): MacrosListItem[]
+    {
+        return this._macros;
+    }
+
+    public get categories(): MacroCategoryItem[]
+    {
+        return this._categories;
+    }
+}
+
+export class MacrosListEvent extends MessageEvent implements IMessageEvent
+{
+    constructor(callBack: Function)
+    {
+        super(callBack, MacrosListParser);
+    }
+
+    public getParser(): MacrosListParser
+    {
+        return this.parser as MacrosListParser;
+    }
+}
+
+// ──────────── RequestMacros (header 6554, client→server) ────────────
+
+export class RequestMacrosComposer implements IMessageComposer<ConstructorParameters<typeof RequestMacrosComposer>>
+{
+    private _data: ConstructorParameters<typeof RequestMacrosComposer>;
+
+    constructor()
+    {
+        this._data = [];
+    }
+
+    public getMessageArray() { return this._data; }
+    public dispose(): void { return; }
+}
+
+// ──────────── SaveMacro (header 6555, client→server) ────────────
+//
+// Wire format: int macroId (0 for new), string keybind, string command,
+// string category. Server upserts on (habboId, keybind) and replies with
+// a fresh MacrosListEvent.
+
+export class SaveMacroComposer implements IMessageComposer<ConstructorParameters<typeof SaveMacroComposer>>
+{
+    private _data: ConstructorParameters<typeof SaveMacroComposer>;
+
+    constructor(macroId: number, keybind: string, command: string, category: string)
+    {
+        this._data = [ macroId, keybind, command, category ];
+    }
+
+    public getMessageArray() { return this._data; }
+    public dispose(): void { return; }
+}
+
+// ──────────── DeleteMacro (header 6556, client→server) ────────────
+
+export class DeleteMacroComposer implements IMessageComposer<ConstructorParameters<typeof DeleteMacroComposer>>
+{
+    private _data: ConstructorParameters<typeof DeleteMacroComposer>;
+
+    constructor(macroId: number)
