new file mode 100644
index 0000000..32aa046
--- /dev/null
+++ b/src/api/pixeltower/MacroBindingFormat.ts
@@ -0,0 +1,97 @@
+// Shared encoding for macro keybindings — used by useKeybindCapture (when
+// the user presses a key in the Add Macro modal) and MacrosKeybindListener
+// (when matching a global press against the saved macro list). Encoding
+// stays the same string round-trip: client → server → client.
+//
+// Wire format: optional `Mod+`* prefix (canonical order
+// Ctrl+Shift+Alt+Meta+) followed by exactly one of:
+//   Key:<KeyboardEvent.code>     e.g. Key:Digit4, Key:KeyW, Key:F2
+//   Mouse4 / Mouse5              browser back/forward thumb buttons
+//   MouseMiddle                  scroll-wheel click
+
+const MOD_ORDER: Array<{ flag: 'ctrlKey' | 'shiftKey' | 'altKey' | 'metaKey'; label: string }> = [
+    { flag: 'ctrlKey',  label: 'Ctrl' },
+    { flag: 'shiftKey', label: 'Shift' },
+    { flag: 'altKey',   label: 'Alt' },
+    { flag: 'metaKey',  label: 'Meta' }
+];
+
+const MODIFIER_KEY_CODES = new Set<string>([
+    'ControlLeft', 'ControlRight',
+    'ShiftLeft', 'ShiftRight',
+    'AltLeft', 'AltRight',
+    'MetaLeft', 'MetaRight',
+    'OSLeft', 'OSRight'
+]);
+
+const modifierPrefix = (e: { ctrlKey: boolean; shiftKey: boolean; altKey: boolean; metaKey: boolean }): string =>
+    MOD_ORDER.filter(m => e[m.flag]).map(m => m.label + '+').join('');
+
+export const isModifierOnlyKey = (code: string): boolean =>
+    MODIFIER_KEY_CODES.has(code);
+
+export const encodeKeyEvent = (event: KeyboardEvent): string | null =>
+{
+    if(!event.code || isModifierOnlyKey(event.code)) return null;
+    return modifierPrefix(event) + 'Key:' + event.code;
+}
+
+export const encodeMouseEvent = (event: MouseEvent): string | null =>
+{
+    let token: string;
+    switch(event.button)
+    {
+        case 1: token = 'MouseMiddle'; break;
+        case 3: token = 'Mouse4'; break;
+        case 4: token = 'Mouse5'; break;
+        default: return null; // ignore left/right click — they're used for normal interaction
+    }
+    return modifierPrefix(event) + token;
+}
+
+// Map KeyboardEvent.code → human label. Covers the codes a player is likely
+// to bind. Falls through to the raw code so unmapped keys are still legible.
+const CODE_LABELS: Record<string, string> = {
+    Backquote: '`', Minus: '-', Equal: '=',
+    BracketLeft: '[', BracketRight: ']', Backslash: '\\',
+    Semicolon: ';', Quote: "'",
+    Comma: ',', Period: '.', Slash: '/',
+    Space: 'Space', Enter: 'Enter', Tab: 'Tab', Escape: 'Esc',
+    Backspace: 'Backspace', Delete: 'Del', Insert: 'Ins',
+    Home: 'Home', End: 'End', PageUp: 'PgUp', PageDown: 'PgDn',
+    ArrowUp: '↑', ArrowDown: '↓', ArrowLeft: '←', ArrowRight: '→',
+    NumpadAdd: 'Num+', NumpadSubtract: 'Num-',
+    NumpadMultiply: 'Num*', NumpadDivide: 'Num/',
+    NumpadEnter: 'NumEnter', NumpadDecimal: 'Num.'
+};
+
+const labelKeyCode = (code: string): string =>
+{
+    if(CODE_LABELS[code]) return CODE_LABELS[code];
+    if(code.startsWith('Key')) return code.slice(3);            // KeyW → W
+    if(code.startsWith('Digit')) return code.slice(5);          // Digit4 → 4
+    if(code.startsWith('Numpad')) return 'Num' + code.slice(6); // Numpad4 → Num4
+    if(/^F\d{1,2}$/.test(code)) return code;                    // F1..F12 verbatim
+    return code;
+}
+
+const TOKEN_LABELS: Record<string, string> = {
+    Mouse4: 'Mouse Forward',
+    Mouse5: 'Mouse Back',
+    MouseMiddle: 'Middle Click'
+};
+
+export const formatBindingForDisplay = (binding: string): string =>
+{
+    if(!binding) return '';
+    const segments = binding.split('+');
+    const last = segments.pop();
+    const mods = segments.join('+');
+
+    let body: string;
+    if(last && last.startsWith('Key:')) body = labelKeyCode(last.slice(4));
+    else if(last && TOKEN_LABELS[last]) body = TOKEN_LABELS[last];
+    else body = last || '';
+
+    return mods.length ? mods + '+' + body : body;
+}
