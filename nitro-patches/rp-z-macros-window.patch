diff --git a/src/components/pixeltower/MacrosKeybindListener.tsx b/src/components/pixeltower/MacrosKeybindListener.tsx
new file mode 100644
index 0000000..b4c26e2
--- /dev/null
+++ b/src/components/pixeltower/MacrosKeybindListener.tsx
@@ -0,0 +1,137 @@
+import { FC, useEffect, useRef } from 'react';
+import { ChatMessageTypeEnum, SendMessageComposer } from '../../api';
+import { encodeKeyEvent, encodeMouseEvent } from '../../api/pixeltower/MacroBindingFormat';
+import { RequestMacrosComposer } from '../../api/pixeltower/PixeltowerSoundMessages';
+import { useRoom } from '../../hooks';
+import { Macro, useMacros } from '../../hooks/pixeltower';
+import { useChatInputWidget } from '../../hooks/rooms/widgets/useChatInputWidget';
+
+// Headless component — mounted once in MainView. Owns the global keydown +
+// mousedown listeners that fire saved macros from anywhere in the client.
+//
+// Why a separate component: the MacrosWindow is unmounted while closed, but
+// the dispatcher needs to run continuously. useMacros is shared across both
+// components via useBetween, so the listener stays in sync with whatever
+// the player has saved.
+//
+// Why useChatInputWidget here: it exposes sendChat(), which already has all
+// the :command shortcuts wired up (:ps x → currently selected target, :hit,
+// :commands open, etc.). Reusing it means a macro for ":ps x" behaves
+// identically to typing ":ps x" into the chat box. The hook isn't memoized
+// across instances so its internal state is parallel to the chat widget's,
+// but only sendChat is read here, and sendChat reads roomSession from the
+// shared useRoom() context.
+//
+// Why capture phase: the chat widget's keydown listener (bubble phase, on
+// document.body) calls setInputFocus() on every keystroke when no input is
+// focused. If we listened in bubble phase too, by the time we ran the chat
+// input would already be focused and our isInputActive() check would
+// always bail. Registering on document in capture phase fires us first,
+// then we stopPropagation() so the chat widget never sees a macro press.
+
+type SendChatFn = (text: string, chatType: number, recipientName?: string, styleId?: number) => void;
+
+export const MacrosKeybindListener: FC<{}> = () =>
+{
+    const { macros } = useMacros();
+    const { sendChat } = useChatInputWidget();
+    const { roomSession } = useRoom();
+
+    // Stash the latest references so the document listeners (attached once
+    // on mount) always see fresh state without tearing down each render.
+    // useChatInputWidget recreates sendChat on every render and roomSession
+    // updates whenever the user enters/exits a room — re-binding listeners
+    // on each change risks a window where neither old nor new is active.
+    const macrosRef = useRef<Macro[]>(macros);
+    const sendChatRef = useRef<SendChatFn | null>(sendChat ?? null);
+    const roomSessionRef = useRef(roomSession);
+
+    useEffect(() => { macrosRef.current = macros; }, [ macros ]);
+    useEffect(() => { sendChatRef.current = sendChat ?? null; }, [ sendChat ]);
+    useEffect(() => { roomSessionRef.current = roomSession; }, [ roomSession ]);
+
+    // Pull a fresh list once on mount. The window also requests on every
+    // open, but mounting before the window is ever opened means saved macros
+    // start firing from the first key press of the session.
+    useEffect(() =>
+    {
+        SendMessageComposer(new RequestMacrosComposer());
+    }, []);
+
+    useEffect(() =>
+    {
+        const isInputActive = () =>
+        {
+            const el = document.activeElement as HTMLElement | null;
+            if(!el) return false;
+            const tag = el.tagName;
+            if(tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT') return true;
+            if(el.isContentEditable) return true;
+            return false;
+        };
+
+        const fire = (binding: string): boolean =>
+        {
+            if(!roomSessionRef.current || !sendChatRef.current) return false;
+            const macro = macrosRef.current.find(m => m.keybind === binding);
+            if(!macro) return false;
+            sendChatRef.current(macro.command, ChatMessageTypeEnum.CHAT_DEFAULT);
+            return true;
+        };
+
+        // Holding Alt (Option on Mac), Ctrl/Control, or Meta (Cmd on Mac /
+        // Win key) signals macro intent even when the chat input is focused
+        // — those combos aren't valid text input across either platform, so
+        // we treat them as a macro attempt regardless of focus and at
+        // minimum keep the chat widget from focus-stealing on the press.
+        const isMacroIntent = (event: KeyboardEvent | MouseEvent) =>
+            event.altKey || event.ctrlKey || event.metaKey;
+
+        const onKey = (event: KeyboardEvent) =>
+        {
+            const intent = isMacroIntent(event);
+            if(!intent && isInputActive()) return;
+            const binding = encodeKeyEvent(event);
+            if(!binding) return;
+            if(fire(binding))
+            {
+                event.preventDefault();
+                event.stopPropagation();
+            }
+            else if(intent)
+            {
+                // Modifier press with no matching macro: don't preventDefault
+                // (could be a legitimate browser shortcut) but stop propagation
+                // so the chat widget doesn't grab focus on the press.
+                event.stopPropagation();
+            }
+        };
+
+        const onMouse = (event: MouseEvent) =>
+        {
+            const intent = isMacroIntent(event);
+            if(!intent && isInputActive()) return;
+            const binding = encodeMouseEvent(event);
+            if(!binding) return;
+            if(fire(binding))
+            {
+                event.preventDefault();
+                event.stopPropagation();
+            }
+            else if(intent)
+            {
+                event.stopPropagation();
+            }
+        };
+
+        document.addEventListener('keydown', onKey, true);
+        document.addEventListener('mousedown', onMouse, true);
+        return () =>
+        {
+            document.removeEventListener('keydown', onKey, true);
+            document.removeEventListener('mousedown', onMouse, true);
+        };
+    }, []);
+
+    return null;
+}
diff --git a/src/components/pixeltower/MacrosWindow.scss b/src/components/pixeltower/MacrosWindow.scss
