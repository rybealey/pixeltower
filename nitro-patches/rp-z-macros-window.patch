diff --git a/src/components/pixeltower/MacrosWindow.tsx b/src/components/pixeltower/MacrosWindow.tsx
new file mode 100644
index 0000000..b811e0f
--- /dev/null
+++ b/src/components/pixeltower/MacrosWindow.tsx
@@ -0,0 +1,145 @@
+import { ILinkEventTracker } from '@nitrots/nitro-renderer';
+import { FC, useEffect, useState } from 'react';
+import { LuChevronDown, LuPencil, LuPlus, LuTrash2 } from 'react-icons/lu';
+import { AddEventLinkTracker, RemoveLinkEventTracker, SendMessageComposer } from '../../api';
+import { formatBindingForDisplay } from '../../api/pixeltower/MacroBindingFormat';
+import { DeleteMacroComposer, RequestMacrosComposer, SaveMacroComposer } from '../../api/pixeltower/PixeltowerSoundMessages';
+import { NitroCardContentView, NitroCardHeaderView, NitroCardView } from '../../common';
+import { useMacros } from '../../hooks/pixeltower';
+import { AddMacroDialog } from './AddMacroDialog';
+
+// Macros Window — .designs/client_ui.pen frame 59QGF.
+// Triggered from the Drawer HUD "Macros" button via
+// CreateLinkEvent('macros-window/show|hide|toggle'). Uses native Nitro card
+// chrome (draggable header, red X close button) for parity with every other
+// in-game dialog. The "+ New Macro" action lives in a top action row above
+// the tab strip rather than inside the title bar — moving it out keeps the
+// header consistent with Habbo's standard chrome.
+//
+// The roster is fetched via RequestMacrosComposer (header 6554) on each
+// open and replied to with a MacrosListEvent (header 6553), shared across
+// the app via the useMacros hook. The MacrosKeybindListener consumes the
+// same hook to dispatch saved bindings against the global key/mouse stream.
+
+export const MacrosWindow: FC<{}> = () =>
+{
+    const [ isVisible, setIsVisible ] = useState(false);
+    const [ addOpen, setAddOpen ] = useState(false);
+    const { macros } = useMacros();
+
+    useEffect(() =>
+    {
+        const linkTracker: ILinkEventTracker = {
+            linkReceived: (url: string) =>
+            {
+                const parts = url.split('/');
+                if(parts.length < 2) return;
+                switch(parts[1])
+                {
+                    case 'show':   setIsVisible(true); return;
+                    case 'hide':   setIsVisible(false); return;
+                    case 'toggle': setIsVisible(v => !v); return;
+                }
+            },
+            eventUrlPrefix: 'macros-window/'
+        };
+        AddEventLinkTracker(linkTracker);
+        return () => RemoveLinkEventTracker(linkTracker);
+    }, []);
+
+    useEffect(() =>
+    {
+        if(!isVisible) return;
+        SendMessageComposer(new RequestMacrosComposer());
+    }, [ isVisible ]);
+
+    if(!isVisible) return null;
+
+    const close = () =>
+    {
+        setAddOpen(false);
+        setIsVisible(false);
+    };
+
+    const handleSave = (keybind: string, command: string, category: string) =>
+    {
+        SendMessageComposer(new SaveMacroComposer(0, keybind, command, category));
+        setAddOpen(false);
+    };
+
+    const handleDelete = (macroId: number) =>
+    {
+        SendMessageComposer(new DeleteMacroComposer(macroId));
+    };
+
+    return (
+        <>
+            <NitroCardView uniqueKey="pixeltower-macros" theme="primary" classNames={ [ 'pixeltower-macros-window' ] }>
+                <NitroCardHeaderView headerText="Macros" onCloseClick={ close } />
+                <NitroCardContentView classNames={ [ 'pixeltower-macros-window__content' ] } overflow="hidden">
+                    <div className="pixeltower-macros-window__action-row">
+                        <button
+                            type="button"
+                            className="pixeltower-macros-window__new-cat-btn"
+                            title="More categories coming soon"
+                            disabled>
+                            <LuPlus />
+                            <span>New Category</span>
+                        </button>
+                        <button
+                            type="button"
+                            className="pixeltower-macros-window__new-btn"
+                            title="New macro"
+                            onClick={ () => setAddOpen(true) }>
+                            <LuPlus />
+                            <span>New Macro</span>
+                        </button>
+                    </div>
+                    <div className="pixeltower-macros-window__cat-dd">
+                        <span className="pixeltower-macros-window__cat-dd-label">Default</span>
+                        <LuChevronDown className="pixeltower-macros-window__cat-dd-chev" />
+                    </div>
+                    <div className="pixeltower-macros-window__table">
+                        <div className="pixeltower-macros-window__row pixeltower-macros-window__row--header">
+                            <div className="pixeltower-macros-window__col pixeltower-macros-window__col--key">Keybinding</div>
+                            <div className="pixeltower-macros-window__col pixeltower-macros-window__col--cmd">Command</div>
+                            <div className="pixeltower-macros-window__col pixeltower-macros-window__col--action">Action</div>
+                        </div>
+                        { macros.length === 0 && (
+                            <div className="pixeltower-macros-window__empty">
+                                No macros yet — click <strong>+ New Macro</strong> to bind a key.
+                            </div>
+                        ) }
+                        { macros.map(macro => (
+                            <div key={ macro.macroId } className="pixeltower-macros-window__row">
+                                <div className="pixeltower-macros-window__col pixeltower-macros-window__col--key">
+                                    { formatBindingForDisplay(macro.keybind) }
+                                </div>
+                                <div className="pixeltower-macros-window__col pixeltower-macros-window__col--cmd">
+                                    <div className="pixeltower-macros-window__cmd-chip">
+                                        <span className="pixeltower-macros-window__cmd-text">{ macro.command }</span>
+                                        <LuPencil className="pixeltower-macros-window__cmd-edit" />
+                                    </div>
+                                </div>
+                                <div className="pixeltower-macros-window__col pixeltower-macros-window__col--action">
+                                    <button
+                                        type="button"
+                                        className="pixeltower-macros-window__delete"
+                                        title="Delete macro"
+                                        onClick={ () => handleDelete(macro.macroId) }>
+                                        <LuTrash2 />
+                                    </button>
+                                </div>
+                            </div>
+                        )) }
+                    </div>
+                </NitroCardContentView>
+            </NitroCardView>
+            { addOpen && (
+                <AddMacroDialog
+                    onClose={ () => setAddOpen(false) }
+                    onSave={ handleSave } />
+            ) }
+        </>
+    );
+}
