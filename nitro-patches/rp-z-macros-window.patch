+@use './tokens' as *;
+
+// Add New Macro Category dialog — .designs/client_ui.pen frame mY6Az.
+// Outer chrome is NitroCardView (theme="primary"); body matches the
+// .pen single-input + Cancel/Add Category buttons row.
+
+$pt-cat-input-bg:     #FFFFFF;
+$pt-cat-input-stroke: #A0A8B5;
+$pt-cat-text-strong:  #1F2C40;
+$pt-cat-text-muted:   #6B7280;
+
+$pt-cat-cancel-top:    #5E7FA3;
+$pt-cat-cancel-bottom: #2B3A54;
+$pt-cat-cancel-glow:   #9AB4D3;
+
+$pt-cat-add-top:    #48C66B;
+$pt-cat-add-bottom: #1F6B36;
+$pt-cat-add-glow:   #9AE3B0;
+
+.pixeltower-add-macro-cat {
+    width: 380px;
+    max-width: calc(100vw - 24px);
+    color: $pt-cat-text-strong;
+    font-family: $pt-font-family;
+
+    &__content {
+        display: flex;
+        flex-direction: column;
+        gap: 12px;
+        padding: 14px;
+    }
+
+    &__field {
+        display: flex;
+        flex-direction: column;
+        gap: 5px;
+    }
+
+    &__label {
+        font-size: 12px;
+        font-weight: 700;
+        letter-spacing: 0.4px;
+        color: $pt-cat-text-strong;
+    }
+
+    &__input {
+        height: 34px;
+        padding: 0 10px;
+        background: $pt-cat-input-bg;
+        border: 1px solid $pt-cat-input-stroke;
+        border-radius: 2px;
+        font-family: inherit;
+        font-size: 13px;
+        color: $pt-cat-text-strong;
+        outline: none;
+        width: 100%;
+        box-sizing: border-box;
+
+        &::placeholder { color: $pt-cat-text-muted; }
+        &:focus {
+            border-color: $pt-cat-cancel-bottom;
+            box-shadow: 0 0 0 2px rgba(94, 127, 163, 0.30);
+        }
+    }
+
+    &__buttons {
+        display: flex;
+        justify-content: flex-end;
+        gap: 8px;
+        margin-top: 4px;
+    }
+
+    &__btn {
+        display: inline-flex;
+        align-items: center;
+        gap: 6px;
+        height: 32px;
+        padding: 0 14px;
+        border: 2px solid $pt-panel-stroke;
+        border-radius: 3px;
+        color: #FFFFFF;
+        font-family: inherit;
+        font-weight: 700;
+        font-size: 13px;
+        letter-spacing: 0.5px;
+        cursor: pointer;
+        text-shadow: 0 1px 0 rgba(10, 20, 36, 0.50);
+
+        svg { width: 13px; height: 13px; }
+        &:hover { filter: brightness(1.08); }
+        &:disabled { filter: grayscale(0.6) brightness(0.85); cursor: not-allowed; }
+
+        &--cancel {
+            background: linear-gradient(180deg,
+                $pt-cat-cancel-top 0%, $pt-cat-cancel-top 50%,
+                $pt-cat-cancel-bottom 50%, $pt-cat-cancel-bottom 100%);
+            box-shadow: 0 1px 0 $pt-cat-cancel-glow;
+        }
+
+        &--add {
+            background: linear-gradient(180deg,
+                $pt-cat-add-top 0%, $pt-cat-add-top 50%,
+                $pt-cat-add-bottom 50%, $pt-cat-add-bottom 100%);
+            box-shadow: 0 1px 0 $pt-cat-add-glow;
+        }
+    }
+}
