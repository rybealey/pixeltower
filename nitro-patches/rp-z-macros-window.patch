+        padding: 0 8px;
+        background: #FFFFFF;
+        border: 1px solid $pt-macros-text-muted;
+        border-radius: 3px;
+        font-family: 'Ubuntu Mono', Ubuntu, monospace;
+        font-size: 13px;
+        font-weight: normal;
+        color: $pt-macros-cmd-chip-text;
