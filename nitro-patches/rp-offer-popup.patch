+        this._serviceKey = wrapper.readString();
+        this._offererName = wrapper.readString();
+        this._title = wrapper.readString();
+        this._description = wrapper.readString();
+        this._iconResource = wrapper.readString();
+        this._price = wrapper.readInt();
+        this._expirySeconds = wrapper.readInt();
+        return true;
+    }
