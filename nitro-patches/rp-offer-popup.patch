diff --git a/src/components/pixeltower/OfferHUD.scss b/src/components/pixeltower/OfferHUD.scss
new file mode 100644
index 0000000..6555070
--- /dev/null
+++ b/src/components/pixeltower/OfferHUD.scss
@@ -0,0 +1,137 @@
+@use './tokens' as *;
+
+// Roleplay service offer popup. Matches .designs/client_ui.pen frame
+// 3P6R0 (Sale Offer Popup) — a single-row compact strip with item icon,
+// "<OFFERER> OFFERS" eyebrow, item-name + coin-price row, and red/green
+// action buttons. Slides in below the Player HUD.
+
+.pixeltower-offer-popup {
+    position: absolute;
+    top: 152px;
+    left: 12px;
+    z-index: 1100;
+
+    width: 380px;
+    padding: 10px 12px;
+
+    background: #2B3A54;
+    border: 2px solid $pt-panel-stroke;
+    border-radius: 3px;
+    box-shadow: 0 3px 6px #00000080;
+
+    display: flex;
+    flex-direction: row;
+    align-items: center;
+    gap: 10px;
+
+    color: $pt-text;
+    font-family: $pt-font-family;
+
+    animation: pixeltower-offer-slide-in 280ms ease-out;
+
+    &__item-icon {
+        flex-shrink: 0;
+        width: 20px;
+        height: 20px;
+        color: $pt-coin-yellow;
+    }
+
+    &__text-col {
+        flex: 1 1 0;
+        min-width: 0;
+        display: flex;
+        flex-direction: column;
+        gap: 1px;
+    }
+
+    &__eyebrow {
+        font-size: 10px;
+        font-weight: 700;
+        color: #9FB3CC;
+        letter-spacing: 1.2px;
+        text-transform: uppercase;
+        white-space: nowrap;
+        overflow: hidden;
+        text-overflow: ellipsis;
+    }
+
+    &__main-row {
+        display: flex;
+        flex-direction: row;
+        align-items: center;
+        gap: 5px;
+        white-space: nowrap;
+    }
+
+    &__item-name {
+        font-size: 14px;
+        font-weight: 700;
+        color: #FFFFFF;
+    }
+
+    &__sep {
+        font-size: 14px;
+        font-weight: 700;
+        color: #7A95B8;
+    }
+
+    &__coin-icon {
+        width: 12px;
+        height: 12px;
+        color: $pt-coin-yellow;
+    }
+
+    &__price {
+        font-size: 14px;
+        font-weight: 700;
+        color: $pt-coin-yellow;
+    }
+
+    &__actions {
+        flex-shrink: 0;
+        display: flex;
+        flex-direction: row;
+        align-items: center;
+        gap: 8px;
+    }
+
+    &__btn {
+        width: 28px;
+        height: 28px;
+        border-radius: 3px;
+        border: 2px solid $pt-panel-stroke;
+        padding: 0;
+        cursor: pointer;
+        display: flex;
+        align-items: center;
+        justify-content: center;
+
+        &:hover { filter: brightness(1.1); }
+        &:active { transform: translateY(1px); }
+    }
+
+    &__btn--decline {
+        background: linear-gradient(180deg,
+            #E04848 0%, #E04848 50%,
+            #7A1818 50%, #7A1818 100%);
+        box-shadow: 0 1px 0 #FF9090;
+    }
+
+    &__btn--accept {
+        background: linear-gradient(180deg,
+            #48C66B 0%, #48C66B 50%,
+            #1F6B36 50%, #1F6B36 100%);
+        box-shadow: 0 1px 0 #A0E8B4;
+    }
+
+    &__btn-icon {
+        width: 14px;
+        height: 14px;
+        color: #FFFFFF;
+    }
+}
+
+@keyframes pixeltower-offer-slide-in {
+    from { transform: translateY(-12px); opacity: 0; }
+    to   { transform: translateY(0);     opacity: 1; }
+}
diff --git a/src/components/pixeltower/OfferHUD.tsx b/src/components/pixeltower/OfferHUD.tsx
new file mode 100644
index 0000000..e0563e5
--- /dev/null
+++ b/src/components/pixeltower/OfferHUD.tsx
@@ -0,0 +1,122 @@
+import { FC, useEffect, useState } from 'react';
+import type { IconType } from 'react-icons';
+import { LuCheck, LuCoins, LuHeartPulse, LuPackage, LuX } from 'react-icons/lu';
+import { SendMessageComposer } from '../../api';
+import {
+    RoleplayOfferDismissEvent,
+    RoleplayOfferEvent,
+    RoleplayOfferResponseComposer
+} from '../../api/pixeltower/PixeltowerSoundMessages';
+import { useMessageEvent } from '../../hooks';
+
+type ActiveOffer = {
+    offerId: number;
+    serviceKey: string;
+    offererName: string;
+    title: string;
+    description: string;
+    iconResource: string;
+    price: number;
+    expiresAt: number;
+};
+
+// Lucide icon names that the server may set via OfferService.iconResource().
+// Anything not listed falls back to a package/cube — the design's default.
+const ICON_MAP: Record<string, IconType> = {
+    'package': LuPackage,
+    'heart-pulse': LuHeartPulse
+};
+
+/**
+ * Roleplay service offer popup — slides in below the player HUD when
+ * another player offers a paid service. One offer at a time; replaced
+ * on a new offer, dismissed on accept/reject/15s expiry.
+ *
+ * Layout matches .designs/client_ui.pen frame 3P6R0 (Sale Offer Popup):
+ * single horizontal strip with item icon, "<OFFERER> OFFERS" eyebrow,
+ * item-name + coin-price row, and red/green action buttons.
+ */
+export const OfferHUD: FC<{}> = () =>
+{
+    const [ offer, setOffer ] = useState<ActiveOffer | null>(null);
+
+    useMessageEvent<RoleplayOfferEvent>(RoleplayOfferEvent, event =>
+    {
+        const parser = event.getParser();
+        if(!parser) return;
+        setOffer({
+            offerId: parser.offerId,
+            serviceKey: parser.serviceKey,
+            offererName: parser.offererName,
+            title: parser.title,
+            description: parser.description,
+            iconResource: parser.iconResource,
+            price: parser.price,
+            expiresAt: Date.now() + (parser.expirySeconds * 1000)
+        });
+    });
+
+    useMessageEvent<RoleplayOfferDismissEvent>(RoleplayOfferDismissEvent, event =>
+    {
+        const parser = event.getParser();
+        if(!parser) return;
+        setOffer(prev => (prev && prev.offerId === parser.offerId ? null : prev));
+    });
+
+    useEffect(() =>
+    {
+        if(!offer) return;
+        const remaining = offer.expiresAt - Date.now();
+        if(remaining <= 0)
+        {
+            setOffer(null);
+            return;
+        }
+        const timeoutId = window.setTimeout(
+            () => setOffer(prev => (prev && prev.offerId === offer.offerId ? null : prev)),
+            remaining
+        );
+        return () => window.clearTimeout(timeoutId);
+    }, [ offer ]);
+
+    if(!offer) return null;
+
+    const ItemIcon = ICON_MAP[offer.iconResource] ?? LuPackage;
+
+    const respond = (accepted: boolean) =>
+    {
+        SendMessageComposer(new RoleplayOfferResponseComposer(offer.offerId, accepted));
+        setOffer(null);
+    };
+
+    return (
+        <div className="pixeltower-offer-popup">
+            <ItemIcon className="pixeltower-offer-popup__item-icon" />
+            <div className="pixeltower-offer-popup__text-col">
+                <div className="pixeltower-offer-popup__eyebrow">{ offer.offererName } offers</div>
+                <div className="pixeltower-offer-popup__main-row">
+                    <span className="pixeltower-offer-popup__item-name">{ offer.title }</span>
+                    <span className="pixeltower-offer-popup__sep">·</span>
+                    <LuCoins className="pixeltower-offer-popup__coin-icon" />
+                    <span className="pixeltower-offer-popup__price">{ offer.price.toLocaleString() }</span>
+                </div>
+            </div>
+            <div className="pixeltower-offer-popup__actions">
+                <button
+                    type="button"
+                    className="pixeltower-offer-popup__btn pixeltower-offer-popup__btn--decline"
+                    onClick={ () => respond(false) }
+                    aria-label="Reject">
+                    <LuX className="pixeltower-offer-popup__btn-icon" strokeWidth={ 3 } />
+                </button>
+                <button
+                    type="button"
+                    className="pixeltower-offer-popup__btn pixeltower-offer-popup__btn--accept"
+                    onClick={ () => respond(true) }
+                    aria-label="Accept">
+                    <LuCheck className="pixeltower-offer-popup__btn-icon" strokeWidth={ 3 } />
+                </button>
+            </div>
+        </div>
+    );
+};
