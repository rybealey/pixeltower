index 0000000..70612ac
--- /dev/null
+++ b/src/components/pixeltower/OfferHUD.scss
@@ -0,0 +1,87 @@
+@use './tokens' as *;
+
+// Roleplay service offer popup. Slides in below the Player HUD when a
+// hospital worker (or any future service-corp member) sends `:offer x heal`.
+// Auto-dismisses after 15s, on accept, or on reject.
+
+.pixeltower-offer-popup {
+    position: absolute;
+    // Player HUD is top:12px and ~120px tall — anchor below with a gap.
+    top: 152px;
+    left: 12px;
+    z-index: 1100;
+
+    width: 280px;
+    padding: 8px 10px;
+    color: $pt-text;
+    font-family: $pt-font-family;
+
+    @include pt-panel;
+
+    animation: pixeltower-offer-slide-in 280ms ease-out;
+
+    &__header {
+        display: flex;
+        flex-direction: column;
+        margin-bottom: 6px;
+    }
+
+    &__title {
+        font-weight: 700;
+        font-size: 13px;
+    }
+
+    &__from {
+        font-size: 11px;
+        opacity: 0.85;
+    }
+
+    &__description {
+        font-size: 12px;
+        margin-bottom: 8px;
+    }
+
+    &__price-row {
+        display: flex;
+        align-items: center;
+        gap: 6px;
+        margin-bottom: 8px;
+    }
+
+    &__coin-icon {
+        color: $pt-coin-yellow;
+        font-size: 14px;
+    }
+
+    &__price { font-weight: 700; }
+
+    &__expiry {
+        margin-left: auto;
+        opacity: 0.7;
+        font-size: 11px;
+    }
+
+    &__actions {
+        display: flex;
+        gap: 6px;
+    }
+
+    &__btn {
+        @include pt-chip;
+        flex: 1;
+        padding: 6px 10px;
+        color: $pt-text;
+        font-family: $pt-font-family;
+        font-weight: 700;
+        font-size: 12px;
+        cursor: pointer;
+
+        &:hover { filter: brightness(1.1); }
+        &:active { transform: translateY(1px); }
+    }
+}
+
+@keyframes pixeltower-offer-slide-in {
+    from { transform: translateY(-12px); opacity: 0; }
+    to   { transform: translateY(0);     opacity: 1; }
+}
diff --git a/src/components/pixeltower/OfferHUD.tsx b/src/components/pixeltower/OfferHUD.tsx
new file mode 100644
index 0000000..1ae9807
--- /dev/null
+++ b/src/components/pixeltower/OfferHUD.tsx
@@ -0,0 +1,116 @@
+import { FC, useEffect, useState } from 'react';
+import { LuCoins } from 'react-icons/lu';
+import { SendMessageComposer } from '../../api';
+import {
+    RoleplayOfferDismissEvent,
+    RoleplayOfferEvent,
+    RoleplayOfferResponseComposer
+} from '../../api/pixeltower/PixeltowerSoundMessages';
+import { useMessageEvent } from '../../hooks';
+
+type ActiveOffer = {
+    offerId: number;
+    serviceKey: string;
+    offererName: string;
+    title: string;
+    description: string;
+    iconResource: string;
+    price: number;
+    expiresAt: number;
+};
+
+/**
+ * Listens for roleplay service offers and renders the slide-in popup
+ * below the Player HUD. One offer is shown at a time; arrival of a new
+ * offer replaces the visible one (server side also dismisses the prior).
+ * Auto-dismisses on the client when the expiry timestamp passes — the
+ * server pushes its own dismiss for hard correctness.
+ */
+export const OfferHUD: FC<{}> = () =>
+{
+    const [ offer, setOffer ] = useState<ActiveOffer | null>(null);
+    const [ now, setNow ] = useState<number>(() => Date.now());
+
+    useMessageEvent<RoleplayOfferEvent>(RoleplayOfferEvent, event =>
+    {
+        const parser = event.getParser();
+        if(!parser) return;
+        setOffer({
+            offerId: parser.offerId,
+            serviceKey: parser.serviceKey,
+            offererName: parser.offererName,
+            title: parser.title,
+            description: parser.description,
+            iconResource: parser.iconResource,
+            price: parser.price,
+            expiresAt: Date.now() + (parser.expirySeconds * 1000)
+        });
+    });
+
+    useMessageEvent<RoleplayOfferDismissEvent>(RoleplayOfferDismissEvent, event =>
+    {
+        const parser = event.getParser();
+        if(!parser) return;
+        setOffer(prev => (prev && prev.offerId === parser.offerId ? null : prev));
+    });
+
+    useEffect(() =>
+    {
+        if(!offer) return;
+        const remaining = offer.expiresAt - Date.now();
+        if(remaining <= 0)
+        {
+            setOffer(null);
+            return;
+        }
+        const timeoutId = window.setTimeout(
+            () => setOffer(prev => (prev && prev.offerId === offer.offerId ? null : prev)),
+            remaining
+        );
+        const tickId = window.setInterval(() => setNow(Date.now()), 1000);
+        return () =>
+        {
+            window.clearTimeout(timeoutId);
+            window.clearInterval(tickId);
+        };
+    }, [ offer ]);
+
+    if(!offer) return null;
+
+    const secondsLeft = Math.max(0, Math.ceil((offer.expiresAt - now) / 1000));
+
+    const respond = (accepted: boolean) =>
+    {
+        SendMessageComposer(new RoleplayOfferResponseComposer(offer.offerId, accepted));
+        setOffer(null);
+    };
+
+    return (
+        <div className="pixeltower-offer-popup">
+            <div className="pixeltower-offer-popup__header">
+                <div className="pixeltower-offer-popup__title">{ offer.title }</div>
+                <div className="pixeltower-offer-popup__from">from { offer.offererName }</div>
+            </div>
+            <div className="pixeltower-offer-popup__description">{ offer.description }</div>
+            <div className="pixeltower-offer-popup__price-row">
+                <LuCoins className="pixeltower-offer-popup__coin-icon" />
+                <span className="pixeltower-offer-popup__price">{ offer.price.toLocaleString() } coins</span>
+                <span className="pixeltower-offer-popup__expiry">{ secondsLeft }s</span>
+            </div>
+            <div className="pixeltower-offer-popup__actions">
+                <button
+                    type="button"
+                    className="pixeltower-offer-popup__btn pixeltower-offer-popup__btn--reject"
+                    onClick={ () => respond(false) }>
+                    Reject
+                </button>
+                <button
+                    type="button"
+                    className="pixeltower-offer-popup__btn pixeltower-offer-popup__btn--accept"
+                    onClick={ () => respond(true) }>
+                    Accept
+                </button>
+            </div>
+        </div>
+    );
+};
