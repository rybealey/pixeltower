+++ b/src/hooks/pixeltower/useStats.ts
@@ -0,0 +1,44 @@
+import { useState } from 'react';
+import { useBetween } from 'use-between';
+import { UpdatePlayerStatsEvent } from '../../api/pixeltower/PixeltowerSoundMessages';
+import { useMessageEvent } from '../events';
+
+export interface PixeltowerStats
+{
+    hp: number;
+    maxHp: number;
+    energy: number;
+    maxEnergy: number;
+    level: number;
+    xp: number;
+    skillPointsUnspent: number;
+    skillHit: number;
+    skillEndurance: number;
+    skillStamina: number;
+}
+
+const useStatsState = () =>
+{
+    const [ stats, setStats ] = useState<PixeltowerStats>(null);
+
+    useMessageEvent<UpdatePlayerStatsEvent>(UpdatePlayerStatsEvent, event =>
+    {
+        const parser = event.getParser();
+        setStats({
+            hp: parser.hp,
+            maxHp: parser.maxHp,
+            energy: parser.energy,
+            maxEnergy: parser.maxEnergy,
+            level: parser.level,
+            xp: parser.xp,
+            skillPointsUnspent: parser.skillPointsUnspent,
+            skillHit: parser.skillHit,
+            skillEndurance: parser.skillEndurance,
+            skillStamina: parser.skillStamina
+        });
+    });
+
+    return { stats };
+}
+
+export const useStats = () => useBetween(useStatsState);
diff --git a/src/hooks/pixeltower/useTarget.ts b/src/hooks/pixeltower/useTarget.ts
new file mode 100644
index 0000000..62148a2
--- /dev/null
+++ b/src/hooks/pixeltower/useTarget.ts
@@ -0,0 +1,44 @@
+import { useState } from 'react';
+import { useBetween } from 'use-between';
+import { UpdateTargetStatsEvent } from '../../api/pixeltower/PixeltowerSoundMessages';
+import { useMessageEvent } from '../events';
+import { PixeltowerStats } from './useStats';
+
+export interface PixeltowerTarget
+{
+    habboId: number;
+    figure: string;
+    userName: string;
+    stats: PixeltowerStats;
+}
+
+const useTargetState = () =>
+{
+    const [ target, setTarget ] = useState<PixeltowerTarget>(null);
+
+    useMessageEvent<UpdateTargetStatsEvent>(UpdateTargetStatsEvent, event =>
+    {
+        const parser = event.getParser();
+        setTarget({
+            habboId: parser.habboId,
+            figure: parser.figure,
+            userName: parser.userName,
+            stats: {
+                hp: parser.hp,
+                maxHp: parser.maxHp,
+                energy: parser.energy,
+                maxEnergy: parser.maxEnergy,
+                level: parser.level,
+                xp: parser.xp,
+                skillPointsUnspent: parser.skillPointsUnspent,
+                skillHit: parser.skillHit,
+                skillEndurance: parser.skillEndurance,
+                skillStamina: parser.skillStamina
+            }
+        });
+    });
+
+    return { target };
+}
+
+export const useTarget = () => useBetween(useTargetState);
