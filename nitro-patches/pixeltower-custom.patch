+import { FC, useState } from 'react';
+import {
+    LuBackpack, LuBuilding2, LuChevronLeft, LuChevronRight,
+    LuKeyboard, LuScroll, LuUsers
+} from 'react-icons/lu';
+
+// Left-edge side drawer for RP-specific actions. Matches
+// .designs/client_ui.pen frame tW1BU: a narrow pull-tab handle that
+// stays flush against the viewport's left edge, and an expandable
+// panel of icon-only action buttons that slides out on click.
+//
+// Click handlers are deliberately no-ops for now — the RP backends
+// (Gangs, Corps, Macros, Wanted) don't yet exist server-side. Swap
+// in CreateLinkEvent(...) calls per-button as those ship.
+
+type DrawerButton = { key: string; label: string; Icon: typeof LuBackpack };
+
+const BUTTONS: DrawerButton[] = [
+    { key: 'inventory', label: 'Inventory', Icon: LuBackpack },
+    { key: 'macros',    label: 'Macros',    Icon: LuKeyboard },
+    { key: 'gangs',     label: 'Gangs',     Icon: LuUsers },
+    { key: 'corps',     label: 'Corps',     Icon: LuBuilding2 },
+    { key: 'wanted',    label: 'Wanted',    Icon: LuScroll },
+];
+
+export const DrawerHUD: FC<{}> = () =>
+{
+    const [ open, setOpen ] = useState(false);
+    const Chev = open ? LuChevronLeft : LuChevronRight;
+
+    return (
+        <div className={ 'pixeltower-drawer-hud' + (open ? ' pixeltower-drawer-hud--open' : '') }>
+            <div className="pixeltower-drawer-hud__panel">
+                { BUTTONS.map(({ key, label, Icon }) => (
+                    <button
+                        key={ key }
+                        type="button"
+                        className="pixeltower-drawer-hud__button"
+                        title={ label }
+                        onClick={ () => { /* placeholder — wire RP actions later */ } }>
+                        <Icon />
+                    </button>
+                )) }
+            </div>
+            <button
+                type="button"
+                className="pixeltower-drawer-hud__handle"
+                title={ open ? 'Collapse' : 'Expand' }
+                onClick={ () => setOpen(o => !o) }>
+                <Chev />
+            </button>
+        </div>
+    );
+}
diff --git a/src/components/pixeltower/PixeltowerLinkListener.tsx b/src/components/pixeltower/PixeltowerLinkListener.tsx
new file mode 100644
index 0000000..ebf363c
--- /dev/null
+++ b/src/components/pixeltower/PixeltowerLinkListener.tsx
@@ -0,0 +1,38 @@
+import { FC } from 'react';
+import { CreateLinkEvent } from '../../api';
+import { OpenClientLinkEvent } from '../../api/pixeltower/PixeltowerSoundMessages';
+import { useMessageEvent } from '../../hooks';
+
+// Allow-list of Nitro link prefixes the rp_functional dispatcher (server
+// header 6503, OpenClientLinkComposer) is permitted to fire via
+// CreateLinkEvent. Defense-in-depth: the source is our own server, but a
+// misconfigured DB row should not be able to open arbitrary surfaces
+// (mod-tools, room-info, etc.). Add new prefixes only after pairing them
+// with a server-side action_type case in FunctionalActionDispatcher.
+const ALLOWED_LINK_PREFIXES = [
+    'avatar-editor/',
+    'navigator/',
+    'catalog/',
+    'wardrobe/',
+    'floor-editor/'
+];
+
+// Headless component — registers a useMessageEvent on mount and renders
+// nothing. Mounted once at the top of MainView so the listener lives for
+// the entire authenticated session.
+export const PixeltowerLinkListener: FC<{}> = () =>
+{
+    useMessageEvent<OpenClientLinkEvent>(OpenClientLinkEvent, event =>
+    {
+        const uri = event.getParser().uri;
+        if(!uri) return;
+        if(!ALLOWED_LINK_PREFIXES.some(prefix => uri.startsWith(prefix)))
+        {
+            console.warn('[PixeltowerRP] OpenClientLink rejected, uri=', uri);
+            return;
+        }
+        CreateLinkEvent(uri);
+    });
+
+    return null;
+};
diff --git a/src/components/pixeltower/StatsHUD.scss b/src/components/pixeltower/StatsHUD.scss
new file mode 100644
index 0000000..5338a6a
--- /dev/null
+++ b/src/components/pixeltower/StatsHUD.scss
@@ -0,0 +1,242 @@
+@use './tokens' as *;
+
+// Player HUD + Target HUD styles.
+// Visual language derived from .designs/client_ui.pen frames HzOI4 (Player)
+// and 1hvgH (Target), scaled from the design's 480px width down to 280px
+// in-game (~58%). Chunky 2D-bevel aesthetic: translucent slate-blue panel,
+// 2px near-navy outline, hard 50/50 gradient bars, tinted 1px underglows.
+
+.pixeltower-stats-hud {
+    position: absolute;
+    top: 12px;
+    left: 12px;
+    // Above Nitro's global `canvas { z-index: 1000 }`.
+    z-index: 1100;
+
+    // Container is transparent per .designs/client_ui.pen frames HzOI4
+    // (Player) and 1hvgH (Target) — no background, border, or blur. The
+    // inner avatar frame and bars carry their own chrome.
+    background: transparent;
+    width: 280px;
+    padding: 6px;
+
+    color: $pt-text;
+    font-family: $pt-font-family;
+    pointer-events: none;
+    user-select: none;
+
+    // Wanted-flag gradient sprite. The <svg> is 0×0 but absolute so
+    // it doesn't reserve an inline line-box at the top of the HUD
+    // (which would otherwise shift the avatar/bars row down ~20px).
+    &__defs {
+        position: absolute;
+        width: 0;
+        height: 0;
+        overflow: hidden;
+        pointer-events: none;
+    }
+
+    &__row {
+        display: flex;
+        flex-direction: row;
+        align-items: stretch;
+        gap: 6px;
+    }
+
+    // ──────────── avatar frame ────────────
+
+    // Avatar wrap — .pen frame HzOI4 > wKu20 specifies a flat dark-navy
+    // fill + matching 2px outside stroke. Earlier gold frame (VIP-like
+    // yellow) was dropped in the updated design.
+    &__avatar {
+        flex-shrink: 0;
