diff --git a/src/components/pixeltower/StatsHUD.scss b/src/components/pixeltower/StatsHUD.scss
new file mode 100644
index 0000000..f9758f5
--- /dev/null
+++ b/src/components/pixeltower/StatsHUD.scss
@@ -0,0 +1,206 @@
+// Player HUD + Target HUD styles.
+// Corner radii, strokes, gradients all derived from .designs/client_ui.pen
+// frames HzOI4 (Player) and 1hvgH (Target), scaled from the design's 480px
+// width down to 280px in-game (≈58%).
+
+.pixeltower-stats-hud {
+    position: absolute;
+    top: 12px;
+    left: 12px;
+    z-index: 3;
+
+    width: 280px;
+    padding: 6px;
+    border-radius: 7px;                            // design 12 × 0.58
+    background: rgba(26, 26, 26, 0.55);
+    backdrop-filter: blur(6px);
+    -webkit-backdrop-filter: blur(6px);
+    box-shadow: 0 3px 0 rgba(0, 0, 0, 0.5);
+
+    color: #fff;
+    font-family: Ubuntu, Inter, sans-serif;
+    pointer-events: none;
+    user-select: none;
+
+    &__row {
+        display: flex;
+        flex-direction: row;
+        align-items: stretch;
+        gap: 6px;
+    }
+
+    // ──────────── avatar frame (gold border, dark-blue inset stroke) ────────────
+
+    &__avatar {
+        flex-shrink: 0;
+        width: 72px;
+        height: 72px;
+        padding: 2px;
+        border-radius: 6px;                        // design 10 × 0.58
+        background: #FFC700;
+        box-shadow: inset 0 0 0 1px #0A1F4A;       // design stroke 1px
+    }
+
+    &__avatar-inner {
+        position: relative;
+        width: 100%;
+        height: 100%;
+        border-radius: 5px;                        // design 8 × 0.58
+        background: #5C6B7A;
+        overflow: hidden;
+        display: flex;
+        flex-direction: column;
+        justify-content: flex-end;
+
+        .avatar-image {
+            position: absolute;
+            top: -30px;
+            left: 50%;
+            transform: translateX(-50%);
+            width: 64px;
+            height: 110px;
+            background-position: center top;
+            background-repeat: no-repeat;
+            image-rendering: pixelated;
+        }
+    }
+
+    &__name {
+        position: relative;
+        padding: 3px 4px;                          // design [6, 8] × 0.58
+        background: rgba(0, 0, 0, 0.6);            // design #00000099
+        text-align: center;
+        font-size: 10px;                           // design 16 × 0.58 ≈ 9
+        font-weight: 900;
+        line-height: 1.1;
+        overflow: hidden;
+        text-overflow: ellipsis;
+        white-space: nowrap;
+    }
+
+    // ──────────── bars column ────────────
+
+    &__bars {
+        display: flex;
+        flex-direction: column;
+        gap: 4px;
+        flex: 1;
+        min-width: 0;
+        justify-content: center;
+    }
+
+    &__bar {
+        position: relative;
+        height: 22px;
+        border: 1px solid rgba(0, 0, 0, 0.25);     // design stroke 1px #00000040
+        border-radius: 5px;                        // design 8 × 0.58
+        overflow: hidden;
+        box-sizing: border-box;
+    }
+
+    &__bar-track {
+        position: absolute;
+        inset: 0;
+    }
+
+    &__bar--hp &__bar-track {
+        background: linear-gradient(180deg, #3a0f0c 0%, #1e0706 100%);
+    }
+
+    &__bar--energy &__bar-track {
+        background: linear-gradient(180deg, #0f2442 0%, #06121f 100%);
+    }
+
+    &__bar-fill {
+        position: absolute;
+        top: 0;
+        left: 0;
+        bottom: 0;
+        transition: width 300ms ease-out;
+        will-change: width;
+
+        &--hp {
+            background: linear-gradient(180deg, #B83227 0%, #7B1A14 100%);
+        }
+        &--energy {
+            background: linear-gradient(180deg, #2E5FA5 0%, #173462 100%);
+        }
+    }
+
+    &__bar-content {
+        position: absolute;
+        inset: 0;
+        display: flex;
+        align-items: center;
+        justify-content: center;
+        gap: 6px;
+        padding: 0 8px;
+        text-shadow: 0 1px 2px rgba(0, 0, 0, 0.7);
+    }
+
+    &__bar-icon {
+        width: 12px;
+        height: 12px;
+        color: #fff;
+        flex-shrink: 0;
+    }
+
+    &__bar-label {
+        font-size: 11px;
+        font-weight: 900;
+        font-variant-numeric: tabular-nums;
+        flex: 1;
+        text-align: center;
+    }
+
+    // ──────────── wanted stars (5 slots, always rendered on Player HUD) ────────────
+
+    &__wanted {
+        display: flex;
+        flex-direction: row;
+        gap: 3px;
+        padding: 0 2px;
+    }
+
+    &__wanted-star {
+        width: 14px;
+        height: 14px;
+        color: #3A3A3A;
+        filter: drop-shadow(0 0 1px #1A1A1A);
+        flex-shrink: 0;
+    }
+
+    &__wanted-star--active {
+        color: #F2B033;
+        filter: drop-shadow(0 0 2px rgba(242, 176, 51, 0.6));
+    }
+
+    // ──────────── Target HUD variant (mirrored layout + lock badge) ────────────
+
+    &--target {
+        left: 300px;                               // 12 (player left) + 280 (player width) + 8 gap
+
+        .pixeltower-stats-hud__row {
+            flex-direction: row-reverse;
+        }
+
+        .pixeltower-stats-hud__bar-content {
+            flex-direction: row-reverse;
+        }
+    }
+
+    &__lock-row {
+        display: flex;
+        flex-direction: row;
+        align-items: center;
+        padding: 2px 4px 0 4px;
+    }
+
+    &__lock-icon {
+        width: 12px;
+        height: 12px;
+        color: #FFC700;
+        filter: drop-shadow(0 0 2px rgba(255, 199, 0, 0.5));
+        flex-shrink: 0;
+    }
+}
