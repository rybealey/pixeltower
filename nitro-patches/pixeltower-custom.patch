@@ -0,0 +1,58 @@
+import { FC } from 'react';
+import { LuHeart, LuLock, LuZap } from 'react-icons/lu';
+import { LayoutAvatarImageView } from '../../common';
+import { useTarget } from '../../hooks';
+
+/**
+ * Mirror-layout HUD showing the currently-targeted player's stats.
+ * Visible only after the first UpdateTargetStatsEvent packet lands
+ * (on profile-card view of another user). Re-renders on every
+ * subsequent packet so switching targets updates in place.
+ *
+ * Matches .designs/client_ui.pen frame 1hvgH, scaled to the same
+ * 280px width as StatsHUD.
+ */
+export const TargetHUD: FC<{}> = () =>
+{
+    const { target = null } = useTarget();
+
+    if(!target) return null;
+
+    const { stats } = target;
+    const hpPct = stats.maxHp > 0 ? Math.max(0, Math.min(100, (stats.hp / stats.maxHp) * 100)) : 0;
+    const energyPct = stats.maxEnergy > 0 ? Math.max(0, Math.min(100, (stats.energy / stats.maxEnergy) * 100)) : 0;
+
+    return (
+        <div className="pixeltower-stats-hud pixeltower-stats-hud--target">
+            <div className="pixeltower-stats-hud__row">
+                <div className="pixeltower-stats-hud__avatar">
+                    <div className="pixeltower-stats-hud__avatar-inner">
+                        <LayoutAvatarImageView figure={ target.figure } direction={ 4 } />
+                        <div className="pixeltower-stats-hud__name">{ target.userName }</div>
+                    </div>
+                </div>
+                <div className="pixeltower-stats-hud__bars">
+                    <div className="pixeltower-stats-hud__bar pixeltower-stats-hud__bar--hp">
+                        <div className="pixeltower-stats-hud__bar-track" />
+                        <div className="pixeltower-stats-hud__bar-fill pixeltower-stats-hud__bar-fill--hp" style={ { width: `${ hpPct }%` } } />
+                        <div className="pixeltower-stats-hud__bar-content">
+                            <LuHeart className="pixeltower-stats-hud__bar-icon" />
+                            <span className="pixeltower-stats-hud__bar-label">{ stats.hp }/{ stats.maxHp }</span>
+                        </div>
+                    </div>
+                    <div className="pixeltower-stats-hud__bar pixeltower-stats-hud__bar--energy">
+                        <div className="pixeltower-stats-hud__bar-track" />
+                        <div className="pixeltower-stats-hud__bar-fill pixeltower-stats-hud__bar-fill--energy" style={ { width: `${ energyPct }%` } } />
+                        <div className="pixeltower-stats-hud__bar-content">
+                            <LuZap className="pixeltower-stats-hud__bar-icon" />
+                            <span className="pixeltower-stats-hud__bar-label">{ stats.energy }/{ stats.maxEnergy }</span>
+                        </div>
+                    </div>
+                    <div className="pixeltower-stats-hud__lock-row">
+                        <LuLock className="pixeltower-stats-hud__lock-icon" />
+                    </div>
+                </div>
+            </div>
+        </div>
+    );
+}
