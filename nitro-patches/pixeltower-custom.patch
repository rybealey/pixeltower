+import { useState } from 'react';
+import { useBetween } from 'use-between';
+import { UpdateTargetStatsEvent } from '../../api/pixeltower/PixeltowerSoundMessages';
+import { useMessageEvent } from '../events';
+import { PixeltowerStats } from './useStats';
+
+export interface PixeltowerTarget
+{
+    habboId: number;
+    figure: string;
+    userName: string;
+    stats: PixeltowerStats;
+}
+
+const useTargetState = () =>
+{
+    const [ target, setTarget ] = useState<PixeltowerTarget>(null);
+
+    useMessageEvent<UpdateTargetStatsEvent>(UpdateTargetStatsEvent, event =>
+    {
+        const parser = event.getParser();
+        setTarget({
+            habboId: parser.habboId,
+            figure: parser.figure,
+            userName: parser.userName,
+            stats: {
+                hp: parser.hp,
+                maxHp: parser.maxHp,
+                energy: parser.energy,
+                maxEnergy: parser.maxEnergy,
+                level: parser.level,
+                xp: parser.xp,
+                skillPointsUnspent: parser.skillPointsUnspent,
+                skillHit: parser.skillHit,
+                skillEndurance: parser.skillEndurance,
+                skillStamina: parser.skillStamina
+            }
+        });
+    });
+
+    return { target };
+}
+
+export const useTarget = () => useBetween(useTargetState);
