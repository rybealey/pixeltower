+
+    &__name {
+        position: relative;
+        padding: 3px 4px;
+        background: $pt-username-badge;
+        text-align: center;
+        font-size: 10px;
+        font-weight: 900;
+        line-height: 1.1;
+        overflow: hidden;
+        text-overflow: ellipsis;
+        white-space: nowrap;
+    }
+
+    // ──────────── bars column ────────────
+
+    &__bars {
+        display: flex;
+        flex-direction: column;
+        gap: 4px;
+        flex: 1;
+        min-width: 0;
+        justify-content: center;
+    }
+
+    &__bar {
+        position: relative;
+        height: 22px;
+        border: 2px solid $pt-panel-stroke;
+        border-radius: 5px;
+        overflow: hidden;
+        box-sizing: border-box;
+    }
+
+    &__bar-track {
+        position: absolute;
+        inset: 0;
+    }
+
+    &__bar--hp {
+        border-color: $pt-hp-stroke;
+        box-shadow: 0 1px 0 $pt-hp-glow;
+
+        .pixeltower-stats-hud__bar-track {
+            background: linear-gradient(180deg,
+                $pt-hp-track-top 0%, $pt-hp-track-top 50%,
+                $pt-hp-track-bottom 50%, $pt-hp-track-bottom 100%);
+        }
+    }
+
+    &__bar--energy {
+        border-color: $pt-energy-stroke;
+        box-shadow: 0 1px 0 $pt-energy-glow;
+
+        .pixeltower-stats-hud__bar-track {
+            background: linear-gradient(180deg,
+                $pt-energy-track-top 0%, $pt-energy-track-top 50%,
+                $pt-energy-track-bottom 50%, $pt-energy-track-bottom 100%);
+        }
+    }
+
+    &__bar-fill {
+        position: absolute;
+        top: 0;
+        left: 0;
+        bottom: 0;
+        transition: width 300ms ease-out;
+        will-change: width;
+
+        &--hp {
+            background: linear-gradient(180deg,
+                $pt-hp-top 0%, $pt-hp-top 50%,
+                $pt-hp-bottom 50%, $pt-hp-bottom 100%);
+        }
+        &--energy {
+            background: linear-gradient(180deg,
+                $pt-energy-top 0%, $pt-energy-top 50%,
+                $pt-energy-bottom 50%, $pt-energy-bottom 100%);
+        }
+    }
+
+    &__bar-content {
+        position: absolute;
+        inset: 0;
+        display: flex;
+        align-items: center;
+        justify-content: center;
+        gap: 6px;
+        padding: 0 8px;
+        text-shadow: 0 1px 2px rgba(0, 0, 0, 0.7);
+    }
+
+    &__bar-icon {
+        width: 12px;
+        height: 12px;
+        color: #fff;
+        flex-shrink: 0;
+    }
+
+    &__bar-label {
+        font-size: 11px;
+        font-weight: 900;
+        font-variant-numeric: tabular-nums;
+        flex: 1;
+        text-align: center;
+    }
+
+    // ──────────── wanted flags (5 slots) ────────────
+
+    &__wanted {
+        display: flex;
+        flex-direction: row;
+        gap: 3px;
+        padding: 0 2px;
+        // Inactive crime level reads as a faded indicator per
+        // .pen frame HzOI4 > VFQ5Z (opacity:0.5). Once the server emits
+        // a non-zero wanted level, the active flags override the haze
+        // via their own brighter drop-shadow filter.
+        opacity: 0.5;
+    }
+
+    // Custom SVG crest (see WantedFlag in StatsHUD.tsx). Fill comes
+    // from the shared gradient defs; this rule just controls render
+    // size + a subtle halo drop-shadow for contrast against rooms.
+    &__wanted-flag {
+        width: 14px;
+        height: 14px;
+        flex-shrink: 0;
+        display: block;
+        overflow: visible;
+        filter: drop-shadow(0 0 1px $pt-panel-stroke);
+    }
+
+    &__wanted-flag--active {
+        filter: drop-shadow(0 0 2px rgba(255, 244, 176, 0.65));
+    }
+
+    // ──────────── Target HUD variant (mirrored layout) ────────────
+
+    &--target {
+        // Sits flush-left of the Player HUD with the inter-HUD gap halved
+        // per the updated .pen layout (frame 1hvgH x:500, was 520).
+        left: 288px;
+
+        .pixeltower-stats-hud__row { flex-direction: row-reverse; }
+        .pixeltower-stats-hud__bar-content { flex-direction: row-reverse; }
+        .pixeltower-stats-hud__name {
+            background: $pt-username-badge-target;
+            padding: 4px 5px;                      // design [6,8] scaled (Player stays [4,8])
+        }
+        // Target HUD has no wanted-flag row (crime level is a self-only
+        // concept). Reserve the space that row would otherwise occupy —
+        // one flag-height (14px) plus the column's inter-item gap (4px) —
+        // so the HP/energy bars center-align identically to the Player HUD.
+        .pixeltower-stats-hud__bars { padding-bottom: 18px; }
+    }
+}
diff --git a/src/components/pixeltower/StatsHUD.tsx b/src/components/pixeltower/StatsHUD.tsx
