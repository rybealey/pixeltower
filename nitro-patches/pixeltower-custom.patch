@@ -0,0 +1,132 @@
+// Top-right Status HUD — matches .designs/client_ui.pen frame KVhc5.
+// Outer shell (padding / cornerRadius) kept identical to Player+Target HUD
+// so the three HUDs read as a set. Top-row buttons scaled up ~10% vs the
+// first scaled pass so the icons / VIP text remain comfortably legible;
+// currency rows mirror the Player HUD bar sizing (11px label, 12px icon,
+// radius 5, 3/6 padding) for rhythm consistency.
+
+.pixeltower-status-hud {
+    position: absolute;
+    top: 12px;
+    right: 12px;
+    z-index: 3;
+
+    width: fit-content;
+    padding: 6px;                                  // matches Player HUD card padding
+    border-radius: 7px;                            // matches Player HUD card radius
+    background: rgba(26, 26, 26, 0.55);
+    backdrop-filter: blur(6px);
+    -webkit-backdrop-filter: blur(6px);
+    box-shadow: 0 3px 0 rgba(0, 0, 0, 0.5);
+
+    display: flex;
+    flex-direction: column;
+    gap: 3px;                                      // tighter than Player HUD's 4 because translucent pills read looser than solid bars
+
+    color: #fff;
+    font-family: Ubuntu, Inter, sans-serif;
+    user-select: none;
+    pointer-events: auto;                          // HUD sits over the room canvas — ensure clicks on buttons still register
+
+    &__top-row {
+        display: flex;
+        flex-direction: row;
+        align-items: center;
+        gap: 3px;
+    }
+
+    // ──────────── VIP chip ────────────
+
+    &__vip-chip {
+        width: 48px;                               // bumped from 36 for readable buttons
+        height: 48px;
+        padding: 6px 8px;
+        border: none;
+        border-radius: 7px;
+        background: rgba(255, 255, 255, 0.065);
+        display: flex;
+        flex-direction: column;
+        align-items: center;
+        justify-content: center;
+        gap: 4px;
+        box-sizing: border-box;
+        cursor: pointer;
+        color: #fff;
+        font-family: inherit;
+        transition: background 150ms ease;
+
+        &:hover { background: rgba(255, 255, 255, 0.12); }
+    }
+
+    &__vip-badge {
+        padding: 2px 5px;
+        border-radius: 3px;
+        background: #FFC700;
+        color: #0A1F4A;
+        font-size: 9px;
+        font-weight: 900;
+        letter-spacing: 0.3px;
+        line-height: 1;
+    }
+
+    &__vip-days {
+        font-size: 11px;
+        font-weight: 900;
+        line-height: 1;
+    }
+
+    // ──────────── icon buttons (chat, settings) ────────────
+
+    &__button {
+        width: 48px;
+        height: 48px;
+        padding: 0;
+        border: none;
+        border-radius: 7px;
+        background: rgba(255, 255, 255, 0.065);
+        display: flex;
+        align-items: center;
+        justify-content: center;
+        color: #fff;
+        cursor: pointer;
+        transition: background 150ms ease;
+
+        svg {
+            width: 18px;
+            height: 18px;
+        }
+
+        &:hover { background: rgba(255, 255, 255, 0.12); }
+    }
+
+    // ──────────── currency rows (coins, diamonds) ────────────
+    // Sized to match Player HUD bars: 22-ish height, radius 5, 3/6 padding,
+    // 12px icon, 11px label. Keeps a consistent visual rhythm top-to-bottom.
+
+    &__row {
+        display: flex;
+        flex-direction: row;
+        align-items: center;
+        gap: 6px;
+        padding: 0 8px;                            // matches Player HUD bar-content padding
+        border-radius: 5px;
+        background: rgba(255, 255, 255, 0.1);      // slightly more opaque so rows read as solid like Player HUD bars
+        box-sizing: border-box;
+        height: 22px;                              // fixed height matches Player HUD bar height exactly
+    }
+
+    &__row-icon {
+        width: 12px;
+        height: 12px;
+        flex-shrink: 0;
+
+        &--coin { color: #FFC700; }
+        &--diamond { color: #3E8FD8; }
+    }
+
+    &__row-value {
+        font-size: 11px;
+        font-weight: 900;
+        font-variant-numeric: tabular-nums;
+    }
+}
