index 0000000..22f6f6a
--- /dev/null
+++ b/src/components/pixeltower/CommandsListView.scss
@@ -0,0 +1,194 @@
+@use './tokens' as *;
+
+// Commands List window — .designs/client_ui.pen frame I2LwC. The outer
+// shell is NitroCardView (theme="primary") so it uses Nitro's native
+// Habbo card chrome including the red close button; the custom red
+// close drawn in the .pen is intentionally disregarded for consistency
+// with every other Habbo dialog in the client.
+
+$pt-cmd-search-top:    #1A2436;
+$pt-cmd-search-bottom: #2B3A54;
+$pt-cmd-search-icon:   #7A95B8;
+$pt-cmd-search-hint:   #9FB3CC;
+
+$pt-cmd-tab-label:         #C4D1E0;
+$pt-cmd-tab-label-active:  #FFFFFF;
+$pt-cmd-tab-underglow:     #9AB4D3;
+
+$pt-cmd-table-bg:              #2B3A54;
+$pt-cmd-table-header-bg:       #1F2C40;
+$pt-cmd-table-header-fg:       #9FB3CC;
+$pt-cmd-table-row-desc:        #C4D1E0;
+$pt-cmd-table-row-param:       #7A95B8;
+$pt-cmd-table-row-placeholder: #FFD028;
+
+.pixeltower-commands-list {
+    width: 560px;
+    max-width: calc(100vw - 24px);
+    color: $pt-text;
+    font-family: $pt-font-family;
+
+    &__body {
+        display: flex;
+        flex-direction: column;
+        gap: 12px;
+        padding: 16px;
+        min-height: 0;
+    }
+
+    &__top-row {
+        display: flex;
+        flex-direction: row;
+        align-items: stretch;
+        gap: 12px;
+    }
+
+    &__search {
+        display: flex;
+        flex: 1 1 auto;
+        align-items: center;
+        gap: 8px;
+        height: 36px;
+        padding: 0 12px;
+        min-width: 0;
+        border: 2px solid $pt-panel-stroke;
+        border-radius: 3px;
+        background: linear-gradient(180deg,
+            $pt-cmd-search-top 0%, $pt-cmd-search-top 50%,
+            $pt-cmd-search-bottom 50%, $pt-cmd-search-bottom 100%);
+        box-shadow: 0 -1px 0 $pt-cmd-tab-underglow;
+    }
+
+    &__search-icon {
+        width: 14px;
+        height: 14px;
+        color: $pt-cmd-search-icon;
+        flex-shrink: 0;
+    }
+
+    &__search-input {
+        flex: 1 1 auto;
+        min-width: 0;
+        background: transparent;
+        border: 0;
+        outline: none;
+        color: $pt-text;
+        font-family: inherit;
+        font-size: 14px;
+        font-weight: 700;
+
+        &::placeholder { color: $pt-cmd-search-hint; }
+    }
+
+    &__tabs {
+        display: flex;
+        flex: 0 0 auto;
+        height: 36px;
+        border: 2px solid $pt-panel-stroke;
+        border-radius: 3px;
+        overflow: hidden;
+        box-shadow: 0 1px 0 $pt-cmd-tab-underglow;
+    }
+
+    &__tab {
+        flex: 0 0 auto;
+        background: linear-gradient(180deg,
+            $pt-chip-top 0%, $pt-chip-top 50%,
+            $pt-chip-bottom 50%, $pt-chip-bottom 100%);
