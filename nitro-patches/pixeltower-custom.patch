--- /dev/null
+++ b/src/components/pixeltower/StatusHUD.tsx
@@ -0,0 +1,120 @@
+import { GetGuestRoomResultEvent } from '@nitrots/nitro-renderer';
+import { FC, useEffect, useState } from 'react';
+import { LuAlarmClock, LuCrown, LuGem, LuMapPin, LuUsers, LuWallet } from 'react-icons/lu';
+import { CreateLinkEvent } from '../../api';
+import { useMessageEvent, usePurse, useRoom } from '../../hooks';
+
+const DIAMOND_CURRENCY_TYPE = 5;
+
+const formatTime = (date: Date): string =>
+    date.toLocaleTimeString([], { hour: 'numeric', minute: '2-digit' });
+
+// Top-right Status HUD — matches .designs/client_ui.pen frame KVhc5.
+//
+// Rows, top → bottom:
+//   1. Room pill       (LuMapPin + current room name)
+//   2. Info row        (time pill, online-users pill)
+//   3. Coin row        (LuWallet + credits, slate chip)
+//   4. Diamond row     (LuGem + activity points) — button: opens Diamonds Window
+//   5. VIP row         (LuCrown + remaining HC days, or "Join VIP" at 0 days)
+//
+// Data sources:
+//   - purse   → usePurse (credits, activity points, HC days)
+//   - room    → GetGuestRoomResultEvent (same pattern as RoomToolsWidgetView)
+//   - time    → local clock, ticked every 30s so a minute rollover is
+//               never more than 30s stale
+//   - online  → AtomCMS /api/online-count, polled every 60s (nginx
+//               routes /api to Laravel)
+
+export const StatusHUD: FC<{}> = () =>
+{
+    const { purse = null } = usePurse();
+    const { roomSession = null } = useRoom();
+    const [ roomName, setRoomName ] = useState<string>('');
+    const [ time, setTime ] = useState<string>(() => formatTime(new Date()));
+    const [ onlineCount, setOnlineCount ] = useState<number | null>(null);
+
+    useMessageEvent<GetGuestRoomResultEvent>(GetGuestRoomResultEvent, event =>
+    {
+        const parser = event.getParser();
+
+        if(!parser.roomEnter) return;
+        if(roomSession && parser.data.roomId !== roomSession.roomId) return;
+        if(roomName !== parser.data.roomName) setRoomName(parser.data.roomName);
+    });
+
+    useEffect(() =>
+    {
+        const id = window.setInterval(() => setTime(formatTime(new Date())), 30_000);
+        return () => window.clearInterval(id);
+    }, []);
+
+    useEffect(() =>
+    {
+        let cancelled = false;
+
+        const fetchCount = async () =>
+        {
+            try
+            {
+                const res = await fetch('/api/online-count', { headers: { Accept: 'application/json' } });
+                if(!res.ok) return;
+                const json = await res.json();
+                // Laravel's JsonResource wraps the payload in a `data` envelope.
+                if(!cancelled && typeof json?.data?.onlineCount === 'number') setOnlineCount(json.data.onlineCount);
+            }
+            catch
+            {
+                // Network blip — keep last-known value.
+            }
+        };
+
+        fetchCount();
+        const id = window.setInterval(fetchCount, 60_000);
+        return () => { cancelled = true; window.clearInterval(id); };
+    }, []);
+
+    if(!purse) return null;
+
+    const totalClubDays = (purse.clubPeriods * 31) + purse.clubDays;
+    const coins = Math.floor(purse.credits);
+    const diamonds = purse.activityPoints?.get(DIAMOND_CURRENCY_TYPE) ?? 0;
+
+    return (
+        <div className="pixeltower-status-hud">
+            <div className="pixeltower-status-hud__room-pill">
+                <LuMapPin className="pixeltower-status-hud__pill-icon" />
+                <span className="pixeltower-status-hud__pill-text">{ roomName || '—' }</span>
+            </div>
+            <div className="pixeltower-status-hud__info-row">
+                <div className="pixeltower-status-hud__info-pill">
+                    <LuAlarmClock className="pixeltower-status-hud__pill-icon" />
+                    <span className="pixeltower-status-hud__pill-text">{ time }</span>
+                </div>
+                <div className="pixeltower-status-hud__info-pill">
+                    <LuUsers className="pixeltower-status-hud__pill-icon" />
+                    <span className="pixeltower-status-hud__pill-text">{ onlineCount !== null ? `${ onlineCount } online` : '— online' }</span>
+                </div>
+            </div>
+            <div className="pixeltower-status-hud__row">
+                <LuWallet className="pixeltower-status-hud__row-icon" />
+                <span className="pixeltower-status-hud__row-value">{ coins }</span>
+            </div>
+            <button
+                type="button"
+                className="pixeltower-status-hud__row-btn"
+                aria-label="Open Diamonds"
+                title="Diamonds"
+                onClick={ () => CreateLinkEvent('diamonds-window/toggle') }>
+                <LuGem className="pixeltower-status-hud__row-icon" />
+                <span className="pixeltower-status-hud__row-value">{ diamonds }</span>
+            </button>
+            <div className="pixeltower-status-hud__row">
+                <LuCrown className="pixeltower-status-hud__row-icon pixeltower-status-hud__row-icon--vip" />
+                <span className="pixeltower-status-hud__row-value">
+                    { totalClubDays === 0 ? 'Join VIP' : `VIP · ${ totalClubDays } d.` }
+                </span>
+            </div>
+        </div>
+    );
+}
