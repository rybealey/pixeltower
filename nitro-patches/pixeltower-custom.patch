+        padding: 0 16px;
+        color: $pt-cmd-tab-label;
+        font-family: inherit;
+        font-size: 14px;
+        font-weight: 700;
+        cursor: pointer;
+        transition: filter 120ms ease;
+
+        &:hover { filter: brightness(1.08); }
+
+        &--active {
+            background: linear-gradient(180deg,
+                $pt-chip-bottom 0%, $pt-chip-bottom 50%,
+                $pt-chip-top 50%, $pt-chip-top 100%);
+            color: $pt-cmd-tab-label-active;
+        }
+    }
+
+    &__tab-divider {
+        width: 2px;
+        background: $pt-panel-stroke;
+        flex-shrink: 0;
+    }
+
+    &__table {
+        display: flex;
+        flex-direction: column;
+        border: 2px solid $pt-panel-stroke;
+        border-radius: 3px;
+        background: $pt-cmd-table-bg;
+        overflow: hidden;
+        min-height: 0;
+    }
+
+    &__table-header {
+        display: flex;
+        gap: 12px;
+        padding: 8px 12px;
+        background: $pt-cmd-table-header-bg;
+        font-size: 12px;
+        font-weight: 700;
+        letter-spacing: 1px;
+        color: $pt-cmd-table-header-fg;
+        text-transform: uppercase;
+    }
+
+    &__table-body {
+        display: flex;
+        flex-direction: column;
+        // Fixed height keeps the dialog the same size across tabs no matter
+        // how many commands a tab has — so switching General (6) → Staff (9)
+        // doesn't resize the window.
+        height: 320px;
+        overflow-y: auto;
+    }
+
+    &__row {
+        display: flex;
+        gap: 12px;
+        padding: 10px 12px;
+        align-items: center;
+        border-bottom: 1px solid $pt-panel-stroke;
+
+        &:last-child { border-bottom: 0; }
+    }
+
+    &__col-command {
+        width: 100px;
+        flex-shrink: 0;
+        font-size: 14px;
+        font-weight: 700;
+        color: $pt-text;
+    }
+
+    &__col-params {
+        width: 150px;
+        flex-shrink: 0;
+        font-size: 14px;
+        color: $pt-cmd-table-row-param;
+
+        &--placeholder { color: $pt-cmd-table-row-placeholder; }
+    }
+
+    &__col-description {
+        flex: 1 1 auto;
+        font-size: 14px;
+        color: $pt-cmd-table-row-desc;
+    }
+
+    &__empty {
+        padding: 24px 12px;
+        text-align: center;
+        color: $pt-cmd-table-row-desc;
+        font-size: 14px;
+    }
+}
diff --git a/src/components/pixeltower/CommandsListView.tsx b/src/components/pixeltower/CommandsListView.tsx
new file mode 100644
index 0000000..fed70a5
--- /dev/null
+++ b/src/components/pixeltower/CommandsListView.tsx
@@ -0,0 +1,199 @@
+import { ILinkEventTracker } from '@nitrots/nitro-renderer';
+import { FC, useEffect, useMemo, useState } from 'react';
+import { LuSearch } from 'react-icons/lu';
+import { AddEventLinkTracker, GetSessionDataManager, RemoveLinkEventTracker } from '../../api';
+import { NitroCardContentView, NitroCardHeaderView, NitroCardView } from '../../common';
+import { useEmployment, usePurse } from '../../hooks';
+
+// Reference window for every chat command the server + client expose.
+// Opens via `:commands` (see useChatInputWidget.ts).
+//
+// Tabs + their contents are gated per the viewer's status:
+//   - General → visible to everyone (stats/target/combat basics)
+//   - Banking → visible to everyone (distinct cluster — 6 commands)
+//   - Job     → only employed users (useEmployment — server signal TBD,
+//               stub currently returns isEmployed:false). Corp-management
+//               commands live here too; they require corp-rank perms
+//               server-side, but you're always employed if you have them.
+//   - VIP     → only users with active HC (usePurse → totalClubDays > 0)
+//   - Staff   → only moderators (GetSessionDataManager().isModerator)
+//
+// Hidden tabs aren't rendered at all, so a regular player never sees
+// evidence of commands they can't run.
+
+type Category = 'general' | 'banking' | 'job' | 'vip' | 'staff';
+
+interface CommandDef {
+    name: string;
+    params?: string;
+    description: string;
+    category: Category;
+    /** When true, the params cell renders in the yellow placeholder style. */
+    paramsPlaceholder?: boolean;
+}
+
+const COMMANDS: CommandDef[] = [
+    // General — action + info for any walking player
+    { name: 'target',       params: '%user%',                   paramsPlaceholder: true, description: 'Target a player to view their stats',              category: 'general' },
+    { name: 'stats',        description: 'Show your own stats',                                                                                           category: 'general' },
+    { name: 'hit',          params: '%user%',                   paramsPlaceholder: true, description: 'Swing at a player (combat rules apply)',           category: 'general' },
+    { name: 'respawn',      description: 'Leave the downed state and return to the hospital',                                                             category: 'general' },
+    { name: 'ct',           description: 'Toggle click-through: suppress avatar menus, walk past players when clicked',                                   category: 'general' },
+    { name: 'dance',        params: '%1-4%',                    paramsPlaceholder: true, description: 'Start a dance (1=Dance, 2=Pogo Mogo, 3=Duck Funk, 4=The Rollie); no number toggles the standard Dance', category: 'general' },
+    { name: 'wd',           description: 'Open Change Your Look (alias :wardrobe)',                                                                       category: 'general' },
+    { name: 'suicide',      description: 'End your life immediately',                                                                                     category: 'general' },
+    { name: 'commands',     description: 'Open this reference window',                                                                                    category: 'general' },
+    // Banking — lifecycle order: open → inspect → move → peer-to-peer
+    { name: 'openaccount',  description: 'Open a personal bank account',                                                                                  category: 'banking' },
+    { name: 'bal',          description: 'Check your bank balance',                                                                                       category: 'banking' },
+    { name: 'deposit',      params: '%amount%',                 paramsPlaceholder: true, description: 'Deposit coins at an ATM',                          category: 'banking' },
+    { name: 'withdraw',     params: '%amount%',                 paramsPlaceholder: true, description: 'Withdraw coins at an ATM',                         category: 'banking' },
+    { name: 'transfer',     params: '%user% %amount%',          paramsPlaceholder: true, description: 'Wire coins from your bank to another player',      category: 'banking' },
+    { name: 'give',         params: '%user% %amount%',          paramsPlaceholder: true, description: 'Hand coins to a player in the same room',          category: 'banking' },
+    // Job — self-shift first, then corp management (requires corp-rank perms)
+    { name: 'startwork',    description: 'Start a shift at your corp',                                                                                    category: 'job' },
+    { name: 'stopwork',     description: 'End your current shift',                                                                                        category: 'job' },
+    { name: 'hire',         params: '%user% %rank%',            paramsPlaceholder: true, description: 'Add a player to your corp (requires CAN_HIRE)',    category: 'job' },
+    { name: 'fire',         params: '%user%',                   paramsPlaceholder: true, description: 'Remove a player from your corp (requires CAN_FIRE)', category: 'job' },
+    { name: 'promote',      params: '%user% %rank%',            paramsPlaceholder: true, description: "Change a corp member's rank (requires CAN_PROMOTE)", category: 'job' },
+    // Staff — economy → stats → combat → rooms
+    { name: 'award',        params: '%user% %currency% %amount%', paramsPlaceholder: true, description: "Credit or debit a player's coins or bank",      category: 'staff' },
+    { name: 'restore',      params: '%user%',                   paramsPlaceholder: true, description: "Restore a player's HP and energy to max",          category: 'staff' },
+    { name: 'sethealth',    params: '%user% %value%',           paramsPlaceholder: true, description: "Set a player's HP",                                category: 'staff' },
+    { name: 'setenergy',    params: '%user% %value%',           paramsPlaceholder: true, description: "Set a player's energy",                            category: 'staff' },
+    { name: 'kill',         params: '%user%',                   paramsPlaceholder: true, description: 'Instantly KO a player',                            category: 'staff' },
+    { name: 'setzone',      params: '%mode%',                   paramsPlaceholder: true, description: 'Toggle PvP for the current room (safe | unsafe)',  category: 'staff' },
+    { name: 'fighttest',    params: '%user% %damage%',          paramsPlaceholder: true, description: 'Drive the damage pipeline (dev)',                  category: 'staff' },
+    { name: 'roomsettings', description: 'Open room settings for the current room',                                                                       category: 'staff' },
+    { name: 'floorplan',    description: 'Open the floor plan editor',                                                                                    category: 'staff' }
+];
+
+const TAB_LABEL: Record<Category, string> = {
+    general: 'General',
+    banking: 'Banking',
+    job:     'Job',
+    vip:     'VIP',
+    staff:   'Staff'
+};
+
+export const CommandsListView: FC<{}> = () =>
+{
+    const [ isVisible, setIsVisible ] = useState(false);
+    const [ activeTab, setActiveTab ] = useState<Category>('general');
+    const [ query, setQuery ] = useState<string>('');
+
+    const { purse = null } = usePurse();
+    const { isEmployed } = useEmployment();
+    const isModerator = GetSessionDataManager().isModerator;
+    const totalClubDays = purse ? (purse.clubPeriods * 31) + purse.clubDays : 0;
+    const isVip = totalClubDays > 0;
+
+    const visibleTabs = useMemo<Category[]>(() =>
+    {
+        const tabs: Category[] = [ 'general', 'banking' ];
+        if(isEmployed) tabs.push('job');
+        if(isVip) tabs.push('vip');
+        if(isModerator) tabs.push('staff');
+        return tabs;
+    }, [ isEmployed, isVip, isModerator ]);
+
+    // If the active tab becomes hidden (e.g. HC expired while the
+    // window was open), fall back to General so the body doesn't render
+    // a tab the user no longer has access to.
+    useEffect(() =>
+    {
+        if(!visibleTabs.includes(activeTab)) setActiveTab('general');
+    }, [ visibleTabs, activeTab ]);
+
+    useEffect(() =>
+    {
+        const linkTracker: ILinkEventTracker = {
+            linkReceived: (url: string) =>
+            {
+                const parts = url.split('/');
+                if(parts.length < 2) return;
+                switch(parts[1])
+                {
+                    case 'show':   setIsVisible(true); return;
+                    case 'hide':   setIsVisible(false); return;
+                    case 'toggle': setIsVisible(v => !v); return;
+                }
+            },
+            eventUrlPrefix: 'commands-list/'
+        };
+        AddEventLinkTracker(linkTracker);
+        return () => RemoveLinkEventTracker(linkTracker);
+    }, []);
+
+    const filtered = useMemo(() =>
+    {
+        const q = query.trim().toLowerCase();
+        return COMMANDS.filter(c =>
+        {
+            if(c.category !== activeTab) return false;
+            if(!q) return true;
+            return c.name.toLowerCase().includes(q) || c.description.toLowerCase().includes(q);
+        });
+    }, [ activeTab, query ]);
+
+    if(!isVisible) return null;
+
+    return (
+        <NitroCardView uniqueKey="pixeltower-commands" theme="primary" classNames={ [ 'pixeltower-commands-list' ] }>
+            <NitroCardHeaderView headerText="Commands List" onCloseClick={ () => setIsVisible(false) } />
+            <NitroCardContentView classNames={ [ 'pixeltower-commands-list__body' ] } overflow="hidden">
+                <div className="pixeltower-commands-list__top-row">
+                    <label className="pixeltower-commands-list__search">
+                        <LuSearch className="pixeltower-commands-list__search-icon" />
+                        <input
+                            type="text"
+                            className="pixeltower-commands-list__search-input"
+                            placeholder="Search commands…"
+                            value={ query }
+                            onChange={ e => setQuery(e.target.value) } />
+                    </label>
+                    <div className="pixeltower-commands-list__tabs">
+                        { visibleTabs.flatMap((tab, i) =>
+                        {
+                            const btn = (
+                                <button
+                                    key={ tab }
+                                    type="button"
+                                    className={ 'pixeltower-commands-list__tab' + (tab === activeTab ? ' pixeltower-commands-list__tab--active' : '') }
+                                    onClick={ () => setActiveTab(tab) }>
+                                    { TAB_LABEL[tab] }
+                                </button>
+                            );
+                            return i === 0
+                                ? [ btn ]
+                                : [ <div key={ `${ tab }-div` } className="pixeltower-commands-list__tab-divider" />, btn ];
+                        }) }
+                    </div>
+                </div>
+                <div className="pixeltower-commands-list__table">
+                    <div className="pixeltower-commands-list__table-header">
+                        <span className="pixeltower-commands-list__col-command">Command</span>
+                        <span className="pixeltower-commands-list__col-params">Parameters</span>
+                        <span className="pixeltower-commands-list__col-description">Description</span>
+                    </div>
+                    <div className="pixeltower-commands-list__table-body">
+                        { filtered.length === 0
+                            ? <div className="pixeltower-commands-list__empty">
+                                { activeTab === 'vip' ? 'No VIP commands yet.' : 'No commands match your search.' }
+                            </div>
+                            : filtered.map(cmd => (
+                                <div key={ cmd.name } className="pixeltower-commands-list__row">
+                                    <span className="pixeltower-commands-list__col-command">{ cmd.name }</span>
+                                    <span className={ 'pixeltower-commands-list__col-params' + (cmd.paramsPlaceholder ? ' pixeltower-commands-list__col-params--placeholder' : '') }>
+                                        { cmd.params ?? 'N/A' }
+                                    </span>
+                                    <span className="pixeltower-commands-list__col-description">{ cmd.description }</span>
+                                </div>
+                            ))
+                        }
+                    </div>
+                </div>
+            </NitroCardContentView>
+        </NitroCardView>
+    );
+}
diff --git a/src/components/pixeltower/DrawerHUD.scss b/src/components/pixeltower/DrawerHUD.scss
