@@ -0,0 +1,69 @@
+import { FC } from 'react';
+import { LuHeart, LuStar, LuZap } from 'react-icons/lu';
+import { GetSessionDataManager } from '../../api';
+import { LayoutAvatarImageView } from '../../common';
+import { useSessionInfo, useStats } from '../../hooks';
+
+const WANTED_SLOT_COUNT = 5;
+
+/**
+ * Persistent top-left Player HUD. Matches the canonical design at
+ * .designs/client_ui.pen frame HzOI4, at a scaled-down size for the
+ * in-game context. Data comes live from UpdatePlayerStatsEvent via the
+ * useStats hook — HP/energy bars deplete in real time. Wanted-slot
+ * indicators are always visible (grey when unwanted).
+ */
+export const StatsHUD: FC<{}> = () =>
+{
+    const { stats = null } = useStats();
+    const { userFigure = null } = useSessionInfo();
+
+    if(!stats) return null;
+
+    const userName = GetSessionDataManager()?.userName ?? '';
+    const hpPct = stats.maxHp > 0 ? Math.max(0, Math.min(100, (stats.hp / stats.maxHp) * 100)) : 0;
+    const energyPct = stats.maxEnergy > 0 ? Math.max(0, Math.min(100, (stats.energy / stats.maxEnergy) * 100)) : 0;
+
+    // Wanted / crime-stars: always render the five slots. The server
+    // doesn't yet emit a wanted level (Tier 4 bounty work) — slots stay
+    // inactive for now.
+    const wantedLevel = 0;
+
+    return (
+        <div className="pixeltower-stats-hud">
+            <div className="pixeltower-stats-hud__row">
+                <div className="pixeltower-stats-hud__avatar">
+                    <div className="pixeltower-stats-hud__avatar-inner">
+                        <LayoutAvatarImageView figure={ userFigure } direction={ 2 } />
+                        <div className="pixeltower-stats-hud__name">{ userName }</div>
+                    </div>
+                </div>
+                <div className="pixeltower-stats-hud__bars">
+                    <div className="pixeltower-stats-hud__bar pixeltower-stats-hud__bar--hp">
+                        <div className="pixeltower-stats-hud__bar-track" />
+                        <div className="pixeltower-stats-hud__bar-fill pixeltower-stats-hud__bar-fill--hp" style={ { width: `${ hpPct }%` } } />
+                        <div className="pixeltower-stats-hud__bar-content">
+                            <LuHeart className="pixeltower-stats-hud__bar-icon" />
+                            <span className="pixeltower-stats-hud__bar-label">{ stats.hp }/{ stats.maxHp }</span>
+                        </div>
+                    </div>
+                    <div className="pixeltower-stats-hud__bar pixeltower-stats-hud__bar--energy">
+                        <div className="pixeltower-stats-hud__bar-track" />
+                        <div className="pixeltower-stats-hud__bar-fill pixeltower-stats-hud__bar-fill--energy" style={ { width: `${ energyPct }%` } } />
+                        <div className="pixeltower-stats-hud__bar-content">
+                            <LuZap className="pixeltower-stats-hud__bar-icon" />
+                            <span className="pixeltower-stats-hud__bar-label">{ stats.energy }/{ stats.maxEnergy }</span>
+                        </div>
+                    </div>
+                    <div className="pixeltower-stats-hud__wanted">
+                        { Array.from({ length: WANTED_SLOT_COUNT }).map((_, i) => (
+                            <LuStar
+                                key={ i }
+                                className={ 'pixeltower-stats-hud__wanted-star' + (i < wantedLevel ? ' pixeltower-stats-hud__wanted-star--active' : '') } />
+                        )) }
+                    </div>
+                </div>
+            </div>
+        </div>
+    );
+}
