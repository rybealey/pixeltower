+
+    &__cost-rate {
+        font-size: 12px;
+        color: #7A95B8;
+    }
+
+    &__cost-value {
+        display: flex;
+        align-items: center;
+        gap: 6px;
+        font-size: 24px;
+        font-weight: 900;
+    }
+
+    &__cost-usd {
+        font-size: 12px;
+        font-weight: 900;
+        letter-spacing: 1px;
+        color: #9FB3CC;
+    }
+
+    // ──────────── footer ────────────
+
+    &__footer {
+        display: flex;
+        gap: 8px;
+        padding: 12px 16px;
+        background: #2B3A54;
+        border-top: 2px solid $pt-panel-stroke;
+        box-shadow: 0 1px 0 #9AB4D3;
+    }
+
+    &__btn {
+        @include pt-chip;
+        flex: 1;
+        padding: 10px 14px;
+        font-size: 14px;
