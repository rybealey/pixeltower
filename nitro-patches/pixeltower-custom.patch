+@use './tokens' as *;
+
+// Top-right Status HUD — matches .designs/client_ui.pen frame KVhc5.
+// Chip bevel gradient on every interactive surface, 2px near-navy outline,
+// and the shared panel mixin on the outer shell so the three HUDs read
+// as a set. Chip/row dimensions bumped ~20% over the first pass for
+// in-game legibility.
+
+.pixeltower-status-hud {
+    position: absolute;
+    top: 12px;
+    right: 12px;
+    z-index: 3;
+
+    @include pt-panel;
+    width: fit-content;
+    padding: 7px;
+
+    display: flex;
+    flex-direction: column;
+    gap: 4px;
+
+    color: $pt-text;
+    font-family: Inter, Ubuntu, sans-serif;
+    user-select: none;
+    pointer-events: auto;
+
+    &__top-row {
+        display: flex;
+        flex-direction: row;
+        align-items: center;
+        gap: 4px;
+    }
+
+    // ──────────── VIP chip ────────────
+
+    &__vip-chip {
+        @include pt-chip;
+        width: 56px;
+        height: 56px;
+        padding: 7px 9px;
+        display: flex;
+        flex-direction: column;
+        align-items: center;
+        justify-content: center;
+        gap: 5px;
+        box-sizing: border-box;
+        cursor: pointer;
+        color: $pt-text;
+        font-family: inherit;
+        transition: filter 150ms ease;
+
+        &:hover { filter: brightness(1.12); }
+    }
+
+    &__vip-badge {
+        padding: 3px 6px;
+        border-radius: 3px;
+        background: linear-gradient(180deg,
+            $pt-vip-top 0%, $pt-vip-top 50%,
+            $pt-vip-bottom 50%, $pt-vip-bottom 100%);
+        color: $pt-vip-text;
+        border: 2px solid $pt-panel-stroke;
+        box-shadow: 0 1px 0 $pt-vip-glow;
+        font-size: 10px;
+        font-weight: 900;
+        letter-spacing: 0.5px;
+        line-height: 1;
+    }
+
+    &__vip-days {
+        font-size: 12px;
+        font-weight: 900;
+        line-height: 1;
+    }
+
+    // ──────────── icon buttons (chat, settings) ────────────
+
+    &__button {
+        @include pt-chip;
+        width: 56px;
+        height: 56px;
+        padding: 0;
+        display: flex;
+        align-items: center;
+        justify-content: center;
+        color: $pt-text;
+        cursor: pointer;
+        transition: filter 150ms ease;
+
+        svg {
+            width: 22px;
+            height: 22px;
+        }
+
+        &:hover { filter: brightness(1.12); }
+    }
+
+    // ──────────── currency rows (coins, diamonds) ────────────
+
+    &__row {
+        @include pt-chip;
+        display: flex;
+        flex-direction: row;
+        align-items: center;
+        gap: 7px;
+        padding: 0 10px;
+        box-sizing: border-box;
+        height: 26px;
+    }
+
+    &__row-icon {
+        width: 14px;
+        height: 14px;
+        flex-shrink: 0;
+        color: $pt-text;
+    }
+
+    &__row-value {
+        font-size: 13px;
+        font-weight: 900;
+        font-variant-numeric: tabular-nums;
+    }
+}
