@@ -0,0 +1,44 @@
+import { useState } from 'react';
+import { useBetween } from 'use-between';
+import { UpdatePlayerStatsEvent } from '../../api/pixeltower/PixeltowerSoundMessages';
+import { useMessageEvent } from '../events';
+
+export interface PixeltowerStats
+{
+    hp: number;
+    maxHp: number;
+    energy: number;
+    maxEnergy: number;
+    level: number;
+    xp: number;
+    skillPointsUnspent: number;
+    skillHit: number;
+    skillEndurance: number;
+    skillStamina: number;
+}
+
+const useStatsState = () =>
+{
+    const [ stats, setStats ] = useState<PixeltowerStats>(null);
+
+    useMessageEvent<UpdatePlayerStatsEvent>(UpdatePlayerStatsEvent, event =>
+    {
+        const parser = event.getParser();
+        setStats({
+            hp: parser.hp,
+            maxHp: parser.maxHp,
+            energy: parser.energy,
+            maxEnergy: parser.maxEnergy,
+            level: parser.level,
+            xp: parser.xp,
+            skillPointsUnspent: parser.skillPointsUnspent,
+            skillHit: parser.skillHit,
+            skillEndurance: parser.skillEndurance,
+            skillStamina: parser.skillStamina
+        });
+    });
+
+    return { stats };
+}
+
+export const useStats = () => useBetween(useStatsState);
