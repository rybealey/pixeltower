+@use './tokens' as *;
+
+// Diamonds Window — matches .designs/client_ui.pen frame 9Ax4A.
+// Outer chrome is NitroCardView (theme="primary") so it inherits the native
+// Habbo card frame, draggable header, and red X close button — same chrome
+// every other dialog uses (Commands List, Friends, Navigator, etc.). The
+// `_app-overrides.scss` rules restyle the header into the slate chip
+// gradient, so the design language matches without per-window CSS.
+
+.pixeltower-diamonds-window {
+    width: 440px;
+    max-width: calc(100vw - 24px);
+    color: $pt-text;
+    font-family: $pt-font-family;
+
+    &__body {
+        display: flex;
+        flex-direction: column;
+        gap: 12px;
+        padding: 16px;
+    }
+
+    &__section-label {
+        font-size: 12px;
+        font-weight: 700;
+        letter-spacing: 1px;
+        color: #9FB3CC;
+    }
+
+    &__uses {
+        display: flex;
+        flex-direction: column;
+        background: #2B3A54;
+        border: 2px solid $pt-panel-stroke;
+        border-radius: 3px;
+    }
+
+    &__use {
+        display: flex;
+        align-items: center;
+        gap: 12px;
+        padding: 10px 12px;
+        font-size: 14px;
+        color: #C4D1E0;
+
+        svg { width: 18px; height: 18px; flex-shrink: 0; color: #7DD3FC; }
+        &--vip svg { color: #FFD028; }
+    }
+
+    &__amount {
+        display: flex;
+        flex-direction: column;
+        gap: 8px;
+    }
+
+    &__input-row {
+        display: flex;
+        align-items: center;
+        gap: 8px;
+    }
+
+    &__step {
+        @include pt-chip;
+        width: 44px;
+        height: 44px;
+        display: flex;
+        align-items: center;
+        justify-content: center;
+        cursor: pointer;
+        color: $pt-text;
+        box-shadow: 0 1px 0 #9AB4D3;
+
+        svg { width: 20px; height: 20px; }
