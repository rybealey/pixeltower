diff --git a/src/components/pixeltower/DrawerHUD.scss b/src/components/pixeltower/DrawerHUD.scss
new file mode 100644
index 0000000..30fd451
--- /dev/null
+++ b/src/components/pixeltower/DrawerHUD.scss
@@ -0,0 +1,98 @@
+@use './tokens' as *;
+
+// Left-edge collapsible drawer — matches .designs/client_ui.pen frame
+// tW1BU. Scaled down from the design's 56x56 buttons / 22x44 handle to
+// 40x40 / 17x34 for in-game rhythm alongside the other HUDs.
+// Anchored flush to the left edge via cornerRadius [0, n, n, 0].
+
+.pixeltower-drawer-hud {
+    position: absolute;
+    top: 50%;
+    left: 0;
+    transform: translateY(-50%);
+    z-index: 3;
+
+    display: flex;
+    flex-direction: row;
+    align-items: center;
+    pointer-events: none;                           // wrapper passthrough; children opt back in
+
+    &__panel {
+        @include pt-panel;
+        border-top-left-radius: 0;                  // flush against viewport left edge
+        border-bottom-left-radius: 0;
+
+        display: flex;
+        flex-direction: column;
+        gap: 6px;
+        padding: 6px;
+
+        max-width: 0;
+        padding-left: 0;
+        padding-right: 0;
+        border-left-width: 0;
+        overflow: hidden;
+        opacity: 0;
+        transition:
+            max-width 220ms ease-out,
+            padding 220ms ease-out,
+            border-left-width 220ms ease-out,
+            opacity 180ms ease-out;
+        pointer-events: auto;
+    }
+
+    &--open &__panel {
+        max-width: 58px;                            // 40 button + 2x6 padding + stroke
+        padding-left: 6px;
+        padding-right: 6px;
+        border-left-width: 0;                       // keep flush left
+        opacity: 1;
+    }
+
+    &__button {
+        @include pt-chip;
+        width: 40px;
+        height: 40px;
+        padding: 0;
+        display: flex;
+        align-items: center;
+        justify-content: center;
+        color: $pt-text;
+        cursor: pointer;
+        font-family: inherit;
+        transition: filter 150ms ease;
+
+        svg { width: 17px; height: 17px; }
+
+        &:hover { filter: brightness(1.12); }
+    }
+
+    &__handle {
+        // Panel treatment but drop-shadow only — no periwinkle rim-light
+        // (per design: the handle reads slightly flatter than the drawer).
+        background: $pt-panel-fill;
+        border: 2px solid $pt-panel-stroke;
+        border-radius: 5px;
+        border-top-left-radius: 0;
+        border-bottom-left-radius: 0;
+        border-left-width: 0;
+        backdrop-filter: blur($pt-panel-blur);
+        -webkit-backdrop-filter: blur($pt-panel-blur);
+        box-shadow: 0 2px 0 $pt-panel-shadow-drop;
+
+        width: 17px;
+        height: 34px;
+        padding: 0;
+        display: flex;
+        align-items: center;
+        justify-content: center;
+        color: $pt-text;
+        cursor: pointer;
+        pointer-events: auto;
+        transition: filter 150ms ease;
+
+        svg { width: 12px; height: 12px; }
+
+        &:hover { filter: brightness(1.12); }
+    }
+}
diff --git a/src/components/pixeltower/DrawerHUD.tsx b/src/components/pixeltower/DrawerHUD.tsx
new file mode 100644
index 0000000..7a6d30c
--- /dev/null
+++ b/src/components/pixeltower/DrawerHUD.tsx
@@ -0,0 +1,54 @@
+import { FC, useState } from 'react';
+import {
+    LuBackpack, LuBuilding2, LuChevronLeft, LuChevronRight,
+    LuKeyboard, LuScroll, LuUsers
+} from 'react-icons/lu';
+
+// Left-edge side drawer for RP-specific actions. Matches
+// .designs/client_ui.pen frame tW1BU: a narrow pull-tab handle that
+// stays flush against the viewport's left edge, and an expandable
+// panel of icon-only action buttons that slides out on click.
+//
+// Click handlers are deliberately no-ops for now — the RP backends
+// (Gangs, Corps, Macros, Wanted) don't yet exist server-side. Swap
+// in CreateLinkEvent(...) calls per-button as those ship.
+
+type DrawerButton = { key: string; label: string; Icon: typeof LuBackpack };
+
+const BUTTONS: DrawerButton[] = [
+    { key: 'inventory', label: 'Inventory', Icon: LuBackpack },
+    { key: 'macros',    label: 'Macros',    Icon: LuKeyboard },
+    { key: 'gangs',     label: 'Gangs',     Icon: LuUsers },
+    { key: 'corps',     label: 'Corps',     Icon: LuBuilding2 },
+    { key: 'wanted',    label: 'Wanted',    Icon: LuScroll },
+];
+
+export const DrawerHUD: FC<{}> = () =>
+{
+    const [ open, setOpen ] = useState(false);
+    const Chev = open ? LuChevronLeft : LuChevronRight;
+
+    return (
+        <div className={ 'pixeltower-drawer-hud' + (open ? ' pixeltower-drawer-hud--open' : '') }>
+            <div className="pixeltower-drawer-hud__panel">
+                { BUTTONS.map(({ key, label, Icon }) => (
+                    <button
+                        key={ key }
+                        type="button"
+                        className="pixeltower-drawer-hud__button"
+                        title={ label }
+                        onClick={ () => { /* placeholder — wire RP actions later */ } }>
+                        <Icon />
+                    </button>
+                )) }
+            </div>
+            <button
+                type="button"
+                className="pixeltower-drawer-hud__handle"
+                title={ open ? 'Collapse' : 'Expand' }
+                onClick={ () => setOpen(o => !o) }>
+                <Chev />
+            </button>
+        </div>
+    );
+}
diff --git a/src/components/pixeltower/StatsHUD.scss b/src/components/pixeltower/StatsHUD.scss
new file mode 100644
index 0000000..7d40ac2
--- /dev/null
+++ b/src/components/pixeltower/StatsHUD.scss
@@ -0,0 +1,210 @@
+@use './tokens' as *;
+
+// Player HUD + Target HUD styles.
+// Visual language derived from .designs/client_ui.pen frames HzOI4 (Player)
+// and 1hvgH (Target), scaled from the design's 480px width down to 280px
+// in-game (~58%). Chunky 2D-bevel aesthetic: translucent slate-blue panel,
+// 2px near-navy outline, hard 50/50 gradient bars, tinted 1px underglows.
+
+.pixeltower-stats-hud {
+    position: absolute;
+    top: 12px;
+    left: 12px;
+    z-index: 3;
+
+    @include pt-panel;
+    width: 280px;
+    padding: 6px;
+
+    color: $pt-text;
+    font-family: Inter, Ubuntu, sans-serif;
+    pointer-events: none;
+    user-select: none;
+
+    &__row {
+        display: flex;
+        flex-direction: row;
+        align-items: stretch;
+        gap: 6px;
+    }
+
+    // ──────────── avatar frame ────────────
+
+    &__avatar {
+        flex-shrink: 0;
+        width: 72px;
+        height: 72px;
+        padding: 2px;
+        border-radius: 5px;
+        background: $pt-avatar-frame;
+        border: 2px solid $pt-panel-stroke;
+        filter: drop-shadow(0 1px 0 rgba(255, 244, 176, 0.85));
+    }
+
+    &__avatar-inner {
+        position: relative;
+        width: 100%;
+        height: 100%;
+        border-radius: 3px;
+        background: linear-gradient(180deg,
+            $pt-avatar-inner-top 0%, $pt-avatar-inner-top 50%,
+            $pt-avatar-inner-bottom 50%, $pt-avatar-inner-bottom 100%);
+        overflow: hidden;
+        display: flex;
+        flex-direction: column;
+        justify-content: flex-end;
+
+        .avatar-image {
+            position: absolute;
+            top: -30px;
+            left: 50%;
+            transform: translateX(-50%);
+            width: 64px;
+            height: 110px;
+            background-position: center top;
+            background-repeat: no-repeat;
+            image-rendering: pixelated;
+        }
+    }
+
+    &__name {
+        position: relative;
+        padding: 3px 4px;
+        background: $pt-username-badge;
+        text-align: center;
+        font-size: 10px;
+        font-weight: 900;
+        line-height: 1.1;
+        overflow: hidden;
+        text-overflow: ellipsis;
+        white-space: nowrap;
+    }
+
+    // ──────────── bars column ────────────
+
+    &__bars {
+        display: flex;
+        flex-direction: column;
+        gap: 4px;
+        flex: 1;
+        min-width: 0;
+        justify-content: center;
+    }
+
+    &__bar {
+        position: relative;
+        height: 22px;
+        border: 2px solid $pt-panel-stroke;
+        border-radius: 5px;
+        overflow: hidden;
+        box-sizing: border-box;
+    }
+
+    &__bar-track {
+        position: absolute;
+        inset: 0;
+    }
+
+    &__bar--hp {
+        border-color: $pt-hp-stroke;
+        box-shadow: 0 1px 0 $pt-hp-glow;
+
+        .pixeltower-stats-hud__bar-track {
+            background: linear-gradient(180deg,
+                $pt-hp-track-top 0%, $pt-hp-track-top 50%,
+                $pt-hp-track-bottom 50%, $pt-hp-track-bottom 100%);
+        }
+    }
+
+    &__bar--energy {
+        border-color: $pt-energy-stroke;
+        box-shadow: 0 1px 0 $pt-energy-glow;
+
+        .pixeltower-stats-hud__bar-track {
+            background: linear-gradient(180deg,
+                $pt-energy-track-top 0%, $pt-energy-track-top 50%,
+                $pt-energy-track-bottom 50%, $pt-energy-track-bottom 100%);
+        }
+    }
+
+    &__bar-fill {
+        position: absolute;
+        top: 0;
+        left: 0;
+        bottom: 0;
+        transition: width 300ms ease-out;
+        will-change: width;
+
+        &--hp {
+            background: linear-gradient(180deg,
+                $pt-hp-top 0%, $pt-hp-top 50%,
+                $pt-hp-bottom 50%, $pt-hp-bottom 100%);
+        }
+        &--energy {
+            background: linear-gradient(180deg,
+                $pt-energy-top 0%, $pt-energy-top 50%,
+                $pt-energy-bottom 50%, $pt-energy-bottom 100%);
+        }
+    }
+
+    &__bar-content {
+        position: absolute;
+        inset: 0;
+        display: flex;
+        align-items: center;
+        justify-content: center;
+        gap: 6px;
+        padding: 0 8px;
+        text-shadow: 0 1px 2px rgba(0, 0, 0, 0.7);
+    }
+
+    &__bar-icon {
+        width: 12px;
+        height: 12px;
+        color: #fff;
+        flex-shrink: 0;
+    }
+
