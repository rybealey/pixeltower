diff --git a/src/components/pixeltower/_app-overrides.scss b/src/components/pixeltower/_app-overrides.scss
new file mode 100644
index 0000000..2c6ae63
--- /dev/null
+++ b/src/components/pixeltower/_app-overrides.scss
@@ -0,0 +1,72 @@
+@use './tokens' as *;
+
+// Nitro's Bootstrap fork sets $body-bg: $black (see
+// assets/styles/bootstrap/_variables.scss), and upstream relied on
+// HotelView painting a full-viewport background over that black until
+// a room loaded. Pixeltower removes HotelView (users are pinned to a
+// room on login), so the black body shows through whenever the PIXI
+// canvas hasn't painted room pixels yet — both on first mount and for
+// a few frames during every room swap. Paint a slate-blue fallback
+// that matches the HUD panel language so those gap frames feel
+// intentional instead of looking like a crash.
+
+:root {
+    --bs-body-bg: #{$pt-panel-stroke};
+}
+
+body {
+    background: linear-gradient(180deg, #1a2436 0%, $pt-panel-stroke 100%);
+}
+
+// LoadingView.scss paints $primary teal over the body — drop that so the
+// slate-blue body gradient shows through and the preloader matches the
+// room-swap fallback.
+.nitro-loading {
+    background: transparent;
+}
+
+// Standard Nitro card windows (Friends, Navigator, alert popups, etc.)
+// ship with a flat $primary teal header (#1E7295) for theme-primary and
+// a tertiary/quaternary teal gradient for theme-primary-slim — both
+// clash with the pixeltower HUD's slate-blue chip language. Restyle
+// both header variants with the same hard 50/50 bevel + panel stroke
+// every HUD chip uses so dialog windows read as the same family as the
+// toolbar. Close button stays upstream red on purpose.
+.nitro-card.theme-primary .nitro-card-header,
+.nitro-card.theme-primary-slim .nitro-card-header {
+    background: linear-gradient(180deg,
+        $pt-chip-top 0%, $pt-chip-top 50%,
+        $pt-chip-bottom 50%, $pt-chip-bottom 100%);
+    border-bottom: 2px solid $pt-panel-stroke;
+}
+
+// Drop the slim variant's white underline (box-shadow) and inner-top
+// white highlight (:before) — both are baked bevels that fight the
+// flat 2D chip gradient.
+.nitro-card.theme-primary-slim .nitro-card-header {
+    box-shadow: none;
+}
+
+.nitro-card.theme-primary-slim .nitro-card-header:before {
+    display: none;
+}
+
+// NitroCardContentView renders `.content-area` (see common/card/
+// NitroCardContentView.tsx) and NitroCardView.scss paints it $light
+// (#DFDFDF) by default — that's the gray every primary dialog body
+// shows. Repaint it slate so every pixeltower dialog (Diamonds,
+// Commands List, future windows) reads as the same family as the
+// toolbar/HUD chrome instead of a stock Bootstrap card.
+.nitro-card.theme-primary .content-area,
+.nitro-card.theme-primary-slim .content-area {
+    background: #3E4E6E;
+}
+
+// Hide the floating name-tag pill above avatars (own user, friends,
+// anyone else) — AvatarInfoWidgetNameView always applies `.name-only`
+// on the ContextMenuView, so this selector catches every variant.
+// The click-to-open avatar info card is a different rendering path
+// and stays untouched.
+.nitro-context-menu.name-only {
+    display: none;
+}
diff --git a/src/components/pixeltower/_tokens.scss b/src/components/pixeltower/_tokens.scss
new file mode 100644
index 0000000..1bc5a1d
--- /dev/null
+++ b/src/components/pixeltower/_tokens.scss
@@ -0,0 +1,87 @@
+// Shared design tokens + mixins for pixeltower HUDs.
+// Palette extracted from .designs/client_ui.pen — all four HUD frames
+// (Player HzOI4, Target 1hvgH, Status KVhc5, Drawer tW1BU) share the same
+// chunky 2D-bevel language: translucent slate-blue panel + 2px near-navy
+// outline + hard 50/50 two-tone gradient on interactive chips.
+
+// ──────────── panel (outer translucent shell) ────────────
+$pt-panel-fill:        rgba(62, 78, 110, 0.50);   // #3E4E6E80
+$pt-panel-stroke:      #0A1424;
+$pt-panel-shadow-drop: rgba(0, 0, 0, 0.44);
+$pt-panel-shadow-rim:  #7A95B8;
+$pt-panel-blur:        8px;
+
+// ──────────── chip / button / row (inner bevel) ────────────
+$pt-chip-top:    #5E7FA3;
+$pt-chip-bottom: #2B3A54;
+
+// ──────────── HP bar ────────────
+$pt-hp-top:     #F04848;
+$pt-hp-bottom:  #8E1414;
+$pt-hp-stroke:  #2A0404;
+$pt-hp-glow:    #FFB0B0;
+$pt-hp-track-top:    #3a0f0c;
+$pt-hp-track-bottom: #1e0706;
+
+// ──────────── Energy bar ────────────
+$pt-energy-top:     #4E85E0;
+$pt-energy-bottom:  #143972;
+$pt-energy-stroke:  #050F22;
+$pt-energy-glow:    #A8C4EE;
+$pt-energy-track-top:    #0f2442;
+$pt-energy-track-bottom: #06121f;
+
+// ──────────── Avatar ────────────
+$pt-avatar-frame:      #FFD028;
+$pt-avatar-frame-glow: #FFF4B0;
+$pt-avatar-inner-top:    #6D7E90;
+$pt-avatar-inner-bottom: #495565;
+
+// ──────────── Wanted stars ────────────
+$pt-wanted-inactive:   #374151;
+$pt-wanted-active:     #FFD028;
+$pt-wanted-active-glow: #FFF4B0;
+
+// ──────────── Badges / accents ────────────
+// Username badge — translucent slate to match .pen frames HzOI4 > ONOMa
+// (#0A142499, ~60% alpha). Avatar art shows through, room canvas does not.
+$pt-username-badge:        rgba(10, 20, 36, 0.60);
+$pt-username-badge-target: rgba(0, 0, 0, 0.60);   // #00000099
+$pt-vip-top:      #FFE066;                        // VIP badge gradient top half
+$pt-vip-bottom:   #D99A00;                        // VIP badge gradient bottom half
+$pt-vip-glow:     #FFF8C8;                        // VIP badge 1px underglow
+$pt-vip-text:     #2A1A00;                        // dark warm brown on yellow bevel
+$pt-coin-yellow:  #FFC700;
+$pt-diamond-blue: #3E8FD8;
+
+$pt-text:       #FFFFFF;
+
+// Ubuntu is loaded via nitro/src/assets/styles/fonts.scss from
+// Ubuntu-C.ttf — the Condensed variant. Use this token across every
+// pixeltower HUD so the .pen designs (which reference system fonts
+// like Inter) always render in Ubuntu Condensed in-game.
+$pt-font-family: Ubuntu, sans-serif;
+
+// ──────────── mixins ────────────
+
+// Translucent slate-blue shell with 2px outline, blur, stacked drop+rim shadow.
+@mixin pt-panel {
+    background: $pt-panel-fill;
+    border: 2px solid $pt-panel-stroke;
+    border-radius: 7px;
+    backdrop-filter: blur($pt-panel-blur);
+    -webkit-backdrop-filter: blur($pt-panel-blur);
+    box-shadow:
+        0 3px 0 $pt-panel-shadow-drop,
+        0 2px 0 $pt-panel-shadow-rim;
+}
+
+// Hard 50/50 two-tone bevel gradient with 2px outline — used on every
+// button, row, and inner chip across all four HUDs.
+@mixin pt-chip {
+    background: linear-gradient(180deg,
+        $pt-chip-top 0%, $pt-chip-top 50%,
+        $pt-chip-bottom 50%, $pt-chip-bottom 100%);
+    border: 2px solid $pt-panel-stroke;
+    border-radius: 5px;
+}
