diff --git a/src/api/pixeltower/PixeltowerSoundMessages.ts b/src/api/pixeltower/PixeltowerSoundMessages.ts
new file mode 100644
index 0000000..f7d681f
--- /dev/null
+++ b/src/api/pixeltower/PixeltowerSoundMessages.ts
@@ -0,0 +1,290 @@
+import { IMessageComposer, IMessageConfiguration, IMessageDataWrapper, IMessageEvent, IMessageParser, MessageEvent } from '@nitrots/nitro-renderer';
+import { GetConnection } from '../nitro/GetConnection';
+
+const PIXELTOWER_PLAY_SOUND = 6500;
+const PIXELTOWER_UPDATE_PLAYER_STATS = 6501;
+const PIXELTOWER_UPDATE_TARGET_STATS = 6502;
+const PIXELTOWER_OPEN_CLIENT_LINK = 6503;
+const PIXELTOWER_SET_TARGET = 6550;
+
+// ──────────── PlaySound (header 6500) ────────────
+
+export class NitroPlaySoundParser implements IMessageParser
+{
+    private _sample: string;
+
+    public flush(): boolean
+    {
+        this._sample = null;
+        return true;
+    }
+
+    public parse(wrapper: IMessageDataWrapper): boolean
+    {
+        if(!wrapper) return false;
+        this._sample = wrapper.readString();
+        return true;
+    }
+
+    public get sample(): string
+    {
+        return this._sample;
+    }
+}
+
+export class NitroPlaySoundEvent extends MessageEvent implements IMessageEvent
+{
+    constructor(callBack: Function)
+    {
+        super(callBack, NitroPlaySoundParser);
+    }
+
+    public getParser(): NitroPlaySoundParser
+    {
+        return this.parser as NitroPlaySoundParser;
+    }
+}
+
+// ──────────── UpdatePlayerStats (header 6501) ────────────
+
+export class UpdatePlayerStatsParser implements IMessageParser
+{
+    private _hp: number;
+    private _maxHp: number;
+    private _energy: number;
+    private _maxEnergy: number;
+    private _level: number;
+    private _xp: number;
+    private _skillPointsUnspent: number;
+    private _skillHit: number;
+    private _skillEndurance: number;
+    private _skillStamina: number;
+
+    public flush(): boolean
+    {
+        this._hp = 0;
+        this._maxHp = 0;
+        this._energy = 0;
+        this._maxEnergy = 0;
+        this._level = 0;
+        this._xp = 0;
+        this._skillPointsUnspent = 0;
+        this._skillHit = 0;
+        this._skillEndurance = 0;
+        this._skillStamina = 0;
+        return true;
+    }
+
+    public parse(wrapper: IMessageDataWrapper): boolean
+    {
+        if(!wrapper) return false;
+        this._hp = wrapper.readInt();
+        this._maxHp = wrapper.readInt();
+        this._energy = wrapper.readInt();
+        this._maxEnergy = wrapper.readInt();
+        this._level = wrapper.readInt();
+        this._xp = wrapper.readInt();
+        this._skillPointsUnspent = wrapper.readInt();
+        this._skillHit = wrapper.readInt();
+        this._skillEndurance = wrapper.readInt();
+        this._skillStamina = wrapper.readInt();
+        return true;
+    }
+
+    public get hp(): number { return this._hp; }
+    public get maxHp(): number { return this._maxHp; }
+    public get energy(): number { return this._energy; }
+    public get maxEnergy(): number { return this._maxEnergy; }
+    public get level(): number { return this._level; }
+    public get xp(): number { return this._xp; }
+    public get skillPointsUnspent(): number { return this._skillPointsUnspent; }
+    public get skillHit(): number { return this._skillHit; }
+    public get skillEndurance(): number { return this._skillEndurance; }
+    public get skillStamina(): number { return this._skillStamina; }
+}
+
+export class UpdatePlayerStatsEvent extends MessageEvent implements IMessageEvent
+{
+    constructor(callBack: Function)
+    {
+        super(callBack, UpdatePlayerStatsParser);
+    }
+
+    public getParser(): UpdatePlayerStatsParser
+    {
+        return this.parser as UpdatePlayerStatsParser;
+    }
+}
+
+// ──────────── UpdateTargetStats (header 6502) ────────────
+
+export class UpdateTargetStatsParser implements IMessageParser
+{
+    private _habboId: number;
+    private _figure: string;
+    private _userName: string;
+    private _hp: number;
+    private _maxHp: number;
+    private _energy: number;
+    private _maxEnergy: number;
+    private _level: number;
+    private _xp: number;
+    private _skillPointsUnspent: number;
+    private _skillHit: number;
+    private _skillEndurance: number;
+    private _skillStamina: number;
+
+    public flush(): boolean
+    {
+        this._habboId = 0;
+        this._figure = '';
+        this._userName = '';
+        this._hp = 0;
+        this._maxHp = 0;
+        this._energy = 0;
+        this._maxEnergy = 0;
+        this._level = 0;
+        this._xp = 0;
+        this._skillPointsUnspent = 0;
+        this._skillHit = 0;
+        this._skillEndurance = 0;
+        this._skillStamina = 0;
+        return true;
+    }
+
+    public parse(wrapper: IMessageDataWrapper): boolean
+    {
+        if(!wrapper) return false;
+        this._habboId = wrapper.readInt();
+        this._figure = wrapper.readString();
+        this._userName = wrapper.readString();
+        this._hp = wrapper.readInt();
+        this._maxHp = wrapper.readInt();
+        this._energy = wrapper.readInt();
+        this._maxEnergy = wrapper.readInt();
+        this._level = wrapper.readInt();
+        this._xp = wrapper.readInt();
+        this._skillPointsUnspent = wrapper.readInt();
+        this._skillHit = wrapper.readInt();
+        this._skillEndurance = wrapper.readInt();
+        this._skillStamina = wrapper.readInt();
+        return true;
+    }
+
+    public get habboId(): number { return this._habboId; }
+    public get figure(): string { return this._figure; }
+    public get userName(): string { return this._userName; }
+    public get hp(): number { return this._hp; }
+    public get maxHp(): number { return this._maxHp; }
+    public get energy(): number { return this._energy; }
+    public get maxEnergy(): number { return this._maxEnergy; }
+    public get level(): number { return this._level; }
+    public get xp(): number { return this._xp; }
+    public get skillPointsUnspent(): number { return this._skillPointsUnspent; }
+    public get skillHit(): number { return this._skillHit; }
+    public get skillEndurance(): number { return this._skillEndurance; }
+    public get skillStamina(): number { return this._skillStamina; }
+}
+
+export class UpdateTargetStatsEvent extends MessageEvent implements IMessageEvent
+{
+    constructor(callBack: Function)
+    {
+        super(callBack, UpdateTargetStatsParser);
+    }
+
+    public getParser(): UpdateTargetStatsParser
+    {
+        return this.parser as UpdateTargetStatsParser;
+    }
+}
+
+// ──────────── OpenClientLink (header 6503) ────────────
+//
+// Generic "open Nitro UI X" composer. Body is a single string consumed by
+// PixeltowerLinkListener via CreateLinkEvent(uri). Sent server-side from the
+// rp_functional furniture dispatcher; allow-listed by prefix on the client
+// to keep misconfigured DB rows from opening arbitrary surfaces.
+
+export class OpenClientLinkParser implements IMessageParser
+{
+    private _uri: string;
+
+    public flush(): boolean
+    {
+        this._uri = null;
+        return true;
+    }
+
+    public parse(wrapper: IMessageDataWrapper): boolean
+    {
+        if(!wrapper) return false;
+        this._uri = wrapper.readString();
+        return true;
+    }
+
+    public get uri(): string
+    {
+        return this._uri;
+    }
+}
+
+export class OpenClientLinkEvent extends MessageEvent implements IMessageEvent
+{
+    constructor(callBack: Function)
+    {
+        super(callBack, OpenClientLinkParser);
+    }
+
+    public getParser(): OpenClientLinkParser
+    {
+        return this.parser as OpenClientLinkParser;
+    }
+}
+
+// ──────────── SetTarget (header 6550, client→server) ────────────
+//
+// Emitted from the room InfoStand whenever the local player selects
+// another user's avatar sprite. The Arcturus-side handler fires
+// UserTargetSelectedEvent, which PixeltowerRP consumes to set the
+// target cache and push UpdateTargetStats back to this client.
+
+export class PixeltowerSetTargetComposer implements IMessageComposer<ConstructorParameters<typeof PixeltowerSetTargetComposer>>
+{
+    private _data: ConstructorParameters<typeof PixeltowerSetTargetComposer>;
+
+    constructor(targetHabboId: number)
+    {
+        this._data = [ targetHabboId ];
+    }
+
+    public getMessageArray()
+    {
+        return this._data;
+    }
+
+    public dispose(): void
+    {
+        return;
+    }
+}
+
+// ──────────── registration ────────────
+
+class PixeltowerMessages implements IMessageConfiguration
+{
+    public events: Map<number, Function> = new Map<number, Function>([
+        [ PIXELTOWER_PLAY_SOUND, NitroPlaySoundEvent ],
+        [ PIXELTOWER_UPDATE_PLAYER_STATS, UpdatePlayerStatsEvent ],
+        [ PIXELTOWER_UPDATE_TARGET_STATS, UpdateTargetStatsEvent ],
+        [ PIXELTOWER_OPEN_CLIENT_LINK, OpenClientLinkEvent ]
+    ]);
+    public composers: Map<number, Function> = new Map<number, Function>([
+        [ PIXELTOWER_SET_TARGET, PixeltowerSetTargetComposer ]
+    ]);
+}
+
+export function registerPixeltowerMessages(): void
+{
+    GetConnection()?.registerMessages(new PixeltowerMessages());
+}
