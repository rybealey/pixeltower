+@use './tokens' as *;
+
+// Top-right Status HUD — matches .designs/client_ui.pen frame KVhc5.
+// The HUD absorbs the former InfoPillsHUD (room / time / online pills)
+// into its top rows; chat-history + user-settings buttons moved to
+// the ToolbarHUD. The outer container is transparent per the updated
+// design — each pill/row carries its own chrome.
+
+.pixeltower-status-hud {
+    position: absolute;
+    top: 12px;
+    right: 12px;
+    // Above Nitro's global `canvas { z-index: 1000 }`.
+    z-index: 1100;
+
+    // Full-scale layout reads as too heavy in the top-right corner;
+    // scale the whole HUD down ~17.5% from its anchor so it sits as an
+    // accent next to the StatsHUD rather than dominating the screen.
+    transform: scale(0.825);
+    transform-origin: top right;
+
+    display: flex;
+    flex-direction: column;
+    align-items: flex-end;
+    width: fit-content;
+    gap: 8px;
+
+    background: transparent;
+    color: $pt-text;
+    font-family: $pt-font-family;
+    pointer-events: auto;
+    user-select: none;
+
+    // ──────────── info pills (room / time / online) ────────────
+
+    &__room-pill {
+        @include pt-panel;
+        border-radius: 3px;
+        padding: 6px 12px;
+        gap: 6px;
+        display: flex;
+        flex-direction: row;
+        align-items: center;
+        align-self: stretch;
+        white-space: nowrap;
+    }
+
+    &__info-row {
+        display: flex;
+        flex-direction: row;
+        gap: 8px;
+    }
+
+    &__info-pill {
+        @include pt-panel;
+        border-radius: 3px;
+        padding: 6px 12px;
+        gap: 6px;
+        display: flex;
+        flex-direction: row;
+        align-items: center;
+        white-space: nowrap;
+    }
+
+    &__pill-icon {
+        width: 16px;
+        height: 16px;
+        flex-shrink: 0;
+        color: $pt-text;
+    }
+
+    &__pill-text {
+        font-size: 15px;
+        font-weight: 700;
+        line-height: 1;
+        font-variant-numeric: tabular-nums;
+    }
+
+    // ──────────── currency + VIP rows ────────────
+    // Coin, diamond, and VIP rows share the same pt-panel shell as the
+    // info pills above — the only VIP-specific treatment is a yellow
+    // crown icon to flag subscription status.
+
+    &__row {
+        @include pt-panel;
+        border-radius: 3px;
+        display: flex;
+        flex-direction: row;
+        align-items: center;
+        gap: 6px;
+        padding: 6px 12px;
+        box-sizing: border-box;
+        align-self: stretch;
+    }
+
+    // Button variant — same panel chrome, plus interactive affordances.
+    // Used by the diamond row (opens Diamonds Window) and the VIP row in
+    // its "Join VIP" zero-day state.
+    &__row-btn {
+        @extend .pixeltower-status-hud__row;
+        font-family: inherit;
+        color: inherit;
+        cursor: pointer;
+        transition: filter 120ms ease, background-color 120ms ease, transform 60ms ease;
+
+        &:hover {
+            filter: brightness(1.15);
+            background: rgba(94, 127, 163, 0.55);   // tinted lift on the slate panel
+        }
+
+        &:active {
+            transform: translateY(1px);
+            filter: brightness(0.95);
+        }
+
+        &:focus-visible {
+            outline: 2px solid $pt-text;
+            outline-offset: 2px;
+        }
+    }
+
+    &__row-icon {
+        width: 16px;
+        height: 16px;
+        flex-shrink: 0;
+        color: $pt-text;
+    }
+
+    &__row-icon--vip {
+        color: #FFD028;
+    }
+
+    &__row-value {
+        font-size: 15px;
+        font-weight: 700;
+        line-height: 1;
+        font-variant-numeric: tabular-nums;
+    }
+}
diff --git a/src/components/pixeltower/StatusHUD.tsx b/src/components/pixeltower/StatusHUD.tsx
