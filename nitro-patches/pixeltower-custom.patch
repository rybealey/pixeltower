diff --git a/src/components/pixeltower/DiamondsWindow.tsx b/src/components/pixeltower/DiamondsWindow.tsx
new file mode 100644
index 0000000..0000000
--- /dev/null
+++ b/src/components/pixeltower/DiamondsWindow.tsx
@@ -0,0 +1,137 @@
+import { ILinkEventTracker } from '@nitrots/nitro-renderer';
+import { FC, useEffect, useState } from 'react';
+import { LuArrowRightLeft, LuCrown, LuGem, LuMinus, LuPlus, LuShirt, LuShoppingCart, LuStar } from 'react-icons/lu';
+import { AddEventLinkTracker, RemoveLinkEventTracker } from '../../api';
+import { NitroCardContentView, NitroCardHeaderView, NitroCardView } from '../../common';
+
+// Diamonds Window — matches .designs/client_ui.pen frame 9Ax4A.
+// Triggered from the Status HUD diamond row via
+// CreateLinkEvent('diamonds-window/show|hide|toggle'). Uses the native
+// Nitro card chrome (draggable header, red X close button) for parity
+// with every other in-game dialog.
+
+const PRESETS = [ 100, 500, 1000, 5000, 10000 ];
+// Pricing: 1 diamond = $0.01 (1 cent). 100 diamonds = $1.00.
+const RATE_USD_PER_DIAMOND = 0.01;
+
+const formatUSD = (value: number): string =>
+    `$${ value.toFixed(2) }`;
+
+const formatNumber = (value: number): string =>
+    value.toLocaleString('en-US');
+
+export const DiamondsWindow: FC<{}> = () =>
+{
+    const [ isVisible, setIsVisible ] = useState(false);
+    const [ amount, setAmount ] = useState<number>(5000);
+
+    useEffect(() =>
+    {
+        const linkTracker: ILinkEventTracker = {
+            linkReceived: (url: string) =>
+            {
+                const parts = url.split('/');
+                if(parts.length < 2) return;
+                switch(parts[1])
+                {
+                    case 'show':   setIsVisible(true); return;
+                    case 'hide':   setIsVisible(false); return;
+                    case 'toggle': setIsVisible(v => !v); return;
+                }
+            },
+            eventUrlPrefix: 'diamonds-window/'
+        };
+        AddEventLinkTracker(linkTracker);
+        return () => RemoveLinkEventTracker(linkTracker);
+    }, []);
+
+    if(!isVisible) return null;
+
+    const close = () => setIsVisible(false);
+    const cost  = amount * RATE_USD_PER_DIAMOND;
+
+    return (
+        <NitroCardView uniqueKey="pixeltower-diamonds" theme="primary" classNames={ [ 'pixeltower-diamonds-window' ] }>
+            <NitroCardHeaderView headerText="Diamonds" onCloseClick={ close } />
+            <NitroCardContentView classNames={ [ 'pixeltower-diamonds-window__content' ] } overflow="hidden">
+                <div className="pixeltower-diamonds-window__body">
+                    <div>
+                        <div className="pixeltower-diamonds-window__section-label">WHAT CAN YOU DO WITH DIAMONDS?</div>
+                        <div className="pixeltower-diamonds-window__uses" style={ { marginTop: 8 } }>
+                            <div className="pixeltower-diamonds-window__use">
+                                <LuShirt />
+                                <span>Exclusive avatar clothing and accessories</span>
+                            </div>
+                            <div className="pixeltower-diamonds-window__use">
+                                <LuStar />
+                                <span>Unique features that enhance gameplay</span>
+                            </div>
+                            <div className="pixeltower-diamonds-window__use">
+                                <LuArrowRightLeft />
+                                <span>Trade or transfer to other players</span>
+                            </div>
+                            <div className="pixeltower-diamonds-window__use pixeltower-diamonds-window__use--vip">
+                                <LuCrown />
+                                <span>Unlock VIP perks and priority access</span>
+                            </div>
+                        </div>
+                    </div>
+                    <div className="pixeltower-diamonds-window__amount">
+                        <div className="pixeltower-diamonds-window__section-label">AMOUNT</div>
+                        <div className="pixeltower-diamonds-window__input-row">
+                            <button
+                                type="button"
+                                className="pixeltower-diamonds-window__step"
+                                aria-label="Decrease"
+                                disabled={ amount <= PRESETS[0] }
+                                onClick={ () => setAmount(a => Math.max(PRESETS[0], a - PRESETS[0])) }>
+                                <LuMinus />
+                            </button>
+                            <div className="pixeltower-diamonds-window__input">
+                                <LuGem />
+                                <span>{ formatNumber(amount) }</span>
+                            </div>
+                            <button
+                                type="button"
+                                className="pixeltower-diamonds-window__step"
+                                aria-label="Increase"
+                                onClick={ () => setAmount(a => a + PRESETS[0]) }>
+                                <LuPlus />
+                            </button>
+                        </div>
+                        <div className="pixeltower-diamonds-window__chips">
+                            { PRESETS.map(preset => (
+                                <button
+                                    key={ preset }
+                                    type="button"
+                                    className={ 'pixeltower-diamonds-window__chip' + (preset === amount ? ' pixeltower-diamonds-window__chip--active' : '') }
+                                    onClick={ () => setAmount(preset) }>
+                                    { formatNumber(preset) }
+                                </button>
+                            )) }
+                        </div>
+                    </div>
+                    <div className="pixeltower-diamonds-window__cost">
+                        <div>
+                            <div className="pixeltower-diamonds-window__cost-label">ESTIMATED COST</div>
+                            <div className="pixeltower-diamonds-window__cost-rate">1 diamond = $0.01</div>
+                        </div>
+                        <div className="pixeltower-diamonds-window__cost-value">
+                            <span>{ formatUSD(cost) }</span>
+                            <span className="pixeltower-diamonds-window__cost-usd">USD</span>
+                        </div>
+                    </div>
+                </div>
+                <div className="pixeltower-diamonds-window__footer">
+                    <button type="button" className="pixeltower-diamonds-window__btn" onClick={ close }>
+                        Cancel
+                    </button>
+                    <button type="button" className="pixeltower-diamonds-window__btn pixeltower-diamonds-window__btn--buy">
+                        <LuShoppingCart />
+                        <span>Buy { formatNumber(amount) } Diamonds</span>
+                    </button>
+                </div>
+            </NitroCardContentView>
+        </NitroCardView>
+    );
+}
diff --git a/src/components/pixeltower/TargetHUD.tsx b/src/components/pixeltower/TargetHUD.tsx
new file mode 100644
index 0000000..5acbbdb
--- /dev/null
+++ b/src/components/pixeltower/TargetHUD.tsx
@@ -0,0 +1,55 @@
+import { FC } from 'react';
+import { LuHeart, LuZap } from 'react-icons/lu';
+import { LayoutAvatarImageView } from '../../common';
+import { useTarget } from '../../hooks';
+
+/**
+ * Mirror-layout HUD showing the currently-targeted player's stats.
+ * Visible only after the first UpdateTargetStatsEvent packet lands
+ * (on profile-card view of another user). Re-renders on every
+ * subsequent packet so switching targets updates in place.
+ *
+ * Matches .designs/client_ui.pen frame 1hvgH, scaled to the same
+ * 280px width as StatsHUD.
+ */
+export const TargetHUD: FC<{}> = () =>
+{
+    const { target = null } = useTarget();
+
+    if(!target) return null;
+
+    const { stats } = target;
+    const hpPct = stats.maxHp > 0 ? Math.max(0, Math.min(100, (stats.hp / stats.maxHp) * 100)) : 0;
+    const energyPct = stats.maxEnergy > 0 ? Math.max(0, Math.min(100, (stats.energy / stats.maxEnergy) * 100)) : 0;
+
+    return (
+        <div className="pixeltower-stats-hud pixeltower-stats-hud--target">
+            <div className="pixeltower-stats-hud__row">
+                <div className="pixeltower-stats-hud__avatar">
+                    <div className="pixeltower-stats-hud__avatar-inner">
+                        <LayoutAvatarImageView figure={ target.figure } direction={ 4 } />
+                        <div className="pixeltower-stats-hud__name">{ target.userName }</div>
+                    </div>
+                </div>
+                <div className="pixeltower-stats-hud__bars">
+                    <div className="pixeltower-stats-hud__bar pixeltower-stats-hud__bar--hp">
+                        <div className="pixeltower-stats-hud__bar-track" />
+                        <div className="pixeltower-stats-hud__bar-fill pixeltower-stats-hud__bar-fill--hp" style={ { width: `${ hpPct }%` } } />
+                        <div className="pixeltower-stats-hud__bar-content">
+                            <LuHeart className="pixeltower-stats-hud__bar-icon" />
+                            <span className="pixeltower-stats-hud__bar-label">{ stats.hp }/{ stats.maxHp }</span>
+                        </div>
+                    </div>
+                    <div className="pixeltower-stats-hud__bar pixeltower-stats-hud__bar--energy">
+                        <div className="pixeltower-stats-hud__bar-track" />
+                        <div className="pixeltower-stats-hud__bar-fill pixeltower-stats-hud__bar-fill--energy" style={ { width: `${ energyPct }%` } } />
+                        <div className="pixeltower-stats-hud__bar-content">
+                            <LuZap className="pixeltower-stats-hud__bar-icon" />
+                            <span className="pixeltower-stats-hud__bar-label">{ stats.energy }/{ stats.maxEnergy }</span>
+                        </div>
+                    </div>
+                </div>
+            </div>
+        </div>
+    );
+}
diff --git a/src/components/pixeltower/ToolbarHUD.scss b/src/components/pixeltower/ToolbarHUD.scss
new file mode 100644
index 0000000..11e55ad
--- /dev/null
+++ b/src/components/pixeltower/ToolbarHUD.scss
@@ -0,0 +1,226 @@
+@use './tokens' as *;
+
+// Bottom-center toolbar — matches .designs/client_ui.pen frame Y6gyQ.
+// Replaces upstream .nitro-toolbar entirely. Hosts the
+// #toolbar-chat-input-container portal target that ChatInputView
+// writes into.
+
+$pt-toolbar-chat-top:    #D9DFE6;                   // light-bevel top (soft gray)
+$pt-toolbar-chat-bottom: #FFFFFF;                   // light-bevel bottom (white)
+$pt-toolbar-chat-icon:   #3E4E6E;
+$pt-toolbar-chat-placeholder: #6B7A8F;
+$pt-toolbar-chat-text:   #0A1424;                   // dark typed text on light bevel
+
+.pixeltower-toolbar-hud {
+    position: fixed;
+    bottom: 12px;
+    left: 12px;
+    right: 12px;
+    // Above Nitro's global `canvas { z-index: 1000 }` so the HUD isn't
+    // occluded the moment RoomView un-hides. All pixeltower HUDs share
+    // this tier.
+    z-index: 1100;
+
+    display: flex;
+    flex-direction: row;
+    align-items: center;
+    gap: 8px;
+    height: 60px;
+    padding: 8px 12px;
+
+    // The toolbar root is transparent per .designs/client_ui.pen frame
+    // Y6gyQ — no background, border, blur, or rim shadow. The buttons
+    // and chat field carry their own chrome; the container is layout only.
+    background: transparent;
+
+    &__left-group {
+        // Staff-only buttons (Navigator, Shop, Mod Tools) live here;
+        // non-staff render nothing. The group flexes to fill the space
+        // between the toolbar's left edge and the chatfield and
+        // left-aligns its contents (default justify-content), matching
+        // `.pen` Y6gyQ > W0BVS where the buttons sit at the far left.
+        flex: 1 1 0;
+        display: flex;
+        flex-direction: row;
+        align-items: center;
+        gap: 8px;
+        align-self: stretch;
+    }
+
+    &__chat-field {
+        display: flex;
+        flex-direction: row;
+        align-items: center;
+        gap: 8px;
+        width: 420px;
+        max-width: 60%;
+        height: 40px;
+        padding: 8px 12px;
+        border: 2px solid $pt-panel-stroke;
+        border-radius: 3px;
+        // light-bevel: soft-gray top, white bottom — inverse of the dark chip
+        // gradient used on the button groups. Per .pen qkSYj > hKnXO.
+        background: linear-gradient(180deg,
+            $pt-toolbar-chat-top 0%, $pt-toolbar-chat-top 50%,
+            $pt-toolbar-chat-bottom 50%, $pt-toolbar-chat-bottom 100%);
+        box-shadow: 0 -1px 0 #FFFFFF;                // white top-edge highlight per .pen qkSYj > hKnXO
+    }
+
+    &__chat-input-slot {
+        flex: 1 1 0;
+        min-width: 0;
+        display: flex;
+        align-items: center;
+
+        // Placeholder visible only before ChatInputView portals its
+        // DOM into this slot (first frame on mount).
+        &:empty::before {
+            content: 'Say something…';
+            font-family: $pt-font-family;
+            font-size: 14px;
+            font-weight: 700;
+            color: $pt-toolbar-chat-placeholder;
+        }
+
+        // Neutralise the upstream chat-input pill (#EDEDED body, black
+        // border, 8px radius, ::before highlight, overflow:hidden).
+        // Every descendant rule is nested inside this block so the
+        // compiled selector chain is 3 classes deep (specificity 0,3,_)
+        // — upstream's `.nitro-chat-input-container .input-sizer`
+        // (0,2,0) would otherwise win the cascade on offset, silently
+        // reinstating `display: inline-grid` + `padding: 0 10px` and
+        // shoving the placeholder right.
+        .nitro-chat-input-container {
+            flex: 1 1 auto;
+            display: flex;
+            align-items: center;
+            gap: 8px;
+            width: 100%;
+            max-width: 100%;
+            padding: 0;
+            background: transparent;
+            border: 0;
+            border-radius: 0;
+            box-shadow: none;
+            overflow: visible;
+
+            &::before { display: none; }
+
+            // Upstream: display:inline-grid + padding:0 10px. Replace
+            // with flex fill so the placeholder anchors left, right
+            // after the chat-bubble icon.
+            .input-sizer {
+                flex: 1 1 auto;
+                min-width: 0;
+                padding: 0;
+                background: transparent;
+                display: flex;
+                align-items: center;
+
+                &::after { display: none; }
+            }
+
+            .chat-input,
+            input.chat-input {
+                width: 100%;
+                background: transparent;
+                border: 0;
+                outline: none;
+                color: $pt-toolbar-chat-text;
+                font-family: $pt-font-family;
+                font-size: 14px;
+                font-weight: 700;
+                text-align: left;
+
+                &::placeholder { color: $pt-toolbar-chat-placeholder; }
+            }
+
+            // ChatInputStyleSelectorView's trigger icon sits inline;
+            // the pixeltower design doesn't surface chat-style
+            // customisation, so hide the trigger entirely.
+            .chatstyles-icon { display: none; }
+        }
+    }
+
+    &__right-group {
+        // Mirrors the `&__left-group` so the 420px chatfield sits
+        // horizontally centred in the 800px toolbar. The phone button
+        // is right-aligned inside this group, landing at the far right
+        // of the toolbar (matches `.pen` Y6gyQ > 5rdYe justifyContent:end).
+        flex: 1 1 0;
+        display: flex;
+        align-items: center;
+        justify-content: flex-end;
+        height: 100%;
+    }
+
+    // Grouped button panels — matches .designs/client_ui.pen frame qkSYj.
+    // Staff icons (nav/shop/mod) and device icons (phone/settings) live
+    // inside shared chip panels with vertical dividers between slots.
+    &__group {
+        @include pt-chip;                            // chip gradient + 2px stroke + radius 3
+        display: flex;
+        height: 40px;
+        box-shadow: 0 1px 0 #9AB4D3;                 // periwinkle underglow per design
+        overflow: hidden;                            // clip slot hover fills to the chip's rounded corners
+    }
+
+    &__slot {
+        width: 40px;
+        height: 40px;
+        padding: 0;
+        background: transparent;
+        border: 0;
+        display: flex;
+        align-items: center;
+        justify-content: center;
+        color: $pt-text;
+        cursor: pointer;
+        transition: background-color 120ms ease, filter 120ms ease;
+        font-family: inherit;
+
+        svg { width: 20px; height: 20px; }
+
+        // Translucent white overlay reads as a visible hover affordance
+        // against the chip gradient; the `__group`'s overflow:hidden
+        // clips it to the chip's rounded corners on edge slots.
+        &:hover {
+            background: rgba(255, 255, 255, 0.12);
+            filter: brightness(1.08);
+        }
+
+        &:active {
+            background: rgba(0, 0, 0, 0.18);
+            filter: none;
+        }
+    }
+
+    &__divider {
+        width: 2px;
+        height: 40px;
+        background: $pt-panel-stroke;
+        flex-shrink: 0;
+        align-self: stretch;
+    }
+
+    // Clickable chat-bubble icon inside the chat field — opens chat history.
+    &__chat-history-btn {
+        display: flex;
+        align-items: center;
+        justify-content: center;
+        padding: 0;
+        background: transparent;
+        border: 0;
+        color: $pt-toolbar-chat-icon;
+        cursor: pointer;
+        transition: filter 120ms ease;
+
+        svg {
+            width: 16px;
+            height: 16px;
+            flex: 0 0 auto;
+        }
+
+        &:hover { filter: brightness(1.3); }
+    }
+}
diff --git a/src/components/pixeltower/ToolbarHUD.tsx b/src/components/pixeltower/ToolbarHUD.tsx
new file mode 100644
index 0000000..ecef69d
--- /dev/null
+++ b/src/components/pixeltower/ToolbarHUD.tsx
@@ -0,0 +1,109 @@
+import { FC } from 'react';
+import { LuCompass, LuMessagesSquare, LuPackage, LuSettings, LuShieldAlert, LuShoppingBag, LuSmartphone } from 'react-icons/lu';
+import { CreateLinkEvent, GetSessionDataManager } from '../../api';
+
+// Bottom-center toolbar replacing upstream ToolbarView. Matches
+// .designs/client_ui.pen frame qkSYj (Toolbar HUD "grouped" variant):
+//   leftGroup  — staffGroup chip holding Navigator + Shop + Inventory +
+//                Mod Tools (staff only) with vertical dividers between slots
+//   chatField  — hosts the #toolbar-chat-input-container portal used
+//                by ChatInputView; the chat-bubble icon on the left of
+//                the field is a button that toggles the chat log
+//   rightGroup — deviceGroup chip holding Phone (friends list) +
+//                Settings with a vertical divider between them
+//
+// Staff gate mirrors upstream ToolbarView: GetSessionDataManager().
+// isModerator is populated from the server's SecureLoginOK payload, so
+// it's stable for the session. Non-staff render nothing in the left
+// group; its flex slot still fills so the chatfield stays centred.
+//
+// Also carries a hidden #toolbar-friend-bar-container portal target —
+// FriendsView portals FriendBarView into it unconditionally, so the
+// slot must exist in the DOM even though the pixeltower design
+// doesn't surface the online-friends pill. Removing it triggers
+// React error #200 ("Target container is not a DOM element") the
+// first time FriendsView renders, which unmounts MainView.
+
+export const ToolbarHUD: FC<{}> = () =>
+{
+    const isMod = GetSessionDataManager().isModerator;
+
+    return (
+        <div className="pixeltower-toolbar-hud">
+            <div className="pixeltower-toolbar-hud__left-group">
+                { isMod && (
+                    <div className="pixeltower-toolbar-hud__group">
+                        <button
+                            type="button"
+                            className="pixeltower-toolbar-hud__slot"
+                            aria-label="Navigator"
+                            title="Navigator"
+                            onClick={ () => CreateLinkEvent('navigator/toggle') }>
+                            <LuCompass />
+                        </button>
+                        <div className="pixeltower-toolbar-hud__divider" />
+                        <button
+                            type="button"
+                            className="pixeltower-toolbar-hud__slot"
+                            aria-label="Shop"
+                            title="Shop"
+                            onClick={ () => CreateLinkEvent('catalog/open') }>
+                            <LuShoppingBag />
+                        </button>
+                        <div className="pixeltower-toolbar-hud__divider" />
+                        <button
+                            type="button"
+                            className="pixeltower-toolbar-hud__slot"
+                            aria-label="Inventory"
+                            title="Inventory"
+                            onClick={ () => CreateLinkEvent('inventory/toggle') }>
+                            <LuPackage />
+                        </button>
+                        <div className="pixeltower-toolbar-hud__divider" />
+                        <button
+                            type="button"
+                            className="pixeltower-toolbar-hud__slot"
