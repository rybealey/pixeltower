+            $pt-avatar-inner-top 0%, $pt-avatar-inner-top 50%,
+            $pt-avatar-inner-bottom 50%, $pt-avatar-inner-bottom 100%);
+        overflow: hidden;
+        display: flex;
+        flex-direction: column;
+        justify-content: flex-end;
+
+        .avatar-image {
+            position: absolute;
+            top: -30px;
+            left: 50%;
+            transform: translateX(-50%);
+            width: 64px;
+            height: 110px;
+            background-position: center top;
