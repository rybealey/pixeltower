@@ -0,0 +1,61 @@
+import { FC } from 'react';
+import { LuDollarSign, LuGem, LuMessageSquare, LuSettings } from 'react-icons/lu';
+import { CreateLinkEvent } from '../../api';
+import { usePurse } from '../../hooks';
+
+const DIAMOND_CURRENCY_TYPE = 5;
+
+/**
+ * Top-right Status HUD — replaces the legacy PurseView. Matches the
+ * client_ui.pen frame KVhc5: a VIP chip showing remaining HC days, a
+ * chat-history button, a settings button, plus coin and diamond rows.
+ * All data sourced from the existing usePurse hook, so HC days / coins
+ * / diamonds stay live on every credits / currency / subscription event.
+ */
+export const StatusHUD: FC<{}> = () =>
+{
+    const { purse = null } = usePurse();
+
+    if(!purse) return null;
+
+    const totalClubDays = (purse.clubPeriods * 31) + purse.clubDays;
+    const coins = Math.floor(purse.credits);
+    const diamonds = purse.activityPoints?.get(DIAMOND_CURRENCY_TYPE) ?? 0;
+
+    return (
+        <div className="pixeltower-status-hud">
+            <div className="pixeltower-status-hud__top-row">
+                <button
+                    type="button"
+                    className="pixeltower-status-hud__vip-chip"
+                    onClick={ () => CreateLinkEvent('habboUI/open/hccenter') }
+                    title="Habbo Club">
+                    <span className="pixeltower-status-hud__vip-badge">VIP</span>
+                    <span className="pixeltower-status-hud__vip-days">{ totalClubDays } d.</span>
+                </button>
+                <button
+                    type="button"
+                    className="pixeltower-status-hud__button"
+                    onClick={ () => CreateLinkEvent('chat-history/toggle') }
+                    title="Chat history">
+                    <LuMessageSquare />
+                </button>
+                <button
+                    type="button"
+                    className="pixeltower-status-hud__button"
+                    onClick={ () => CreateLinkEvent('user-settings/toggle') }
+                    title="Settings">
+                    <LuSettings />
+                </button>
+            </div>
+            <div className="pixeltower-status-hud__row">
+                <LuDollarSign className="pixeltower-status-hud__row-icon pixeltower-status-hud__row-icon--coin" />
+                <span className="pixeltower-status-hud__row-value">{ coins }</span>
+            </div>
+            <div className="pixeltower-status-hud__row">
+                <LuGem className="pixeltower-status-hud__row-icon pixeltower-status-hud__row-icon--diamond" />
+                <span className="pixeltower-status-hud__row-value">{ diamonds }</span>
+            </div>
+        </div>
+    );
+}
