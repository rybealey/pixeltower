.env
.env.local
.env.production
.env.*.local

# Persistent data (bind-mounted volumes)
/data/

# Third-party sources cloned in at bootstrap
/atomcms/
/nitro/
/docker/converter/app/
/docker/imager/app/

# Emulator — JAR is built into the image from upstream; only ignore local
# overrides (optional host-supplied JAR + plugins) and rendered config.
/emulator/*.jar
/emulator/plugins/
/emulator/config.ini

# Gamedata (large, not source-controlled)
/gamedata/

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/
