# ─── Environment ────────────────────────────────────────────────────────────
# "local"       → http://localhost, no TLS, nginx dev config
# "production"  → https://pixeltower.digital, Let's Encrypt TLS, nginx prod config
APP_ENV=local
DOMAIN=localhost
APP_URL=http://localhost

# Required when APP_ENV=production
LETSENCRYPT_EMAIL=you@example.com

# ─── Database (shared by AtomCMS + Arcturus) ────────────────────────────────
DB_HOST=db
DB_PORT=3306
DB_DATABASE=atom
DB_USERNAME=atom
DB_PASSWORD=change-me-strong
DB_ROOT_PASSWORD=change-me-stronger

# ─── AtomCMS (Laravel) ──────────────────────────────────────────────────────
APP_NAME=Pixelworld
APP_DEBUG=true
APP_KEY=                              # leave blank; `php artisan key:generate` fills it
TINYMCE_KEY=
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# URLs the CMS hands to the Nitro client. In dev these are http://localhost/...
IMAGER_URL=http://localhost/imager
STATIC_URL=http://localhost/gamedata
CLIENT_URL=http://localhost/client
STATIC_PATH=/var/www/gamedata

# ─── Emulator (Arcturus Morningstar) ────────────────────────────────────────
EMU_WS_PORT=2095
EMU_GAME_PORT=3000
EMU_RCON_PORT=3001
EMU_XMX=2048m

# ─── Host UID/GID for bind-mounted volumes (avoid root-owned files) ─────────
UID=1000
GID=1000

# ─── Backups (compose-managed cron container) ───────────────────────────────
# Cron schedule in standard 5-field syntax. Default: daily at 04:00 TZ.
BACKUP_SCHEDULE=0 4 * * *
BACKUP_RETENTION_DAYS=14
TZ=UTC
