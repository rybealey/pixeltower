# ─── Environment ────────────────────────────────────────────────────────────
# "local"       → http://localhost, no TLS, nginx dev config
# "production"  → https://pixeltower.digital, Cloudflare Origin Cert, nginx prod
APP_ENV=local
DOMAIN=localhost
APP_URL=http://localhost

# ─── AtomCMS (Laravel) ──────────────────────────────────────────────────────
APP_NAME=Pixeltower
APP_DEBUG=true
# APP_KEY is filled by `php artisan key:generate`
APP_KEY=
TINYMCE_API_KEY=
TURNSTILE_ENABLED=false
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
FINDRETROS_ENABLED=false
FINDRETROS_NAME=pixeltower

# Nitro client path (served by nginx at /client/ from ./nitro/dist)
NITRO_CLIENT_PATH=/client
FORCE_HTTPS=false
FLASH_CLIENT_ENABLED=false

# ─── Database (shared by AtomCMS + Arcturus) ────────────────────────────────
DB_HOST=db
DB_PORT=3306
DB_DATABASE=habbo
DB_USERNAME=cms
DB_PASSWORD=change-me-strong
DB_ROOT_PASSWORD=change-me-stronger

# ─── Emulator (Arcturus Morningstar) ────────────────────────────────────────
EMU_WS_PORT=2096
EMU_GAME_PORT=3000
EMU_RCON_PORT=3001
EMU_XMX=2048m
EMU_TIMEZONE=Europe/Amsterdam

# ─── Imager (nitro-imager) ──────────────────────────────────────────────────
IMAGER_API_HOST=imager
IMAGER_API_PORT=3030

# ─── Backups ────────────────────────────────────────────────────────────────
BACKUP_SCHEDULE="0 4 * * *"
BACKUP_RETENTION_DAYS=14
TZ=UTC

# ─── Host UID/GID for bind-mounted volumes ──────────────────────────────────
UID=1000
GID=1000
